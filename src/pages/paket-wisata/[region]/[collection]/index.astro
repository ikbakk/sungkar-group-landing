---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import PackageCard from "@/components/cards/PackageCard.astro";

import { packages } from "@/lib/content/tourPackages";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

export function getStaticPaths() {
  return packages
    .map((pkg) => ({
      region: pkg.region,
      collection: pkg.collectionSlug,
    }))
    .filter(
      (value, index, self) =>
        index ===
        self.findIndex(
          (item) =>
            item.region === value.region &&
            item.collection === value.collection,
        ),
    )
    .map((item) => ({
      params: item,
    }));
}

const region = Astro.params.region as Region;
const collection = Astro.params.collection!;

const collectionPackages = packages.filter(
  (pkg) => pkg.region === region && pkg.collectionSlug === collection,
);

const collectionTitle = collectionPackages[0]?.collectionTitle ?? "";
---

<MainLayout
  title={collectionTitle}
  description={`Pilihan paket wisata ${collectionTitle} di ${REGION_LABEL[region]}.`}
  canonical={`/paket-wisata/${region}/${collection}`}
>
  <PageHeader
    eyebrow="Paket Wisata"
    title={`Pilihan paket wisata ${collectionTitle} di ${REGION_LABEL[region]}`}
    description={`Pilih kategori paket wisata ${collectionTitle} di ${REGION_LABEL[region]}.`}
    breadcrumbs={[
      {
        label: "Beranda",
        href: "/",
      },
      {
        label: "Paket Wisata",
        href: "/paket-wisata",
      },
      {
        label: REGION_LABEL[region],
        href: `/paket-wisata/${region}`,
      },
      {
        label: collectionTitle,
      },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {collectionPackages.map((tour) => <PackageCard tour={tour} />)}
    </div>
  </SectionContainer>
</MainLayout>

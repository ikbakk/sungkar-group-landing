---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import PackageCard from "@/components/cards/PackageCard.astro";

import { getPackages } from "@/lib/content/tourPackages/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import { getGlobalStrings, getTourPackagesPageStrings } from "@/lib/i18n";

export async function getStaticPaths() {
  const idPackages = await getPackages("id");
  const paths = [];
  const uniqueColl = idPackages
    .map((pkg) => ({
      region: pkg.region,
      collection: pkg.collectionSlug,
    }))
    .filter(
      (value, index, self) =>
        index ===
        self.findIndex(
          (item) =>
            item.region === value.region &&
            item.collection === value.collection,
        ),
    );
  for (const item of uniqueColl) {
    paths.push({ params: { ...item } });
  }
  return paths;
}

const locale = "id";
const { region, collection } = Astro.params;
const r = region as Region;
const globalStrings = getGlobalStrings(locale);
const packageStrings = getTourPackagesPageStrings(locale);

const packages = await getPackages(locale);
const collectionPackages = packages.filter(
  (pkg) => pkg.region === r && pkg.collectionSlug === collection,
);

const collectionTitle = collectionPackages[0]?.collectionTitle ?? "";
const regionLabel = REGION_LABEL[r];
const normalizedCollectionTitle = collectionTitle.toLowerCase();
const collectionSeoTitle = normalizedCollectionTitle.includes(
  regionLabel.toLowerCase(),
)
  ? collectionTitle
  : `${collectionTitle} ${regionLabel}`;
const collectionDescription = `Temukan pilihan ${collectionSeoTitle} dari Sungkar Group, lengkap dengan rute, durasi, aktivitas utama, dan opsi konsultasi itinerary sesuai kebutuhan perjalanan Anda.`;

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: "/" },
  { label: globalStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
  { label: regionLabel, href: `/paket-wisata/${r}` },
  { label: collectionTitle },
];
---

<MainLayout
  title={collectionSeoTitle}
  description={collectionDescription}
  canonical={`/paket-wisata/${r}/${collection}`}
  locale={locale}
>
  <PageHeader
    eyebrow={packageStrings.paketWisata.eyebrow}
    title={collectionTitle}
    description={collectionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        collectionPackages.map((tour, i) => (
          <PackageCard
            tour={tour}
            locale={locale}
            moreCountLabel={globalStrings.common.moreCount}
            viewPackageDetailLabel={
              packageStrings.paketWisata.viewPackageDetail
            }
            loading={i < 3 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "auto"}
          />
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateProductSchema, generateBreadcrumbSchema, generateFAQPageSchema } from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";

import { packages } from "@/lib/content/tourPackages/index";
import { REGION_LABEL } from "@/lib/regions";

import FaqSection from "@/components/site/Faq.astro";
import PackageImagePreview from "@/components/packages/PackageImagePreview.astro";
import PackageDetailPanel from "@/components/packages/PackageDetailPanel.astro";
import PackageItinerary from "@/components/packages/PackageItinerary.astro";
import PackageIncludesExcludes from "@/components/packages/PackageIncludesExcludes.astro";

import { packageFaq } from "@/lib/content/faqs/package";

import type { TourPackage } from "@/lib/content/tourPackages/types";
import SectionContainer from "@/layouts/SectionContainer.astro";

export function getStaticPaths() {
  return packages.map((tour: TourPackage) => ({
    params: {
      region: tour.region,
      collection: tour.collectionSlug,
      slug: tour.slug,
    },
    props: { tour },
  }));
}

const { tour } = Astro.props;

// Generate schemas
const packageUrl = `${SITE_URL}/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`;
const absoluteImageUrl = new URL(tour.images[0].src, SITE_URL).toString();

const productSchema = generateProductSchema(
  tour.title,
  tour.summary,
  "Hubungi untuk harga",
  absoluteImageUrl,
  packageUrl,
  tour.duration,
);

const faqSchema = generateFAQPageSchema(packageFaq);

const breadcrumbItems = [
  { name: "Beranda", url: "/" },
  { name: "Paket Wisata", url: "/paket-wisata" },
  {
    name: tour.region,
    url: `/paket-wisata/${tour.region}`,
  },
  {
    name: tour.collectionTitle,
    url: `/paket-wisata/${tour.region}/${tour.collectionSlug}`,
  },
  {
    name: tour.title,
    url: `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`,
  },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const itineraryByDay = Object.entries(
  tour.itinerary.reduce((acc: Record<string, string[]>, item: string) => {
    const [day, ...rest] = item.split(" - ");
    const description = rest.join(" - ");
    if (!acc[day]) {
      acc[day] = [];
    }
    acc[day].push(description);
    return acc;
  }, {}),
);
---

<MainLayout
  title={tour.title}
  description={tour.summary}
  canonical={`/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`}
  image={tour.images[0]}
>
  <StructuredData schema={productSchema} />
  <StructuredData schema={breadcrumbSchema} />
  <StructuredData schema={faqSchema} />

  <PageHeader
    eyebrow="Detail Paket"
    title={tour.title}
    description={tour.summary}
    breadcrumbs={[
      {
        label: "Beranda",
        href: "/",
      },
      {
        label: "Paket Wisata",
        href: "/paket-wisata",
      },
      {
        label: REGION_LABEL[tour.region],
        href: `/paket-wisata/${tour.region}`,
      },
      {
        label: tour.collectionTitle,
        href: `/paket-wisata/${tour.region}/${tour.collectionSlug}`,
      },
      {
        label: tour.title,
      },
    ]}
    image={tour.images[0]}
    imageAlt={tour.title}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-stretch">
        <PackageImagePreview {tour} />
        <div class="lg:sticky lg:top-24">
          <PackageDetailPanel {tour} />
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <PackageItinerary {itineraryByDay} />
        <PackageIncludesExcludes {tour} />
      </div>

      <FaqSection
        eyebrow="FAQ"
        title="FAQ Paket Wisata"
        items={packageFaq}
        background="bg-surface-soft"
      />
    </div>
  </SectionContainer>
</MainLayout>

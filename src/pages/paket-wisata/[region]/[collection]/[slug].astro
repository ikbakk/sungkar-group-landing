---
import MainLayout from "@/layouts/MainLayout.astro";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateProductSchema, generateBreadcrumbSchema, generateFAQPageSchema } from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";

import { packages } from "@/lib/content/tourPackages/index";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import PageHeader from "@/components/site/PageHeader.astro";
import PackageItinerary from "@/components/packages/PackageItinerary.astro";
import PackageIncludesExcludes from "@/components/packages/PackageIncludesExcludes.astro";
import PackageGallery from "@/components/packages/PackageGallery";
import FaqSection from "@/components/site/Faq.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselNext,
  CarouselPrevious,
} from "@/components/ui/carousel";
import WhatsAppForm from "@/components/contact/WhatsAppForm.astro";
import { paketWisataFormFields } from "@/lib/contact-data";

import { loadFaq } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";

import type { TourPackage } from "@/lib/content/tourPackages/types";

export function getStaticPaths() {
  const paths = [];
  for (const tour of packages) {
    paths.push({
      params: {
        region: tour.region,
        collection: tour.collectionSlug,
        slug: tour.slug,
      },
      props: { tour },
    });
  }
  return paths;
}

const locale = "id";
const { tour } = Astro.props;
const uiStrings = t(locale);

const r = tour.region as Region;

const packageUrl = `${SITE_URL}/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`;
const absoluteImageUrl = new URL(tour.images[0].src, SITE_URL).toString();

const productSchema = generateProductSchema(
  tour.title,
  tour.summary,
  "Hubungi untuk harga",
  absoluteImageUrl,
  packageUrl,
  tour.duration,
);

const faqModule = await loadFaq(locale, "package");
const { packageFaq } = faqModule;

const faqSchema = generateFAQPageSchema(packageFaq);

const breadcrumbItems = [
  { name: uiStrings.breadcrumb.home, url: "/" },
  { name: uiStrings.breadcrumb.tourPackages, url: "/paket-wisata" },
  { name: REGION_LABEL[r], url: `/paket-wisata/${tour.region}` },
  { name: tour.collectionTitle, url: `/paket-wisata/${tour.region}/${tour.collectionSlug}` },
  { name: tour.title, url: packageUrl },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const itineraryByDay = Object.entries(
  tour.itinerary.reduce((acc: Record<string, string[]>, item: string) => {
    const [day, ...rest] = item.split(" - ");
    const description = rest.join(" - ");
    if (!acc[day]) {
      acc[day] = [];
    }
    acc[day].push(description);
    return acc;
  }, {}),
);
---

<MainLayout
  title={tour.title}
  description={tour.summary}
  canonical={`/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`}
  image={tour.images[0]}
  locale={locale}
>
  <StructuredData schema={productSchema} />
  <StructuredData schema={breadcrumbSchema} />
  <StructuredData schema={faqSchema} />

  <PageHeader
    title={tour.title}
    description={tour.summary}
    breadcrumbs={[
      { label: uiStrings.breadcrumb.home, href: "/" },
      { label: uiStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
      { label: REGION_LABEL[r], href: `/paket-wisata/${tour.region}` },
      { label: tour.collectionTitle, href: `/paket-wisata/${tour.region}/${tour.collectionSlug}` },
      { label: tour.title },
    ]}
    image={tour.images[0]}
    imageAlt={tour.title}
    stats={[
      { label: uiStrings.paketWisata.duration, value: tour.duration },
      { label: uiStrings.paketWisata.category, value: tour.category },
      { label: uiStrings.paketWisata.location, value: REGION_LABEL[r] },
    ]}
  />

  <SectionContainer background="bg-surface-soft" padding="py-16 sm:py-20">
    <PackageItinerary itineraryByDay={itineraryByDay} />
  </SectionContainer>

  <SectionContainer background="bg-white" padding="py-16 sm:py-20">
    <PackageIncludesExcludes tour={tour} />
  </SectionContainer>

  <SectionContainer background="bg-surface-soft" padding="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
        {uiStrings.gallery.title}
      </div>
      <h2 class="mt-2 text-3xl leading-tight sm:text-4xl">
        {uiStrings.gallery.photos}
      </h2>
    </div>

    <div class="mt-10">
      <Carousel opts={{ loop: true, align: "center" }} class="mx-auto max-w-3xl">
        <CarouselContent>
          {tour.images.map((img, i) => (
            <CarouselItem>
              <button
                type="button"
                data-image-index={i}
                class="group cursor-zoom-in overflow-hidden rounded-xl"
              >
                <div class="aspect-[4/3]">
                  <OptimizedImage
                    src={img}
                    alt=""
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              </button>
            </CarouselItem>
          ))}
        </CarouselContent>
        <CarouselPrevious class="left-2 md:-left-12 bg-background" />
        <CarouselNext class="right-2 md:-right-12 bg-background" />
      </Carousel>
    </div>

    <PackageGallery images={tour.images} client:load />
  </SectionContainer>

  <SectionContainer background="bg-white" padding="py-16 sm:py-20">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
      <div class="pt-8">
        <div class="mb-8">
          <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
            {uiStrings.cta.book}
          </div>
          <h2 class="mt-2 text-3xl leading-tight">
            {uiStrings.paketWisata.readyToStart}
          </h2>
        </div>
        <WhatsAppForm
          context="paket-wisata"
          fields={paketWisataFormFields}
          mode="section"
          itemName={tour.title}
          region={REGION_LABEL[r]}
        />
      </div>
      <FaqSection
        eyebrow="FAQ"
        title={uiStrings.faq.sectionTitle}
        items={packageFaq}
        variant="card"
      />
    </div>
  </SectionContainer>

  <SectionContainer background="bg-surface-soft" padding="py-12">
    <div class="flex flex-wrap justify-center gap-2">
      {
        tour.highlights.map((item) => (
          <span class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-3.5 py-1.5 text-sm font-medium text-brand-700">
            {item}
          </span>
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

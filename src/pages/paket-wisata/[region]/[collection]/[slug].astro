---
import PackageDetailPage from "@/components/pages/PackageDetailPage.astro";
import { getPackages } from "@/lib/content/tourPackages/collection";

export async function getStaticPaths() {
  const idPackages = await getPackages("id");
  const paths = [];
  for (const tour of idPackages) {
    paths.push({
      params: {
        region: tour.region,
        collection: tour.collectionSlug,
        slug: tour.slug,
      },
      props: { tour },
    });
  }
  return paths;
}

const locale = "id";
const { tour } = Astro.props;
---

<PackageDetailPage tour={tour} locale={locale} />

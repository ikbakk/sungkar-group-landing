---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { getPackages } from "@/lib/content/tourPackages/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import { getGlobalStrings, getTourPackagesPageStrings } from "@/lib/i18n";

import CollectionCard from "@/components/packages/CollectionCard.astro";

type CCard = {
  slug: string;
  title: string;
  packages: typeof regionPackages;
};

export function getStaticPaths() {
  const regions: Region[] = [
    "lombok",
    "sumbawa",
    "labuan-bajo",
    "sailing-labuan-bajo",
    "lombok-to-bajo",
    "lombok-bajo",
  ];
  const paths = [];
  for (const region of regions) {
    paths.push({ params: { region } });
  }
  return paths;
}

const locale = "id";
const { region } = Astro.params;
const r = region as Region;
const globalStrings = getGlobalStrings(locale);
const packageStrings = getTourPackagesPageStrings(locale);

const packages = await getPackages(locale);
const regionPackages = packages.filter((pkg) => pkg.region === r);

const collections = Object.values(
  regionPackages.reduce<Record<string, CCard>>((acc, pkg) => {
    if (!acc[pkg.collectionSlug]) {
      acc[pkg.collectionSlug] = {
        slug: pkg.collectionSlug,
        title: pkg.collectionTitle,
        packages: [],
      };
    }
    acc[pkg.collectionSlug].packages.push(pkg);
    return acc;
  }, {}),
).sort((a, b) => a.title.localeCompare(b.title));

const REGION_SEO: Record<Region, { title: string; description: string }> = {
  lombok: {
    title: "Paket Wisata Lombok",
    description:
      "Pilih paket wisata Lombok untuk pantai Mandalika, Gili Trawangan, Gili Nanggu, desa budaya Sasak, air terjun, dan rute private tour fleksibel.",
  },
  sumbawa: {
    title: "Paket Wisata Sumbawa",
    description:
      "Temukan paket wisata Sumbawa untuk whale shark Teluk Saleh, Moyo, Kenawa, Sangiang, dan perjalanan laut dari Lombok dengan open trip atau private trip.",
  },
  "labuan-bajo": {
    title: "Paket Wisata Labuan Bajo",
    description:
      "Jelajahi paket wisata Labuan Bajo untuk rute darat Flores, city tour, bukit, pantai, dan itinerary nyaman sebelum atau sesudah sailing Komodo.",
  },
  "sailing-labuan-bajo": {
    title: "Sailing Labuan Bajo",
    description:
      "Bandingkan paket sailing Labuan Bajo ke Komodo, Padar, Pink Beach, Manta Point, dan Taka Makassar dengan pilihan open trip atau private phinisi.",
  },
  "lombok-to-bajo": {
    title: "Paket Lombok ke Labuan Bajo",
    description:
      "Rencanakan perjalanan laut dari Lombok ke Labuan Bajo melewati pulau-pulau eksotis, snorkeling, dan destinasi bahari terbaik Nusa Tenggara.",
  },
  "lombok-bajo": {
    title: "Paket Lombok - Labuan Bajo",
    description:
      "Pilih paket lintas pulau Lombok dan Labuan Bajo dengan opsi keberangkatan dua arah, kapal phinisi, open trip, dan private charter.",
  },
};

const regionSeo = REGION_SEO[r];
const regionDescription = regionSeo.description;

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: "/" },
  { label: globalStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
  { label: REGION_LABEL[r] },
];
---

<MainLayout
  title={regionSeo.title}
  description={regionDescription}
  canonical={`/paket-wisata/${r}`}
  image={regionPackages[0]?.images[0]}
  locale={locale}
>
  <PageHeader
    eyebrow={packageStrings.paketWisata.eyebrow}
    title={regionSeo.title}
    description={regionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        collections.map((collection) => (
          <CollectionCard
            collection={collection}
            region={r}
            packagesAvailableLabel={
              packageStrings.paketWisata.packagesAvailable
            }
            morePackagesLabel={packageStrings.paketWisata.morePackages}
          />
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

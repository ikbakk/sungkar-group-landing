---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { packages } from "@/lib/content/tourPackages/index";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import CollectionCard from "@/components/packages/CollectionCard.astro";

type CollectionCard = {
  slug: string;
  title: string;
  packages: typeof regionPackages;
};

export function getStaticPaths() {
  return [
    { params: { region: "lombok" } },
    { params: { region: "sumbawa" } },
    { params: { region: "labuan-bajo" } },
  ];
}

const region = Astro.params.region as Region;

const regionPackages = packages.filter((pkg) => pkg.region === region);

const collections = Object.values(
  regionPackages.reduce<Record<string, CollectionCard>>((acc, pkg) => {
    if (!acc[pkg.collectionSlug]) {
      acc[pkg.collectionSlug] = {
        slug: pkg.collectionSlug,
        title: pkg.collectionTitle,
        packages: [],
      };
    }
    acc[pkg.collectionSlug].packages.push(pkg);
    return acc;
  }, {}),
);
---

<MainLayout
  title={`Paket Wisata ${REGION_LABEL[region]}`}
  description={`Pilihan paket wisata ${REGION_LABEL[region]}`}
  canonical={`/paket-wisata/${region}`}
  image={regionPackages[0]?.image}
>
  <PageHeader
    eyebrow="Paket Wisata"
    title={`Paket Wisata ${REGION_LABEL[region]}`}
    description={`Pilih kategori paket wisata yang tersedia di ${REGION_LABEL[region]}.`}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Paket Wisata", href: "/paket-wisata" },
      { label: REGION_LABEL[region] },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {collections.map((collection) => (
        <CollectionCard collection={collection} region={region} />
      ))}
    </div>
  </SectionContainer>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent } from "@/components/ui/card";

import { packages } from "@/lib/content/tourPackages";

type Region = "lombok" | "sumbawa" | "labuan-bajo";

type CollectionCard = {
  slug: string;
  title: string;
  packages: typeof regionPackages;
};

export function getStaticPaths() {
  return [
    {
      params: {
        region: "lombok",
      },
    },
    {
      params: {
        region: "sumbawa",
      },
    },
    {
      params: {
        region: "labuan-bajo",
      },
    },
  ];
}

const region = Astro.params.region as Region;

const regionTitleMap: Record<Region, string> = {
  lombok: "Lombok",
  sumbawa: "Sumbawa",
  "labuan-bajo": "Labuan Bajo",
};

const regionPackages = packages.filter((pkg) => pkg.region === region);

const collections = Object.values(
  regionPackages.reduce<Record<string, CollectionCard>>((acc, pkg) => {
    if (!acc[pkg.collectionSlug]) {
      acc[pkg.collectionSlug] = {
        slug: pkg.collectionSlug,
        title: pkg.collectionTitle,
        packages: [],
      };
    }

    acc[pkg.collectionSlug].packages.push(pkg);

    return acc;
  }, {}),
);
---

<MainLayout
  title={`Paket Wisata ${regionTitleMap[region]}`}
  description={`Pilihan paket wisata ${regionTitleMap[region]}`}
  canonical={`/paket-wisata/${region}`}
  image={regionPackages[0]?.image}
>
  <PageHeader
    eyebrow="Paket Wisata"
    title={`Paket Wisata ${regionTitleMap[region]}`}
    description={`Pilih kategori paket wisata yang tersedia di ${regionTitleMap[region]}.`}
    breadcrumbs={[
      {
        label: "Beranda",
        href: "/",
      },
      {
        label: "Paket Wisata",
        href: "/paket-wisata",
      },
      {
        label: regionTitleMap[region],
      },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        collections.map((collection) => (
          <a href={`/paket-wisata/${region}/${collection.slug}`}>
            <Card
              className="
                h-full
                transition-all
                hover:-translate-y-1
                hover:shadow-lg
                cursor-pointer
              "
            >
              <CardContent className="p-6">
                <h2 class="text-xl font-heading">{collection.title}</h2>

                <p class="mt-2 text-sm text-text-muted">
                  {collection.packages.length} paket tersedia
                </p>

                <ul class="mt-4 space-y-2 text-sm text-text-muted">
                  {collection.packages.slice(0, 3).map((pkg) => (
                    <li class="flex gap-2">
                      <span>•</span>
                      <span>{pkg.title}</span>
                    </li>
                  ))}

                  {collection.packages.length > 3 && (
                    <li class="font-medium text-brand-700">
                      +{collection.packages.length - 3} paket lainnya
                    </li>
                  )}
                </ul>
              </CardContent>
            </Card>
          </a>
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

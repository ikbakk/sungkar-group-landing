---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { getPackages } from "@/lib/content/tourPackages/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import { t } from "@/lib/i18n";

import CollectionCard from "@/components/packages/CollectionCard.astro";

type CCard = {
  slug: string;
  title: string;
  packages: typeof regionPackages;
};

export function getStaticPaths() {
  const regions: Region[] = ["lombok", "sumbawa", "labuan-bajo", "sailing-labuan-bajo", "lombok-to-bajo"];
  const paths = [];
  for (const region of regions) {
    paths.push({ params: { region } });
  }
  return paths;
}

const locale = "id";
const { region } = Astro.params;
const r = region as Region;
const uiStrings = t(locale);

const packages = await getPackages(locale);
const regionPackages = packages.filter((pkg) => pkg.region === r);

const collections = Object.values(
  regionPackages.reduce<Record<string, CCard>>((acc, pkg) => {
    if (!acc[pkg.collectionSlug]) {
      acc[pkg.collectionSlug] = {
        slug: pkg.collectionSlug,
        title: pkg.collectionTitle,
        packages: [],
      };
    }
    acc[pkg.collectionSlug].packages.push(pkg);
    return acc;
  }, {}),
).sort((a, b) => a.title.localeCompare(b.title));

const regionDescription = uiStrings.paketWisata.chooseCategory.replace(
  "{region}",
  REGION_LABEL[r],
);

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
  { label: REGION_LABEL[r] },
];
---

<MainLayout
  title={`${uiStrings.paketWisata.packagesFor.replace("{region}", REGION_LABEL[r])}`}
  description={regionDescription}
  canonical={`/paket-wisata/${r}`}
  image={regionPackages[0]?.images[0]}
  locale={locale}
>
  <PageHeader
    eyebrow={uiStrings.paketWisata.eyebrow}
    title={uiStrings.paketWisata.packagesFor.replace(
      "{region}",
      REGION_LABEL[r],
    )}
    description={regionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        collections.map((collection) => (
          <CollectionCard collection={collection} region={r} />
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

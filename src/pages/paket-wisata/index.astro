---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import RelatedContent from "@/components/site/RelatedContent.astro";

import PackageRegionNav from "@/components/packages/PackageRegionNav.astro";
import PackageRegionSection from "@/components/packages/PackageRegionSection.astro";
import PackagePageCta from "@/components/packages/PackagePageCta.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { packages } from "@/lib/content/tourPackages/index";
import { packagePageContent } from "@/lib/content/packagePage";
import { packageFaq } from "@/lib/content/faqs/package";

const lombokPackages = packages.filter((pkg) => pkg.region === "lombok");

const sumbawaPackages = packages.filter((pkg) => pkg.region === "sumbawa");

const labuanBajoPackages = packages.filter(
  (pkg) => pkg.region === "labuan-bajo",
);

const regions = [
  {
    id: "lombok",
    label: "Lombok",
    count: lombokPackages.length,
  },
  {
    id: "sumbawa",
    label: "Sumbawa",
    count: sumbawaPackages.length,
  },
  {
    id: "labuan-bajo",
    label: "Labuan Bajo",
    count: labuanBajoPackages.length,
  },
];
---

<MainLayout
  title="Paket Wisata"
  description={packagePageContent.hero.description}
  canonical="/paket-wisata"
  image={packages[0].image}
>
  <PageHeader
    eyebrow={packagePageContent.hero.eyebrow}
    title={packagePageContent.hero.title}
    description={packagePageContent.hero.description}
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Paket Wisata" }]}
  />

  <PackageRegionNav regions={regions} />

  <SectionContainer background="bg-surface-soft">
    <PackageRegionSection
      id="lombok"
      title={packagePageContent.regions.lombok.title}
      description={packagePageContent.regions.lombok.description}
      packages={lombokPackages}
    />
  </SectionContainer>

  <SectionContainer background="bg-background">
    <PackageRegionSection
      id="sumbawa"
      title={packagePageContent.regions.sumbawa.title}
      description={packagePageContent.regions.sumbawa.description}
      packages={sumbawaPackages}
    />
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <PackageRegionSection
      id="labuan-bajo"
      title={packagePageContent.regions.labuanBajo.title}
      description={packagePageContent.regions.labuanBajo.description}
      packages={labuanBajoPackages}
    />
  </SectionContainer>

  <FaqSection
    eyebrow="FAQ"
    title="Pertanyaan Seputar Paket Wisata"
    items={packageFaq}
  />

  <RelatedContent
    title="Jelajahi Layanan Kami"
    items={[
      {
        title: "Destinasi Wisata",
        href: "/destinasi",
        description:
          "Temukan tempat-tempat indah dan destinasi impian di Lombok, Sumbawa, dan Labuan Bajo",
      },
      {
        title: "Panduan Wisata",
        href: "/panduan-wisata",
        description:
          "Baca panduan lengkap untuk merencanakan perjalanan Anda dengan sempurna",
      },
      {
        title: "Akomodasi",
        href: "/akomodasi",
        description:
          "Pilih hotel dan penginapan terbaik di setiap destinasi wisata",
      },
      {
        title: "Sewa Mobil",
        href: "/sewa-mobil",
        description:
          "Nikmati kenyamanan perjalanan dengan layanan sewa kendaraan kami",
      },
      {
        title: "Tentang Kami",
        href: "/tentang-kami",
        description:
          "Ketahui lebih lanjut tentang Sungkar Group dan pengalaman kami",
      },
    ]}
  />

  <PackagePageCta />
</MainLayout>

<script>
  const links = document.querySelectorAll("[data-region-link]");
  const sections = document.querySelectorAll("[data-region-section]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const id = entry.target.id;

        links.forEach((link) => {
          const active = link.getAttribute("href") === `#${id}`;

          link.classList.toggle("bg-brand-700", active);
          link.classList.toggle("text-white", active);
          link.classList.toggle("border-brand-700", active);
        });
      });
    },
    {
      rootMargin: "-40% 0px -40% 0px",
    },
  );

  sections.forEach((section) => observer.observe(section));
</script>

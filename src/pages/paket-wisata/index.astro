---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import { packages, packageFaqItems } from "@/lib/site-data";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import "../../styles/global.css";
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Paket Wisata | Sungkar Group</title>
    <meta
      name="description"
      content="Daftar paket wisata Lombok dari Sungkar Group dengan detail kartu dan halaman paket tersendiri."
    />
  </head>
  <body>
    <MainLayout>
      <PageHeader
        eyebrow="Paket Wisata"
        title="Paket wisata yang punya halaman detail masing-masing"
        description="Setiap kartu tur mengarah ke halaman paket tersendiri agar itinerary, yang termasuk di dalamnya, dan detail perjalanan bisa dibaca tanpa menebak."
        breadcrumbs={[
          { label: "Beranda", href: "/" },
          { label: "Paket Wisata" },
        ]}
        image={packages[0].image}
        imageAlt="Paket wisata Lombok"
      />

      <section class="bg-surface-soft">
        <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {
              packages.map((tour) => (
                <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
                  <div class="aspect-[4/3] overflow-hidden">
                    <Image
                      src={tour.image}
                      alt={tour.title}
                      class="h-full w-full object-cover"
                    />
                  </div>
                  <CardHeader>
                    <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
                      {tour.category}
                    </Badge>
                    <CardTitle className="text-3xl leading-tight">
                      {tour.title}
                    </CardTitle>
                    <CardDescription className="text-sm leading-6 text-text-muted">
                      {tour.duration}
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <p class="text-sm leading-7 text-text-muted">{tour.summary}</p>
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {tour.highlights.map((item) => (
                        <li class="rounded-full border border-border bg-surface-soft px-3 py-1 text-xs font-medium text-foreground">
                          {item}
                        </li>
                      ))}
                    </ul>
                  </CardContent>
                  <CardFooter className="justify-between gap-3">
                    <Button variant="outline" asChild>
                      <a href={`/paket-wisata/${tour.slug}`}>Lihat detail</a>
                    </Button>
                    <span class="text-xs uppercase tracking-[0.2em] text-text-muted">
                      Halaman detail
                    </span>
                  </CardFooter>
                </Card>
              ))
            }
          </div>

          <div class="mt-12 grid gap-4">
            <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
              FAQ Paket Wisata
            </div>
            {packageFaqItems.map((item) => (
              <details class="rounded-[1.5rem] border border-border bg-white p-6">
                <summary class="cursor-pointer list-none font-medium text-foreground [&::-webkit-details-marker]:hidden">
                  {item.question}
                </summary>
                <p class="mt-4 text-sm leading-7 text-text-muted">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    </MainLayout>
  </body>
</html>

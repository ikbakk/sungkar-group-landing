---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import VehicleRegionSection from "@/components/vehicles/VehicleRegionSection.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { vehicles } from "@/lib/content/car-rental";
import { REGION_LABEL, REGIONS, type RegionKey as Region } from "@/lib/regions";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const region of REGIONS) {
    const regionVehicles = vehicles.filter((v) => v.region === region);
    if (regionVehicles.length === 0) continue;
    paths.push({
      params: { region },
      props: { region, vehicles: regionVehicles },
    });
  }
  return paths;
}

const locale = "id";
const uiStrings = t(locale);

const pageModule = await loadContent(locale, "sewaPage");
const { sewaPageContent } = pageModule;

const faqModule = await loadFaq(locale, "sewa-mobil");
const { sewaMobilFaq } = faqModule;

const faqSchema = generateFAQPageSchema(sewaMobilFaq);

interface Props {
  region: Region;
  vehicles: typeof vehicles;
}

const { region, vehicles: regionVehicles } = Astro.props;

const regionName = REGION_LABEL[region];
const regionDescription = sewaPageContent.regions[region].title;

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.carRental, href: "/car-rental" },
  { label: regionName },
];
---

<MainLayout
  title={`${uiStrings.sewaMobil.title} ${regionName}`}
  description={regionDescription}
  canonical={`/car-rental/${region}`}
  image={regionVehicles[0]?.imageTop}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={uiStrings.sewaMobil.vehicleFor.replace("{region}", regionName)}
    title={uiStrings.sewaMobil.vehicleFor.replace("{region}", regionName)}
    description={regionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <VehicleRegionSection
      id={region}
      title={uiStrings.sewaMobil.rentalVehicles.replace("{region}", regionName)}
      description={uiStrings.sewaMobil.allVehicles.replace("{region}", regionName)}
      vehicles={regionVehicles}
    />
  </SectionContainer>

  <FaqSection
    eyebrow="FAQ"
    title={uiStrings.sewaMobil.faqTitleFor.replace("{region}", regionName)}
    items={sewaMobilFaq}
    background="bg-surface-soft"
  />
</MainLayout>

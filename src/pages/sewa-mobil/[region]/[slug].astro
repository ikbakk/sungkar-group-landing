---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import RelatedLinkCardsSection from "@/components/site/RelatedLinkCardsSection.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { generateServiceSchema, generateBreadcrumbSchema, generateFAQPageSchema } from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";

import { getVehicles } from "@/lib/content/car-rental/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";
import { sewaMobilFormFields } from "@/lib/contact-data";

import VehicleDetailPanel from "@/components/vehicles/VehicleDetailPanel.astro";
import WhatsAppForm from "@/components/contact/WhatsAppForm.astro";

import { t } from "@/lib/i18n";
import { loadContent, loadFaq } from "@/lib/i18n/loader";
import { getImageSrc } from "@/lib/images";

export async function getStaticPaths() {
  const vehicles = await getVehicles("id");
  const paths = [];
  for (const vehicle of vehicles) {
    paths.push({
      params: { region: vehicle.region, slug: vehicle.slug },
      props: { vehicle },
    });
  }
  return paths;
}

const locale = "id";
const { vehicle } = Astro.props;
const uiStrings = t(locale);

const vehicleUrl = `${SITE_URL}/sewa-mobil/${vehicle.region}/${vehicle.slug}`;
const absoluteImageUrl = new URL(
  getImageSrc(vehicle.imageTop),
  SITE_URL,
).toString();

const serviceSchema = generateServiceSchema(
  vehicle.name,
  vehicle.description,
  vehicle.pricePerDay,
  absoluteImageUrl,
  vehicleUrl,
  uiStrings.sewaMobil.title,
);

const breadcrumbItems = [
  { name: uiStrings.breadcrumb.home, url: "/" },
  { name: uiStrings.breadcrumb.carRental, url: "/sewa-mobil" },
  { name: REGION_LABEL[vehicle.region], url: `/sewa-mobil/${vehicle.region}` },
  { name: vehicle.name, url: `/sewa-mobil/${vehicle.region}/${vehicle.slug}` },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const faqModule = await loadFaq(locale, "sewa-mobil");
const { sewaMobilFaq } = faqModule;
const pageModule = await loadContent(locale, "sewaPage");
const { sewaPageContent } = pageModule;
const faqSchema = generateFAQPageSchema(sewaMobilFaq);

const r = vehicle.region as Region;
---

<MainLayout
  title={`${vehicle.name} - ${uiStrings.sewaMobil.title} ${REGION_LABEL[r]}`}
  description={vehicle.description}
  canonical={`/sewa-mobil/${vehicle.region}/${vehicle.slug}`}
  image={vehicle.imageTop}
  locale={locale}
>
  <StructuredData schema={serviceSchema} />
  <StructuredData schema={breadcrumbSchema} />
  <StructuredData schema={faqSchema} />

  <PageHeader
    eyebrow={uiStrings.sewaMobil.vehicleDetail}
    title={vehicle.name}
    description={vehicle.description}
    breadcrumbs={[
      { label: uiStrings.breadcrumb.home, href: "/" },
      { label: uiStrings.breadcrumb.carRental, href: "/sewa-mobil" },
      { label: REGION_LABEL[r], href: `/sewa-mobil/${vehicle.region}` },
      { label: vehicle.name },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <div class="space-y-8">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto]">
          <VehicleDetailPanel {vehicle} />
          <div class="w-full lg:w-96 overflow-hidden flex lg:flex-col gap-8">
            <OptimizedImage
              src={vehicle.imageTop}
              alt={vehicle.name}
              class="aspect-4/3 w-full object-cover rounded-lg"
              loading="lazy"
            />

            <OptimizedImage
              src={vehicle.imageBottom}
              alt={vehicle.name}
              class="aspect-4/3 w-full object-cover rounded-lg"
              loading="lazy"
            />
          </div>
        </div>
        <WhatsAppForm
          context="sewa-mobil"
          fields={sewaMobilFormFields}
          mode="sidebar"
          itemName={vehicle.name}
          region={REGION_LABEL[r]}
        />
      </div>
    </div>
  </SectionContainer>
  <FaqSection
    eyebrow={uiStrings.faq.sectionTitle}
    title={uiStrings.faq.sectionCarRental}
    items={sewaMobilFaq}
    background="bg-surface-soft"
  />

  <SectionContainer background="bg-white" padding="py-14 sm:py-16">
    <RelatedLinkCardsSection
      title={sewaPageContent.relatedContentTitle}
      buttonLabel={uiStrings.common.learnMore}
      items={sewaPageContent.relatedContent}
    />
  </SectionContainer>
</MainLayout>

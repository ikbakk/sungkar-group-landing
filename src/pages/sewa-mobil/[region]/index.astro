---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import VehicleRegionSection from "@/components/vehicles/VehicleRegionSection.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { vehicles } from "@/lib/content/sewaMobilData";
import { sewaPageContent } from "@/lib/content/sewaPage";
import { sewaMobilFaq } from "@/lib/content/faqs/sewa-mobil";
import { REGION_LABEL, REGIONS, type RegionKey as Region } from "@/lib/regions";

const faqSchema = generateFAQPageSchema(sewaMobilFaq);

export async function getStaticPaths() {
  const regions = REGIONS;

  return regions
    .map((region) => {
      const regionVehicles = vehicles.filter((v) => v.region === region);
      if (regionVehicles.length === 0) return null;

      return {
        params: { region },
        props: { region, vehicles: regionVehicles },
      };
    })
    .filter((entry) => entry !== null);
}

interface Props {
  region: Region;
  vehicles: typeof vehicles;
}

const { region, vehicles: regionVehicles } = Astro.props;

const regionName = REGION_LABEL[region];
const regionDescription = sewaPageContent.regions[region].title;
---

<MainLayout
  title={`Sewa Mobil ${regionName}`}
  description={regionDescription}
  canonical={`/sewa-mobil/${region}`}
  image={regionVehicles[0]?.imageTop}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={`Sewa Mobil ${regionName}`}
    title={`Kendaraan Rental di ${regionName}`}
    description={regionDescription}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Sewa Mobil", href: "/sewa-mobil" },
      { label: regionName },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <VehicleRegionSection
      id={region}
      title={`Pilihan Kendaraan ${regionName}`}
      description={`Semua kendaraan di ${regionName} telah diperiksa kondisinya dan dilengkapi dengan asuransi komprehensif untuk keamanan perjalanan Anda.`}
      vehicles={regionVehicles}
    />
  </SectionContainer>

  <FaqSection
    eyebrow="FAQ"
    title={`Pertanyaan Seputar Sewa Mobil ${regionName}`}
    items={sewaMobilFaq}
    background="bg-surface-soft"
  />
</MainLayout>

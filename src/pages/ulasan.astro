---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import ReviewsGridSection from "@/components/reviews/ReviewsGridSection.astro";
import ReviewStatsSection from "@/components/reviews/ReviewStatsSection.astro";
import ReviewsCtaSection from "@/components/reviews/ReviewsCtaSection.astro";
import ReviewGallerySection from "@/components/reviews/ReviewGallerySection.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import { reviewsFaq } from "@/lib/content/faqs/reviews";
import {
  reviewsPageContent,
  reviews,
  reviewStats,
} from "@/lib/content/reviewPage";

const faqSchema = generateFAQPageSchema(reviewsFaq);
---

<MainLayout
  title="Ulasan"
  description="Ulasan Google, foto, dan sinyal kepercayaan untuk Sungkar Group."
  canonical="/ulasan"
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow="Ulasan"
    title="Ulasan Google, foto, dan sinyal kepercayaan"
    description="Halaman ini menampilkan suara tamu, nuansa layanan, dan alasan orang memilih Sungkar Group untuk perjalanan Lombok yang lebih rapi."
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Ulasan" }]}
    transition:animate={"slide"}
  />

  <SectionContainer background="bg-surface-soft">
    <ReviewStatsSection
      rating={reviewStats.rating}
      totalReviews={reviewStats.totalReviews}
    />
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <ReviewsGridSection reviews={reviews} />
  </SectionContainer>

  <SectionContainer background="bg-background">
    <!-- <TrustSignalSection
      title={reviewsPageContent.trust.title}
      items={reviewsPageContent.trust.description}
    /> -->
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <ReviewGallerySection />
  </SectionContainer>

  <FaqSection
    eyebrow="FAQ"
    title="Pertanyaan Seputar Ulasan"
    items={reviewsFaq}
  />

  <SectionContainer background="bg-surface-soft">
    <ReviewsCtaSection
      title={reviewsPageContent.cta.title}
      description={reviewsPageContent.cta.description}
    />
  </SectionContainer>
</MainLayout>

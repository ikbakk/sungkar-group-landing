---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import ReviewsGridSection from "@/components/reviews/ReviewsGridSection.astro";
import ReviewStatsSection from "@/components/reviews/ReviewStatsSection.astro";
import ReviewInsightsSection from "@/components/reviews/ReviewInsightsSection.astro";
import ReviewGallerySection from "@/components/reviews/ReviewGallerySection.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";

const locale = "id";
const uiStrings = t(locale);

const faqModule = await loadFaq(locale, "reviews");
const { reviewsFaq } = faqModule;

const pageModule = await loadContent(locale, "reviewPage");
const { reviewsPageContent, reviews, reviewStats } = pageModule;

const faqSchema = generateFAQPageSchema(reviewsFaq);

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.reviews },
];
---

<MainLayout
  title={uiStrings.page.reviews}
  description={reviewsPageContent.hero.description}
  canonical="/ulasan"
  locale={locale}
  enableClientRouter={true}
>
  <StructuredData schema={faqSchema} />

  <PageHeader
    eyebrow={reviewsPageContent.hero.eyebrow}
    title={reviewsPageContent.hero.title}
    description={reviewsPageContent.hero.description}
    breadcrumbs={breadcrumbs}
    transition:animate={"slide"}
  />

  <SectionContainer background="bg-white">
    <ReviewStatsSection
      locale={locale}
      rating={reviewStats.rating}
      totalReviews={reviewStats.totalReviews}
    />
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <ReviewsGridSection reviews={reviews} />
  </SectionContainer>

  <SectionContainer background="bg-white">
    <ReviewInsightsSection
      insights={reviewsPageContent.insights}
      seeOnGoogleMaps={uiStrings.reviews.seeOnGoogleMaps}
      seeAllReviews={uiStrings.reviews.seeAllReviews}
    />
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <ReviewGallerySection locale={locale} />
  </SectionContainer>

  <FaqSection
    eyebrow={uiStrings.faq.sectionTitle}
    title={uiStrings.faq.sectionReviews}
    items={reviewsFaq}
  />
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { accommodations } from "@/lib/content/akomodasiData";
import { akomodasiPageContent } from "@/lib/content/akomodasiPage";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import AccommodationCard from "@/components/cards/AccommodationCard.astro";

import type { Accommodation } from "@/lib/content/akomodasiData";

export function getStaticPaths() {
  const regions: Region[] = ["lombok", "sumbawa", "labuan-bajo"];

  return regions.map((region) => ({
    params: { slug: region },
    props: { region },
  }));
}

const { region } = Astro.props as { region: Region };
const regionAccommodations = accommodations.filter(
  (acc) => acc.region === region,
);

const regionName = REGION_LABEL[region];
---

<MainLayout
  title={`Akomodasi ${regionName}`}
    description={`Temukan akomodasi terbaik di ${regionName} untuk pengalaman menginap yang sempurna`}
  canonical={`/akomodasi/${region}`}
  image={regionAccommodations[0]?.image}
>
  <PageHeader
    eyebrow="Pilihan Akomodasi"
    title={`Akomodasi ${regionName}`}
    description={`Jelajahi berbagai pilihan penginapan berkualitas di ${regionName} yang disesuaikan dengan kebutuhan dan preferensi perjalanan Anda.`}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Akomodasi", href: "/akomodasi" },
      { label: regionName },
    ]}
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {regionAccommodations.map((accommodation) => (
        <AccommodationCard accommodation={accommodation} />
      ))}
    </div>
  </SectionContainer>
</MainLayout>

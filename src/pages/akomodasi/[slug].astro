---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";

import { accommodations } from "@/lib/content/akomodasiData";

import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";

import type { Accommodation } from "@/lib/content/akomodasiData";

export function getStaticPaths() {
  const regions = ["lombok", "sumbawa", "labuan-bajo"];
  
  return regions.map((region) => ({
    params: { slug: region },
    props: { 
      region,
      regionName: region.charAt(0).toUpperCase() + region.slice(1).replace("-", " ")
    },
  }));
}

const { region, regionName } = Astro.props;
const regionAccommodations = accommodations.filter(
  (acc) => acc.region === region
);

// Format region name for breadcrumb
const regionDisplay =
  region === "labuan-bajo"
    ? "Labuan Bajo"
    : region.charAt(0).toUpperCase() + region.slice(1);
---

<MainLayout
  title={`Akomodasi ${regionDisplay}`}
  description={`Temukan akomodasi terbaik di ${regionDisplay} untuk pengalaman menginap yang sempurna`}
  canonical={`/akomodasi/${region}`}
  image={regionAccommodations[0]?.image}
>
  <PageHeader
    eyebrow="Pilihan Akomodasi"
    title={`Akomodasi ${regionDisplay}`}
    description={`Jelajahi berbagai pilihan penginapan berkualitas di ${regionDisplay} yang disesuaikan dengan kebutuhan dan preferensi perjalanan Anda.`}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Akomodasi", href: "/akomodasi" },
      { label: regionDisplay },
    ]}
  />

  <section class="bg-surface-soft">
    <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        {
          regionAccommodations.map((accommodation) => (
            <Card className="border-border overflow-hidden bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)] transition-all duration-300 hover:shadow-[0_18px_55px_rgba(17,24,39,0.1)]">
              <div className="relative h-64 w-full overflow-hidden rounded-t-lg">
                <Image
                  src={accommodation.image}
                  alt={accommodation.name}
                  className="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>

              <CardHeader>
                <CardTitle className="text-2xl leading-tight">
                  {accommodation.name}
                </CardTitle>
              </CardHeader>

              <CardContent className="space-y-4">
                <p className="text-sm leading-7 text-text-muted">
                  {accommodation.description}
                </p>

                <div>
                  <div className="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700">
                    Fasilitas & Layanan
                  </div>
                  <div className="flex flex-wrap gap-2">
                    {accommodation.perks.map((perk) => (
                      <Badge variant="outline" className="rounded-full px-3 py-1">
                        {perk}
                      </Badge>
                    ))}
                  </div>
                </div>

                <Separator />

                <div>
                  <div className="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700">
                    Keunggulan Lokasi
                  </div>
                  <ul className="space-y-1 text-sm leading-7 text-text-muted">
                    {accommodation.regionalHighlights.map((highlight) => (
                      <li className="flex gap-2">
                        <span>✓</span>
                        <span>{highlight}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <Separator />

                <div className="flex flex-wrap gap-3">
                  <Button href="/kontak" variant="outline" className="flex-1">
                    Tanyakan
                  </Button>
                  <Button href="/kontak" className="flex-1">
                    Hubungi
                  </Button>
                </div>
              </CardContent>
            </Card>
          ))
        }
      </div>

      <div class="mt-12 rounded-2xl border border-border bg-white p-8 text-center shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
        <h3 class="text-2xl font-heading leading-tight">
          Tidak menemukan akomodasi yang cocok?
        </h3>
        <p class="mt-2 text-text-muted">
          Tim kami siap membantu Anda menemukan penginapan sempurna sesuai budget dan preferensi Anda.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <Button href="/kontak" variant="outline">
            Konsultasi Gratis
          </Button>
          <Button href="/kontak">Chat WhatsApp</Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

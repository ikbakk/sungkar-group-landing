---
import MainLayout from "@/layouts/MainLayout.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Button } from "@/components/ui/button";

const locale = "id";
---

<MainLayout
  title="Halaman Tidak Ditemukan"
  description="Halaman yang Anda cari tidak ditemukan atau telah dipindahkan."
  noIndex={true}
  locale={locale}
>
  <SectionContainer background="bg-surface-soft" padding="py-24 sm:py-32">
    <div class="mx-auto max-w-xl text-center">
      <p class="text-8xl font-bold text-brand-600">404</p>
      <h1 class="mt-4 text-3xl leading-tight sm:text-4xl">
        Halaman Tidak Ditemukan
      </h1>
      <p class="mt-4 text-base leading-7 text-text-muted">
        Halaman yang Anda cari mungkin telah dipindahkan, dihapus, atau tidak pernah ada.
      </p>
      <div class="mt-8">
        <Button as="a" href="/" variant="default" size="lg">
          Kembali ke Beranda
        </Button>
      </div>
    </div>
  </SectionContainer>
</MainLayout>

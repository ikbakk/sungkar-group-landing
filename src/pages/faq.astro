---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { HERO } from "@/assets/images";

const locale = "id";
const uiStrings = t(locale);

const faqModule = await loadFaq(locale, "general");
const { generalFaqItems } = faqModule;

const pageModule = await loadContent(locale, "faqPage");
const { faqPageContent } = pageModule;

const faqSchema = generateFAQPageSchema(generalFaqItems);

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.faq },
];
---

<MainLayout
  title="FAQ"
  description={faqPageContent.hero.description}
  canonical="/faq"
  image={HERO.lombok}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={faqPageContent.hero.eyebrow}
    title={faqPageContent.hero.title}
    description={faqPageContent.hero.description}
    breadcrumbs={breadcrumbs}
    image={HERO.lombok}
    imageAlt="Lombok saat matahari terbit"
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
      <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <Card class="border-border bg-white">
          <CardHeader>
            <Badge variant="outline" class="w-fit rounded-full px-3 py-1">
              {faqPageContent.introCard.badge}
            </Badge>
            <CardTitle class="text-3xl leading-tight">
              {faqPageContent.introCard.title}
            </CardTitle>
          </CardHeader>
          <CardContent class="text-sm leading-7 text-text-muted">
            <p>{faqPageContent.introCard.description}</p>
          </CardContent>
        </Card>

        <div class="grid gap-4">
          {
            generalFaqItems.map((item) => (
              <details class="rounded-[1.5rem] border border-border bg-white p-6">
                <summary class="cursor-pointer list-none font-medium text-foreground [&::-webkit-details-marker]:hidden">
                  {item.question}
                </summary>
                <p class="mt-4 text-sm leading-7 text-text-muted">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {faqPageContent.relatedCards.map((card) => (
          <Card class="border-border bg-white">
            <CardHeader>
              <Badge variant="outline" class="w-fit rounded-full px-3 py-1">
                {card.badge}
              </Badge>
              <CardTitle class="text-3xl leading-tight">{card.title}</CardTitle>
            </CardHeader>
            <CardContent class="grid gap-3 text-sm leading-7 text-text-muted">
              <p>{card.description}</p>
              <Button href={card.buttonHref} variant="outline">
                {card.buttonLabel}
              </Button>
            </CardContent>
          </Card>
        ))}
      </div>
  </SectionContainer>
</MainLayout>

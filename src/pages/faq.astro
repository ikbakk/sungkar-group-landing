---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import { generalFaqItems } from "@/lib/content/faqs/general";
import { faqPageContent } from "@/lib/content/faqPage";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import HeroLombok from "@/assets/images/hero-lombok.webp";

const faqSchema = generateFAQPageSchema(generalFaqItems);
---

<MainLayout
  title="FAQ"
  description="Pertanyaan yang sering ditanyakan tentang layanan, paket, destinasi, dan cara memulai pemesanan."
  canonical="/faq"
  image={HeroLombok}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={faqPageContent.hero.eyebrow}
    title={faqPageContent.hero.title}
    description={faqPageContent.hero.description}
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "FAQ" }]}
    image={HeroLombok}
    imageAlt="Lombok saat matahari terbit"
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
      <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <Card className="border-border bg-white">
          <CardHeader>
            <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
              {faqPageContent.introCard.badge}
            </Badge>
            <CardTitle className="text-3xl leading-tight">
              {faqPageContent.introCard.title}
            </CardTitle>
          </CardHeader>
          <CardContent className="text-sm leading-7 text-text-muted">
            <p>{faqPageContent.introCard.description}</p>
          </CardContent>
        </Card>

        <div class="grid gap-4">
          {
            generalFaqItems.map((item) => (
              <details class="rounded-[1.5rem] border border-border bg-white p-6">
                <summary class="cursor-pointer list-none font-medium text-foreground [&::-webkit-details-marker]:hidden">
                  {item.question}
                </summary>
                <p class="mt-4 text-sm leading-7 text-text-muted">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {faqPageContent.relatedCards.map((card) => (
          <Card className="border-border bg-white">
            <CardHeader>
              <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
                {card.badge}
              </Badge>
              <CardTitle className="text-3xl leading-tight">{card.title}</CardTitle>
            </CardHeader>
            <CardContent className="grid gap-3 text-sm leading-7 text-text-muted">
              <p>{card.description}</p>
              <Button href={card.buttonHref} variant="outline">
                {card.buttonLabel}
              </Button>
            </CardContent>
          </Card>
        ))}
      </div>
  </SectionContainer>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import RelatedContent from "@/components/site/RelatedContent.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StickyNav from "@/components/ui/StickyNav.astro";
import DestinationGroupSection from "@/components/destinations/DestinationGroupSection.astro";
import { destinations } from "@/lib/content/destinationsData";
import { destinationsPageContent } from "@/lib/content/destinationsPage";

import "../../styles/global.css";

const faqSchema = generateFAQPageSchema(destinationsPageContent.faq);

const destinationBySlug = new Map(
  destinations.map((destination) => [destination.slug, destination]),
);

const groups = destinationsPageContent.groups.map((group) => ({
  ...group,
  count: group.destinationSlugs.length,
  destinations: group.destinationSlugs
    .map((slug) => destinationBySlug.get(slug))
    .filter((destination): destination is (typeof destinations)[number] => Boolean(destination)),
}));
---

<MainLayout
  title="Destinasi"
  description={destinationsPageContent.hero.description}
  canonical="/destinasi"
  image={destinationsPageContent.spotlightImage}
>
  <StructuredData schema={faqSchema} />
  <div id="top" />

  <PageHeader
    eyebrow={destinationsPageContent.hero.eyebrow}
    title={destinationsPageContent.hero.title}
    description={destinationsPageContent.hero.description}
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Destinasi" }]}
    image={destinationsPageContent.spotlightImage}
    imageAlt="Destinasi Lombok"
  />

  <StickyNav
    items={groups.map(({ id, label, count }) => ({ id, label, count }))}
    dataAttr="destination-group-link"
  />

  {groups.map((group, index) => (
    <SectionContainer background={index % 2 === 0 ? "bg-surface-soft" : "bg-background"}>
      <DestinationGroupSection
        id={group.id}
        title={group.title}
        description={group.description}
        destinations={group.destinations}
      />
    </SectionContainer>
  ))}

  <FaqSection
    eyebrow="FAQ"
    title={destinationsPageContent.detail.faqTitle}
    items={destinationsPageContent.faq}
  />

  <RelatedContent
    title="Layanan Terkait"
    items={destinationsPageContent.relatedContent}
    background="bg-surface-soft"
  />
</MainLayout>

---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import {
  generateTouristAttractionSchema,
  generateBreadcrumbSchema,
  generateFAQPageSchema,
} from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";
import { destinations } from "@/lib/content/destinationsData";
import { packages } from "@/lib/content/tourPackages";
import { destinationsPageContent } from "@/lib/content/destinationsPage";
import SectionContainer from "@/layouts/SectionContainer.astro";
import FaqSection from "@/components/site/Faq.astro";
import DestinationDetailPanel from "@/components/destinations/DestinationDetailPanel.astro";
import DestinationInfoCards from "@/components/destinations/DestinationInfoCards.astro";

import "../../styles/global.css";

export function getStaticPaths() {
  return destinations.map((destination) => ({
    params: { slug: destination.slug },
    props: { destination },
  }));
}

const { destination } = Astro.props;

const relatedPackages = packages.filter((tour) =>
  destination.packages.includes(tour.slug),
);

// Generate structured data schemas
const absoluteImageUrl = new URL(destination.image.src, SITE_URL).toString();

const touristAttractionSchema = generateTouristAttractionSchema(
  destination.title,
  destination.summary,
  absoluteImageUrl,
  SITE_URL,
  destination.slug,
  destination.region,
);

const breadcrumbItems = [
  { name: "Beranda", url: "/" },
  { name: "Destinasi", url: "/destinasi" },
  { name: destination.title, url: `/destinasi/${destination.slug}` },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const faqSchema = generateFAQPageSchema(destinationsPageContent.faq);
---

<MainLayout
  title={destination.title}
  description={destination.summary}
  canonical={`/destinasi/${destination.slug}`}
  image={destination.image}
>
  <StructuredData schema={touristAttractionSchema} />
  <StructuredData schema={breadcrumbSchema} />
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={destinationsPageContent.detail.headline}
    title={destination.title}
    description={destination.summary}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Destinasi", href: "/destinasi" },
      { label: destination.title },
    ]}
    image={destination.image}
    imageAlt={destination.title}
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
    <DestinationDetailPanel
      destination={destination}
      relatedPackages={relatedPackages}
      content={destinationsPageContent.detail}
    />

    <DestinationInfoCards
      summary={destination.summary}
      content={destinationsPageContent.detail}
    />

    <FaqSection
      eyebrow="FAQ"
      title={destinationsPageContent.detail.faqTitle}
      items={destinationsPageContent.faq}
      variant="card"
      background="bg-surface-soft"
    />
  </SectionContainer>
</MainLayout>

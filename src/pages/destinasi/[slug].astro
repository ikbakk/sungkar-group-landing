---
import DestinationDetailPage from "@/components/pages/DestinationDetailPage.astro";
import { getDestinations } from "@/lib/content/destinations/collection";

export async function getStaticPaths() {
  const paths = [];
  for (const destination of await getDestinations("id")) {
    paths.push({
      params: { slug: destination.slug },
      props: { destination },
    });
  }
  return paths;
}

const locale = "id";
const { destination } = Astro.props;
---

<DestinationDetailPage destination={destination} locale={locale} />

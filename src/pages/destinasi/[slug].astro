---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import {
  generateTouristAttractionSchema,
  generateBreadcrumbSchema,
  generateFAQPageSchema,
} from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";
import { destinations } from "@/lib/content/destinationsData";
import { packages } from "@/lib/content/tourPackages";
import { destinationsPageContent } from "@/lib/content/destinationsPage";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import FaqSection from "@/components/site/Faq.astro";

import "../../styles/global.css";

export function getStaticPaths() {
  return destinations.map((destination) => ({
    params: { slug: destination.slug },
    props: { destination },
  }));
}

const { destination } = Astro.props;

const relatedPackages = packages.filter((tour) =>
  destination.packages.includes(tour.slug),
);

// Generate structured data schemas
const absoluteImageUrl = new URL(destination.image.src, SITE_URL).toString();

const touristAttractionSchema = generateTouristAttractionSchema(
  destination.title,
  destination.summary,
  absoluteImageUrl,
  SITE_URL,
  destination.slug,
  destination.region,
);

const breadcrumbItems = [
  { name: "Beranda", url: "/" },
  { name: "Destinasi", url: "/destinasi" },
  { name: destination.title, url: `/destinasi/${destination.slug}` },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const faqSchema = generateFAQPageSchema(destinationsPageContent.faq);
---

<MainLayout
  title={destination.title}
  description={destination.summary}
  canonical={`/destinasi/${destination.slug}`}
  image={destination.image}
>
  <StructuredData schema={touristAttractionSchema} />
  <StructuredData schema={breadcrumbSchema} />
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={destinationsPageContent.detail.headline}
    title={destination.title}
    description={destination.summary}
    breadcrumbs={[
      { label: "Beranda", href: "/" },
      { label: "Destinasi", href: "/destinasi" },
      { label: destination.title },
    ]}
    image={destination.image}
    imageAlt={destination.title}
  />

  <section class="bg-surface-soft">
    <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div
          class="overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
        >
          <Image
            src={destination.image}
            alt={destination.title}
            class="h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="grid gap-6">
          <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
            <CardHeader>
              <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
                {destination.region}
              </Badge>
              <CardTitle className="text-3xl leading-tight">
                {destinationsPageContent.detail.activitiesTitle}
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div class="grid gap-3">
                {
                  destination.thingsToDo.map((item) => (
                    <div class="rounded-2xl border border-border bg-surface-soft px-4 py-3 text-sm font-medium text-foreground">
                      {item}
                    </div>
                  ))
                }
              </div>
            </CardContent>
          </Card>

          <Card className="border-border bg-brand-900 text-white shadow-[0_16px_45px_rgba(17,24,39,0.1)]">
            <CardHeader>
              <CardTitle className="text-3xl leading-tight text-white">
                {destinationsPageContent.detail.relatedPackagesTitle}
              </CardTitle>
            </CardHeader>
            <CardContent>
              {relatedPackages.length > 0 ? (
                <div class="grid gap-3">
                  {
                    relatedPackages.map((tour) => (
                      <a
                        href={`/paket-wisata/${tour.slug}`}
                        class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition-colors hover:bg-white/10"
                      >
                        {tour.title}
                      </a>
                    ))
                  }
                </div>
              ) : (
                <p class="text-sm leading-7 text-brand-100">
                  {destinationsPageContent.detail.emptyRelatedPackages}
                </p>
              )}
            </CardContent>
          </Card>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
          <CardHeader>
            <CardTitle className="text-3xl leading-tight">
              {destinationsPageContent.detail.summaryTitle}
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm leading-7 text-text-muted">
              {destination.summary}
            </p>
          </CardContent>
        </Card>

        <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
          <CardHeader>
            <CardTitle className="text-3xl leading-tight">
              {destinationsPageContent.detail.transportTitle}
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div class="grid gap-3 text-sm leading-7 text-text-muted">
              <p>{destinationsPageContent.detail.transportDescription}</p>
              <Separator />
              <p>{destinationsPageContent.detail.transportNote}</p>
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              <Button href="/kontak" variant="outline">
                Cek Ketersediaan
              </Button>
              <Button href="/kontak">Chat WhatsApp</Button>
            </div>
          </CardContent>
        </Card>
      </div>

      <FaqSection
        eyebrow="FAQ"
        title={destinationsPageContent.detail.faqTitle}
        items={destinationsPageContent.faq}
        variant="card"
        background="bg-surface-soft"
      />
    </div>
  </section>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { BlogCard } from "@/components/blog";
import { getBlogPosts } from "@/lib/content/blog";

import { t } from "@/lib/i18n";

const locale = "id";
const uiStrings = t(locale);
const posts = await getBlogPosts(locale);
const description = uiStrings.blogSection.description;

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.blog },
];
---

<MainLayout
  title={`${uiStrings.page.blog} - Sungkar Group`}
  description={description}
  canonical="/blog"
  locale={locale}
>
  <PageHeader
    eyebrow={uiStrings.page.blog}
    title={uiStrings.page.blog}
    description={description}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-background">
    {
      posts.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard post={post} locale={locale} />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <p class="text-text-muted">{uiStrings.blogSection.emptyState}</p>
        </div>
      )
    }
  </SectionContainer>
</MainLayout>

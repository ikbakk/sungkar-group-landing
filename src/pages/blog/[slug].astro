---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { BlogPostLayout } from "@/components/blog";
import { getBlogPosts, getBlogPost } from "@/lib/content/blog";
import { generateArticleSchema } from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";
import { BlogCard } from "@/components/blog";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { t } from "@/lib/i18n";

export async function getStaticPaths() {
  const posts = await getBlogPosts("id");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

const locale = "id";
const uiStrings = t(locale);
const { slug } = Astro.props;
const post = await getBlogPost(locale, slug);

if (!post) {
  return Astro.redirect("/blog", 404);
}

const { Content, title, description, publishDate, readingTime, tags, featuredImage } = post;

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: "Blog", href: "/blog" },
  { label: title },
];

const articleImage = featuredImage || "";
const articleSchema = generateArticleSchema(title, description, articleImage, SITE_URL, `blog/${slug}`, publishDate.toISOString());
---

<MainLayout
  title={`${title} - Blog Sungkar Group`}
  description={description}
  canonical={`/blog/${slug}`}
  image={featuredImage}
  imageAlt={title}
  locale={locale}
>
  <StructuredData schema={articleSchema} />

  <PageHeader
    eyebrow="Blog"
    title={title}
    description={description}
    breadcrumbs={breadcrumbs}
  />

  <BlogPostLayout
    title={title}
    description={description}
    publishDate={publishDate}
    readingTime={readingTime}
    readingTimeLabel={uiStrings.guides.readingTime}
    tags={tags}
    locale={locale}
  >
    <Content />
  </BlogPostLayout>

  <SectionContainer background="bg-background">
    <div class="mx-auto max-w-4xl">
      <div class="border-t border-border pt-8">
        <p class="mb-4 text-sm font-medium text-text-muted">{uiStrings.blogSection.share}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`https://wa.me/?text=${encodeURIComponent(`${title} - ${SITE_URL}/blog/${slug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a
            href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`${SITE_URL}/blog/${slug}`)}&text=${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-black px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`${SITE_URL}/blog/${slug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-[#1877F2] px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <button
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-accent"
            id="copy-link-btn"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            {uiStrings.blogSection.copyLink}
          </button>
        </div>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <div class="mx-auto max-w-4xl">
      <div class="mb-8">
        <h2 class="text-3xl leading-tight text-foreground">
          {uiStrings.blogSection.relatedPosts}
        </h2>
        <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
          {uiStrings.blogSection.relatedPostsDesc}
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          (await getBlogPosts(locale))
            .filter((p) => p.slug !== slug)
            .slice(0, 3)
            .map((p) => <BlogCard post={p} locale={locale} />)
        }
      </div>
    </div>
  </SectionContainer>
</MainLayout>

<script is:inline define:vars={{ uiStrings }}>
  document.getElementById("copy-link-btn")?.addEventListener("click", async () => {
    const url = window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      const btn = document.getElementById("copy-link-btn");
      if (btn) {
        const original = btn.innerHTML;
        btn.innerHTML = `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> ${uiStrings.blogSection.linkCopied}`;
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      }
    } catch { /* ignore */ }
  });
</script>

<style is:global>
  .article-content {
    font-family: var(--font-sans);
  }

  .article-content h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .article-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-content p {
    color: var(--color-foreground);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  .article-content ul,
  .article-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  .article-content ul {
    list-style-type: disc;
  }

  .article-content ol {
    list-style-type: decimal;
  }

  .article-content li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
    color: var(--color-foreground);
  }

  .article-content strong {
    font-weight: 600;
    color: var(--color-foreground);
  }
</style>

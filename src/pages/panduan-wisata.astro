---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import RelatedContent from "@/components/site/RelatedContent.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";
import { guides } from "@/lib/content/guides";
import { destinations } from "@/lib/content/destinationsData";
import { packages } from "@/lib/content/tourPackages";
import { generalFaqItems } from "@/lib/content/faqs/general";
import GuideCard from "@/components/guides/GuideCard.astro";
import LinkCardList from "@/components/site/LinkCardList.astro";

const faqSchema = generateFAQPageSchema(generalFaqItems);
---

<MainLayout
  title="Panduan Wisata"
  description="Panduan lengkap untuk merencanakan perjalanan wisata Anda ke Lombok dengan tips, trik, dan rekomendasi dari para ahli lokal."
  canonical="/panduan-wisata"
>
  <StructuredData schema={faqSchema} />

  <PageHeader
    eyebrow="Panduan Wisata"
    title="Panduan wisata untuk merencanakan perjalanan sempurna"
    description="Baca panduan mendalam kami yang mencakup waktu terbaik untuk berkunjung, cara memilih tur, dan tips transportasi lokal yang efisien."
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Panduan Wisata" }]}
  />

  <SectionContainer background="bg-surface-soft" padding="py-16">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">
        Panduan Lengkap Kami
      </h2>
      <p class="mt-2 text-muted-foreground">
        Pelajari segala yang perlu Anda ketahui untuk merencanakan perjalanan wisata yang sempurna
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {guides.map((guide) => <GuideCard {guide} />)}
    </div>
  </SectionContainer>

  <SectionContainer background="bg-background" padding="py-16">
    <div class="grid gap-6 lg:grid-cols-2">
      <LinkCardList
        title="Destinasi terkait"
        items={destinations.slice(0, 8).map((d) => ({
          title: d.title,
          href: `/destinasi/${d.slug}`,
        }))}
      />
      <LinkCardList
        title="Paket terkait"
        items={packages.map((p) => ({
          title: p.title,
          href: `/paket-wisata/${p.slug}`,
        }))}
        variant="branded"
      />
    </div>
  </SectionContainer>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import LandingPage from "@/components/landing/LandingPage.astro";
import { loadContent } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";
import { BRAND } from "@/assets/images";

const landingModule = await loadContent("id", "landing");
const { landingHero, landingFeaturedTours, landingDestinations, landingTransport, landingTestimonials, landingVideo, landingBackgroundImage } = landingModule;
const uiStrings = t("id");
---

<MainLayout
  title={landingHero.title}
  description={landingHero.description}
  canonical="/"
  image={BRAND.ogHome}
  imageAlt={uiStrings.common.imageAltSunset}
  locale="id"
>
  <LandingPage
    hero={landingHero}
    featuredTours={landingFeaturedTours}
    destinations={landingDestinations}
    transport={landingTransport}
    testimonials={landingTestimonials}
    video={landingVideo}
    backgroundImage={landingBackgroundImage}
  />
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import LandingPage from "@/components/landing/LandingPage.astro";
import { loadContent } from "@/lib/i18n/loader";
import { getGlobalStrings } from "@/lib/i18n";
import { OG } from "@/assets/images";
import { getDestinations } from "@/lib/content/destinations/collection";
import { toLandingDestinationCard } from "@/lib/content/landing";
import { getPackages } from "@/lib/content/tourPackages/collection";
import { toLandingTourCard } from "@/lib/content/landing";

const landingModule = await loadContent("id", "landing");
const {
  landingHero,
  landingFeaturedToursBase,
  landingDestinationsBase,
  landingTransport,
  landingTestimonials,
  landingVideo,
  landingBackgroundImage,
} = landingModule;
const packages = await getPackages("id");
const allDestinations = await getDestinations("id");
const landingFeaturedTours = {
  ...landingFeaturedToursBase,
  tours: packages
    .filter((p) => p.featured)
    .sort((a, b) => {
      const order = [
        "open-trip-motogp-mandalika-2026-4-hari-3-malam",
        "paket-wisata-lombok-3-hari-2-malam-snorkeling-3-gili-mandalika",
        "open-trip-whale-shark-sumbawa",
        "paket-wisata-pantai-kuta-lombok-desa-suku-sasak",
        "open-trip-maheswari",
        "luxury-ocean-angel",
      ];
      return order.indexOf(a.slug) - order.indexOf(b.slug);
    })
    .map(toLandingTourCard),
};
const landingDestinations = {
  ...landingDestinationsBase,
  destinations: allDestinations.slice(0, 4).map(toLandingDestinationCard),
};
const globalStrings = getGlobalStrings("id");
---

<MainLayout
  title={landingHero.title}
  description={landingHero.description}
  canonical="/"
  image={OG.home}
  imageAlt={globalStrings.common.imageAltSunset}
  locale="id"
>
  <LandingPage
    hero={landingHero}
    featuredTours={landingFeaturedTours}
    destinations={landingDestinations}
    transport={landingTransport}
    testimonials={landingTestimonials}
    video={landingVideo}
    backgroundImage={landingBackgroundImage}
  />
</MainLayout>

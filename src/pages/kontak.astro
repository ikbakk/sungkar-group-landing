---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { generalFaqItems } from "@/lib/site-data";
---

<MainLayout
  title="Kontak"
  description="Hubungi Sungkar Group untuk cek ketersediaan, itinerary, dan layanan WhatsApp."
  canonical="/kontak"
>
  <PageHeader
    eyebrow="Kontak"
    title="Hubungi Sungkar Group untuk itinerary, paket, atau transportasi"
    description="Sampaikan tanggal perjalanan, jumlah tamu, titik penjemputan, dan prioritas destinasi. Dari situ kami bisa menyusun opsi yang paling masuk akal."
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Kontak" }]}
  />

  <section class="bg-surface-soft">
    <div class="section-container pb-20">
      <div class="grid-form">
        <Card className="border-border bg-white">
          <CardHeader>
            <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
              Metode kontak
            </Badge>
            <CardTitle className="text-3xl leading-tight"
              >Cara menghubungi tim</CardTitle
            >
          </CardHeader>
          <CardContent className="grid gap-3">
            <div class="info-box">
              <div class="info-box-title">
                Cek Ketersediaan
              </div>
              <div class="info-box-description">
                Gunakan alur pertanyaan untuk memastikan tanggal perjalanan dan
                rute yang paling praktis.
              </div>
            </div>
            <div class="info-box">
              <div class="info-box-title">
                Chat WhatsApp
              </div>
              <div class="info-box-description">
                Paling cocok untuk pertanyaan cepat, konfirmasi pesan, dan
                penyesuaian itinerary.
              </div>
            </div>
            <div class="info-box">
              <div class="info-box-title">
                Saluran sosial
              </div>
              <div class="info-box-description">
                Instagram dan YouTube ditampilkan di footer untuk pembaruan
                perjalanan dan cerita destinasi.
              </div>
            </div>
          </CardContent>
        </Card>

        <Card className="border-border bg-brand-900 text-white">
          <CardHeader>
            <Badge variant="secondary" className="w-fit rounded-full px-3 py-1">
              Formulir pertanyaan
            </Badge>
            <CardTitle className="text-3xl leading-tight text-white"
              >Ceritakan rencana perjalanan Anda</CardTitle
            >
          </CardHeader>
          <CardContent className="grid gap-4">
            <label class="grid gap-2">
              <span class="form-label-light">Tanggal perjalanan</span>
              <input
                class="form-input-dark"
                placeholder="Contoh: 12 Agustus 2026"
              />
            </label>
            <label class="grid gap-2">
              <span class="form-label-light">Jumlah tamu</span>
              <input
                class="form-input-dark"
                placeholder="Contoh: 4 dewasa"
              />
            </label>
            <label class="grid gap-2">
              <span class="form-label-light">Fokus destinasi</span>
              <input
                class="form-input-dark"
                placeholder="Contoh: Gili dan Kuta"
              />
            </label>
            <div class="flex flex-wrap gap-3 pt-2">
              <Button href="/kontak" variant="secondary">
                Cek Ketersediaan
              </Button>
              <Button href="/kontak">Chat WhatsApp</Button>
            </div>
          </CardContent>
        </Card>
      </div>

      <div class="mt-10 grid gap-4">
        {
          generalFaqItems.map((item) => (
            <details class="faq-accordion">
              <summary class="faq-summary">
                {item.question}
              </summary>
              <p class="faq-answer">
                {item.answer}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>

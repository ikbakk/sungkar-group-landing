---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { generalFaqItems } from "@/lib/site-data";
import "../styles/global.css";
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Kontak | Sungkar Group</title>
    <meta
      name="description"
      content="Hubungi Sungkar Group untuk cek ketersediaan, itinerary, dan layanan WhatsApp."
    />
  </head>
  <body>
    <MainLayout>
      <PageHeader
        eyebrow="Kontak"
        title="Hubungi Sungkar Group untuk itinerary, paket, atau transportasi"
        description="Sampaikan tanggal perjalanan, jumlah tamu, titik penjemputan, dan prioritas destinasi. Dari situ kami bisa menyusun opsi yang paling masuk akal."
        breadcrumbs={[
          { label: "Beranda", href: "/" },
          { label: "Kontak" },
        ]}
      />

      <section class="bg-surface-soft">
        <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
          <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
            <Card className="border-border bg-white">
              <CardHeader>
                <Badge variant="outline" className="w-fit rounded-full px-3 py-1">
                  Metode kontak
                </Badge>
                <CardTitle className="text-3xl leading-tight">Cara menghubungi tim</CardTitle>
              </CardHeader>
              <CardContent className="grid gap-3">
                <div class="rounded-2xl border border-border bg-surface-soft px-4 py-3">
                  <div class="text-sm font-medium text-foreground">Cek Ketersediaan</div>
                  <div class="mt-1 text-sm leading-7 text-text-muted">Gunakan alur pertanyaan untuk memastikan tanggal perjalanan dan rute yang paling praktis.</div>
                </div>
                <div class="rounded-2xl border border-border bg-surface-soft px-4 py-3">
                  <div class="text-sm font-medium text-foreground">Chat WhatsApp</div>
                  <div class="mt-1 text-sm leading-7 text-text-muted">Paling cocok untuk pertanyaan cepat, konfirmasi pesan, dan penyesuaian itinerary.</div>
                </div>
                <div class="rounded-2xl border border-border bg-surface-soft px-4 py-3">
                  <div class="text-sm font-medium text-foreground">Saluran sosial</div>
                  <div class="mt-1 text-sm leading-7 text-text-muted">Instagram dan YouTube ditampilkan di footer untuk pembaruan perjalanan dan cerita destinasi.</div>
                </div>
              </CardContent>
            </Card>

            <Card className="border-border bg-brand-900 text-white">
              <CardHeader>
                <Badge variant="secondary" className="w-fit rounded-full px-3 py-1">
                  Formulir pertanyaan
                </Badge>
                <CardTitle className="text-3xl leading-tight text-white">Ceritakan rencana perjalanan Anda</CardTitle>
              </CardHeader>
              <CardContent className="grid gap-4">
                <label class="grid gap-2 text-sm">
                  <span class="text-brand-100">Tanggal perjalanan</span>
                  <input class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-brand-100/50" placeholder="Contoh: 12 Agustus 2026" />
                </label>
                <label class="grid gap-2 text-sm">
                  <span class="text-brand-100">Jumlah tamu</span>
                  <input class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-brand-100/50" placeholder="Contoh: 4 dewasa" />
                </label>
                <label class="grid gap-2 text-sm">
                  <span class="text-brand-100">Fokus destinasi</span>
                  <input class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-brand-100/50" placeholder="Contoh: Gili dan Kuta" />
                </label>
                <div class="flex flex-wrap gap-3 pt-2">
                  <Button variant="secondary" asChild>
                    <a href="/kontak">Cek Ketersediaan</a>
                  </Button>
                  <Button asChild>
                    <a href="/kontak">Chat WhatsApp</a>
                  </Button>
                </div>
              </CardContent>
            </Card>
          </div>

          <div class="mt-10 grid gap-4">
            {generalFaqItems.map((item) => (
              <details class="rounded-[1.5rem] border border-border bg-white p-6">
                <summary class="cursor-pointer list-none font-medium text-foreground [&::-webkit-details-marker]:hidden">
                  {item.question}
                </summary>
                <p class="mt-4 text-sm leading-7 text-text-muted">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    </MainLayout>
  </body>
</html>

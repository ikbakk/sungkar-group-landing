---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import ContactForm from "@/components/contact/ContactForm.astro";
import ContactInfoSection from "@/components/contact/ContactInfoSection.astro";
import EmbeddedMap from "@/components/contact/EmbeddedMap.astro";
import { generalFaqItems } from "@/lib/site-data";
import {
  businessInfo,
  contactFormFields,
  geoLocation,
} from "@/lib/contact-data";
import { generateContactPageSchema, generateFAQPageSchema } from "@/lib/schemas";

const siteUrl = Astro.site?.toString() || "https://sungkargroup.com";
const contactSchema = generateContactPageSchema(siteUrl, businessInfo);
const faqSchema = generateFAQPageSchema(generalFaqItems);
---

<MainLayout
  title="Kontak"
  description="Hubungi Sungkar Group untuk cek ketersediaan, itinerary, dan layanan WhatsApp. Tersedia via phone, email, WhatsApp, dan formulir online."
  canonical="/kontak"
>
  <StructuredData schema={contactSchema} />
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow="Kontak"
    title="Hubungi Sungkar Group untuk itinerary, paket, atau transportasi"
    description="Sampaikan tanggal perjalanan, jumlah tamu, titik penjemputan, dan prioritas destinasi. Dari situ kami bisa menyusun opsi yang paling masuk akal."
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Kontak" }]}
  />

  <!-- Contact Section with Map and Form -->
  <section class="bg-surface-soft">
    <div class="section-container section-padding">
      <!-- Map Section -->
      <div class="mb-12">
        <EmbeddedMap
          latitude={geoLocation.latitude}
          longitude={geoLocation.longitude}
          zoom={geoLocation.zoom}
          businessName={businessInfo.name}
          businessAddress={`${businessInfo.address.street}, ${businessInfo.address.city}`}
        />
      </div>

      <!-- Contact Form and Info Grid -->
      <div class="grid-form">
        <ContactInfoSection
          businessInfo={businessInfo}
          title="Informasi Kontak"
          description="Berbagai cara untuk menghubungi tim kami"
        />

        <ContactForm
          fields={contactFormFields}
          businessInfo={businessInfo}
          title="Ceritakan rencana perjalanan Anda"
          description="Formulir pertanyaan"
        />
      </div>

      <!-- FAQ Section -->
      <div class="mt-16">
        <div class="mb-8 text-center">
          <h2 class="section-title text-left">Pertanyaan yang Sering Diajukan</h2>
          <p class="section-description text-left">
            Cari jawaban dari pertanyaan umum tentang layanan kami
          </p>
        </div>

        <div class="grid gap-4">
          {
            generalFaqItems.map((item) => (
              <details class="faq-accordion">
                <summary class="faq-summary">
                  {item.question}
                </summary>
                <p class="faq-answer">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>

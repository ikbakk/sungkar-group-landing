---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import StickyNav from "@/components/ui/StickyNav.astro";
import RegionObserver from "@/components/ui/RegionObserver.astro";
import RegionNavCard from "@/components/ui/RegionNavCard.astro";
import AccommodationRegionSection from "@/components/accommodations/AccommodationRegionSection.astro";
import PackagePageCta from "@/components/packages/PackagePageCta.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { accommodations } from "@/lib/content/akomodasiData";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import { t } from "@/lib/i18n";

const locale = "id";
const uiStrings = t(locale);

const pageModule = await loadContent(locale, "akomodasiPage");
const { akomodasiPageContent } = pageModule;

const faqModule = await loadFaq(locale, "akomodasi");
const { akomodasiFaq } = faqModule;

const faqSchema = generateFAQPageSchema(akomodasiFaq);

const lombokAccommodations = accommodations.filter(
  (acc) => acc.region === "lombok"
);

const sumbawaAccommodations = accommodations.filter(
  (acc) => acc.region === "sumbawa"
);

const labuanBajoAccommodations = accommodations.filter(
  (acc) => acc.region === "labuan-bajo"
);

const regions = [
  { id: "lombok", label: "Lombok", count: lombokAccommodations.length },
  { id: "sumbawa", label: "Sumbawa", count: sumbawaAccommodations.length },
  { id: "labuan-bajo", label: "Labuan Bajo", count: labuanBajoAccommodations.length },
].filter((region) => region.count > 0);

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: "/" },
  { label: uiStrings.breadcrumb.accommodations },
];
---

<MainLayout
  title={uiStrings.akomodasi.title}
  description={akomodasiPageContent.hero.description}
  canonical="/accommodations"
  image={accommodations[0]?.image}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={akomodasiPageContent.hero.eyebrow}
    title={akomodasiPageContent.hero.title}
    description={akomodasiPageContent.hero.description}
    breadcrumbs={breadcrumbs}
  />

  {regions.length > 0 && <StickyNav items={regions} />}

  {lombokAccommodations.length > 0 && (
    <SectionContainer background="bg-surface-soft">
      <AccommodationRegionSection
        id="lombok"
        title={akomodasiPageContent.regions.lombok.title}
        description={akomodasiPageContent.regions.lombok.description}
        accommodations={lombokAccommodations}
      />
    </SectionContainer>
  )}

  {sumbawaAccommodations.length > 0 && (
    <SectionContainer background="bg-background">
      <AccommodationRegionSection
        id="sumbawa"
        title={akomodasiPageContent.regions.sumbawa.title}
        description={akomodasiPageContent.regions.sumbawa.description}
        accommodations={sumbawaAccommodations}
      />
    </SectionContainer>
  )}

  {labuanBajoAccommodations.length > 0 && (
    <SectionContainer background="bg-surface-soft">
      <AccommodationRegionSection
        id="labuan-bajo"
        title={akomodasiPageContent.regions["labuan-bajo"].title}
        description={akomodasiPageContent.regions["labuan-bajo"].description}
        accommodations={labuanBajoAccommodations}
      />
    </SectionContainer>
  )}

  <FaqSection
    eyebrow="FAQ"
    title={uiStrings.faq.sectionAccommodations}
    items={akomodasiFaq}
    background="bg-surface-soft"
  />

  <PackagePageCta />
</MainLayout>

<RegionObserver />

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import KeyTakeaways from "@/components/guides/KeyTakeaways.astro";
import GuideCard from "@/components/guides/GuideCard.astro";
import DestinationCard from "@/components/cards/DestinationCard.astro";
import PackageCard from "@/components/cards/PackageCard.astro";
import { generateHowToSchema } from "@/lib/schemas";
import { guides } from "@/lib/content/guides";
import { destinations } from "@/lib/content/destinationsData";
import { packages } from "@/lib/content/tourPackages";

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

interface Props {
  guide: (typeof guides)[0];
}

const { guide } = Astro.props;

const relatedDestinations = destinations.filter((d) =>
  guide.relatedDestinations.includes(d.slug)
);

const relatedPackages = packages.filter((p) =>
  guide.relatedPackages.includes(p.slug)
);

const breadcrumbs = [
  { label: "Beranda", href: "/" },
  { label: "Panduan Wisata", href: "/panduan-wisata" },
  { label: guide.title },
];

const howToSteps = guide.keyTakeaways.map((takeaway, index) => ({
  name: `Poin ${index + 1}`,
  description: takeaway,
}));

const guideSchema = generateHowToSchema(guide.title, guide.description, howToSteps);
---

<MainLayout
  title={guide.title}
  description={guide.description}
  canonical={`/panduan-wisata/${guide.slug}`}
>
  <StructuredData schema={guideSchema} />

  <PageHeader
    eyebrow="Panduan Wisata"
    title={guide.title}
    description={guide.description}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <article class="article-content mx-auto max-w-4xl">
      <div class="mb-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-text-muted">
        <span class="inline-flex items-center gap-2">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
          {guide.readingTime} menit membaca
        </span>
        <span class="hidden sm:inline text-border">&#47;</span>
        <span class="inline-flex items-center gap-2">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <path d="M16 2v4" />
            <path d="M8 2v4" />
            <path d="M3 10h18" />
          </svg>
          <time datetime={guide.publishDate}>
            {new Date(guide.publishDate).toLocaleDateString("id-ID", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })}
          </time>
        </span>
      </div>

      <div set:html={guide.content.trim()} class="article-body" />
    </article>
  </SectionContainer>

  <SectionContainer background="bg-background">
    <KeyTakeaways takeaways={guide.keyTakeaways} />
  </SectionContainer>

  {relatedDestinations.length > 0 && (
    <SectionContainer background="bg-surface-soft">
      <div class="mb-8">
        <h2 class="font-heading text-3xl leading-tight text-foreground">
          Destinasi Terkait
        </h2>
        <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
          Tempat-tempat yang direkomendasikan berdasarkan panduan ini
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {relatedDestinations.map((dest) => (
          <DestinationCard destination={dest} />
        ))}
      </div>
    </SectionContainer>
  )}

  {relatedPackages.length > 0 && (
    <SectionContainer background="bg-background">
      <div class="mb-8">
        <h2 class="font-heading text-3xl leading-tight text-foreground">
          Paket Wisata Terkait
        </h2>
        <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
          Paket wisata yang sesuai dengan panduan ini
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {relatedPackages.map((pkg) => (
          <PackageCard tour={pkg} />
        ))}
      </div>
    </SectionContainer>
  )}

  <SectionContainer background="bg-surface-soft">
    <div class="mb-8">
      <h2 class="font-heading text-3xl leading-tight text-foreground">
        Panduan Lainnya
      </h2>
      <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
        Baca panduan wisata lainnya untuk perjalanan yang lebih lengkap
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {guides
        .filter((g) => g.slug !== guide.slug)
        .slice(0, 3)
        .map((g) => (
          <GuideCard guide={g} />
        ))}
    </div>
  </SectionContainer>
</MainLayout>

<style is:global>
  .article-body h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .article-body h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-body h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-body p {
    color: var(--color-foreground);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  .article-body ul,
  .article-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  .article-body ul {
    list-style-type: disc;
  }

  .article-body ol {
    list-style-type: decimal;
  }

  .article-body li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
    color: var(--color-foreground);
  }

  .article-body strong {
    font-weight: 600;
    color: var(--color-foreground);
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .article-body th {
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-soft);
    padding: 0.75rem;
    font-weight: 600;
    text-align: left;
  }

  .article-body td {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
  }
</style>

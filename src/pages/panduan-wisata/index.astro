---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import GuideCard from "@/components/guides/GuideCard.astro";
import { REGION_LABEL } from "@/lib/regions";
import { guides } from "@/lib/content/guides";
import type { Guide } from "@/lib/content/guides";

const regions = ["lombok", "sumbawa", "labuan-bajo", "general"] as const;

function guidesByRegion(region: string): Guide[] {
  return guides.filter((g) => g.region === region);
}
---

<MainLayout
  title="Panduan Wisata"
  description="Panduan lengkap untuk merencanakan perjalanan Anda ke Lombok, Sumbawa, dan Labuan Bajo — dari waktu terbaik berkunjung hingga tips transportasi."
  canonical="/panduan-wisata"
>
  <PageHeader
    eyebrow="Panduan Wisata"
    title="Panduan Perjalanan"
    description="Panduan lengkap untuk merencanakan perjalanan Anda ke Lombok, Sumbawa, dan Labuan Bajo — dari waktu terbaik berkunjung hingga tips transportasi."
    breadcrumbs={[{ label: "Beranda", href: "/" }, { label: "Panduan Wisata" }]}
  />

  {
    regions.map((region) => {
      const regionGuides = guidesByRegion(region);
      if (regionGuides.length === 0) return null;

      const label = region === "general" ? "Panduan Umum" : `Panduan ${REGION_LABEL[region as keyof typeof REGION_LABEL]}`;

      return (
        <SectionContainer
          background={region === "lombok" ? "bg-surface-soft" : "bg-background"}
        >
          <div class="mb-12">
            <h2 class="font-heading text-3xl leading-tight text-foreground">
              {label}
            </h2>
            <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
              {
                region === "lombok"
                  ? "Tips dan panduan wisata untuk liburan Anda di Lombok."
                  : region === "sumbawa"
                    ? "Informasi wisata untuk petualangan di Sumbawa."
                    : region === "labuan-bajo"
                      ? "Semua yang perlu Anda tahu sebelum ke Labuan Bajo."
                      : "Panduan umum untuk perjalanan Anda."
              }
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {regionGuides.map((guide) => (
              <GuideCard guide={guide} />
            ))}
          </div>
        </SectionContainer>
      );
    })
  }
</MainLayout>

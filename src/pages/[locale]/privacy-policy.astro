---
import { TypographyH2 } from "@/components/ui/typography";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import {
  getFooterStrings,
  getGlobalStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";
import { HERO } from "@/assets/images";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const footerStrings = getFooterStrings(locale!);

const metaDescriptions = {
  en: "Learn how Sungkar Group collects, uses, and protects your personal data when you use our website, contact forms, and travel services.",
  ar: "تعرّف على كيفية جمع Sungkar Group لبياناتك الشخصية واستخدامها وحمايتها عند استخدام الموقع ونماذج التواصل وخدمات السفر.",
  ms: "Ketahui cara Sungkar Group mengumpul, menggunakan, dan melindungi data peribadi anda apabila anda menggunakan laman web, borang hubungan, dan perkhidmatan perjalanan kami.",
  zh: "了解 Sungkar Group 在您使用我们的网站、联系表单和旅游服务时，如何收集、使用并保护您的个人数据。",
} as const;

const metaDescription =
  metaDescriptions[locale as keyof typeof metaDescriptions];

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  { label: footerStrings.footer.privacy },
];

const clarityDisclosures = {
  en: {
    heading: "6. Cookies and Microsoft Clarity",
    cookie:
      "Our website may use cookies and similar tracking technologies to enhance your browsing experience. You can manage cookie preferences through your browser settings.",
    disclosure:
      "We partner with Microsoft Clarity and Microsoft Advertising to understand how you use and interact with our website through behavioral metrics, heatmaps, and session replay. Website usage data is collected using first-party and third-party cookies and other tracking technologies to help us improve our services, optimize the site, support security and fraud prevention, and support marketing or advertising activities. For more information about how Microsoft collects and uses your data, visit the Microsoft Privacy Statement.",
    link: "Microsoft Privacy Statement",
  },
  ar: {
    heading: "6. ملفات تعريف الارتباط وMicrosoft Clarity",
    cookie:
      "قد يستخدم موقعنا ملفات تعريف الارتباط وتقنيات تتبع مماثلة لتحسين تجربة التصفح. يمكنك إدارة تفضيلات ملفات تعريف الارتباط من خلال إعدادات المتصفح.",
    disclosure:
      "نتعاون مع Microsoft Clarity وMicrosoft Advertising لفهم كيفية استخدامك لموقعنا وتفاعلك معه من خلال مقاييس السلوك والخرائط الحرارية وتسجيلات الجلسات. يتم جمع بيانات استخدام الموقع باستخدام ملفات تعريف ارتباط من الطرف الأول والطرف الثالث وتقنيات تتبع أخرى لمساعدتنا على تحسين خدماتنا، وتحسين الموقع، ودعم الأمان ومنع الاحتيال، ودعم أنشطة التسويق أو الإعلان. لمزيد من المعلومات حول كيفية جمع Microsoft لبياناتك واستخدامها، يُرجى زيارة بيان خصوصية Microsoft.",
    link: "بيان خصوصية Microsoft",
  },
  ms: {
    heading: "6. Kuki dan Microsoft Clarity",
    cookie:
      "Laman web kami mungkin menggunakan kuki dan teknologi penjejakan serupa untuk meningkatkan pengalaman pelayaran anda. Anda boleh mengurus keutamaan kuki melalui tetapan pelayar anda.",
    disclosure:
      "Kami bekerjasama dengan Microsoft Clarity dan Microsoft Advertising untuk memahami cara anda menggunakan dan berinteraksi dengan laman web kami melalui metrik tingkah laku, peta haba, dan rakaman sesi. Data penggunaan laman web dikumpulkan menggunakan kuki pihak pertama dan pihak ketiga serta teknologi penjejakan lain untuk membantu kami meningkatkan perkhidmatan, mengoptimumkan laman web, menyokong keselamatan dan pencegahan penipuan, serta menyokong aktiviti pemasaran atau pengiklanan. Untuk maklumat lanjut tentang cara Microsoft mengumpul dan menggunakan data anda, lawati Pernyataan Privasi Microsoft.",
    link: "Pernyataan Privasi Microsoft",
  },
  zh: {
    heading: "6. Cookie 与 Microsoft Clarity",
    cookie:
      "我们的网站可能会使用 Cookie 和类似的跟踪技术来提升您的浏览体验。您可以通过浏览器设置管理 Cookie 偏好。",
    disclosure:
      "我们与 Microsoft Clarity 和 Microsoft Advertising 合作，通过行为指标、热力图和会话回放了解您如何使用我们的网站并与之互动。网站使用数据会通过第一方和第三方 Cookie 以及其他跟踪技术收集，以帮助我们改进服务、优化网站、支持安全和防欺诈，并支持营销或广告活动。有关 Microsoft 如何收集和使用您的数据的更多信息，请访问 Microsoft 隐私声明。",
    link: "Microsoft 隐私声明",
  },
} as const;

const clarityDisclosure =
  clarityDisclosures[locale as keyof typeof clarityDisclosures] ??
  clarityDisclosures.en;
---

<MainLayout
  title={footerStrings.footer.privacy}
  description={metaDescription}
  canonical={`/${locale}/privacy-policy`}
  image={HERO.heroLombok}
  locale={locale}
>
  <PageHeader
    eyebrow={footerStrings.footer.privacy}
    title={footerStrings.footer.privacy}
    description={metaDescription}
    breadcrumbs={breadcrumbs}
    image={HERO.heroLombok}
    imageAlt={globalStrings.common.imageAltSunrise}
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
    <div class="prose prose-sm prose-gray mx-auto max-w-3xl">
      <TypographyH2>1. Informasi yang Kami Kumpulkan</TypographyH2>
      <p>
        Kami mengumpulkan informasi yang Anda berikan secara sukarela saat
        menghubungi kami melalui formulir kontak, WhatsApp, atau saluran
        komunikasi lainnya. Informasi tersebut dapat mencakup:
      </p>
      <ul>
        <li>Nama lengkap</li>
        <li>Alamat email</li>
        <li>Nomor telepon / WhatsApp</li>
        <li>Tanggal perjalanan yang diinginkan</li>
        <li>Jumlah tamu dan preferensi perjalanan</li>
        <li>Informasi lain yang Anda berikan secara sukarela</li>
      </ul>

      <TypographyH2>2. Penggunaan Informasi</TypographyH2>
      <p>Informasi yang kami kumpulkan digunakan untuk:</p>
      <ul>
        <li>Memproses dan merespons pertanyaan serta pemesanan Anda</li>
        <li>Memberikan informasi tentang paket wisata dan layanan kami</li>
        <li>Meningkatkan kualitas layanan dan pengalaman pelanggan</li>
        <li>Mengirimkan informasi promosi (hanya dengan persetujuan Anda)</li>
      </ul>

      <TypographyH2>3. Perlindungan Data</TypographyH2>
      <p>
        Kami mengambil langkah-langkah keamanan yang wajar untuk melindungi
        informasi pribadi Anda dari akses tidak sah, perubahan, pengungkapan,
        atau penghancuran. Data Anda disimpan di sistem yang aman dan hanya
        dapat diakses oleh personel yang berwenang.
      </p>

      <TypographyH2>4. Pengungkapan kepada Pihak Ketiga</TypographyH2>
      <p>
        Kami tidak menjual, menukarkan, atau mengalihkan informasi pribadi Anda
        kepada pihak ketiga tanpa persetujuan Anda, kecuali jika diwajibkan oleh
        hukum atau untuk memproses layanan yang Anda minta (misalnya, pemesanan
        hotel atau tiket).
      </p>

      <TypographyH2>5. Hak Anda</TypographyH2>
      <p>Anda berhak untuk:</p>
      <ul>
        <li>Mengakses data pribadi yang kami simpan</li>
        <li>Meminta koreksi atau penghapusan data</li>
        <li>Menolak penggunaan data untuk tujuan pemasaran</li>
        <li>Menarik persetujuan yang telah diberikan sebelumnya</li>
      </ul>

      <TypographyH2>{clarityDisclosure.heading}</TypographyH2>
      <p>{clarityDisclosure.cookie}</p>
      <p>
        {clarityDisclosure.disclosure.split(clarityDisclosure.link)[0]}
        <a
          href="https://privacy.microsoft.com/privacystatement"
          rel="noopener noreferrer"
          target="_blank">{clarityDisclosure.link}</a
        >{clarityDisclosure.disclosure.split(clarityDisclosure.link)[1]}
      </p>

      <TypographyH2>7. Perubahan Kebijakan</TypographyH2>
      <p>
        Kebijakan privasi ini dapat diperbarui dari waktu ke waktu. Perubahan
        akan diumumkan melalui halaman ini. Dengan terus menggunakan layanan
        kami, Anda menyetujui pembaruan kebijakan ini.
      </p>

      <TypographyH2>8. Kontak</TypographyH2>
      <p>
        Jika Anda memiliki pertanyaan tentang kebijakan privasi ini, silakan
        hubungi kami melalui halaman <a href="/kontak">Kontak</a> atau WhatsApp di
        +62 81236128629.
      </p>
    </div>
  </SectionContainer>
</MainLayout>

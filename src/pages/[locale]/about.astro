---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import StorySection from "@/components/about/StorySection.astro";
import ServicesSection from "@/components/about/ServicesSection.astro";
import StrengthsSection from "@/components/about/StrengthsSection.astro";
import ValuesSection from "@/components/about/ValuesSection.astro";
import CommitmentSection from "@/components/about/CommitmentSection.astro";
import LegalityTeamSection from "@/components/about/LegalityTeamSection.astro";
import CtaSection from "@/components/about/CtaSection.astro";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import {
  getAboutPageStrings,
  getFaqPageStrings,
  getGlobalStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const aboutStrings = getAboutPageStrings(locale!);
const faqStrings = getFaqPageStrings(locale!);

const aboutModule = await loadContent(locale!, "about");
const { aboutContent } = aboutModule;

const faqModule = await loadFaq(locale!, "about");
const { aboutFaq } = faqModule;

const faqSchema = generateFAQPageSchema(aboutFaq);

const pageTitle = globalStrings.page.about;
const pageDescription = aboutContent.hero.description;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`/${locale}/about`}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={aboutContent.hero.eyebrow}
    title={aboutContent.hero.title}
    description={aboutContent.hero.description}
    breadcrumbs={[
      { label: globalStrings.breadcrumb.home, href: `/${locale}` },
      { label: globalStrings.breadcrumb.about },
    ]}
  />
  <StorySection
    story={aboutContent.story}
    sectionLabel={aboutStrings.about.ourJourney}
  />
  <ServicesSection
    services={aboutContent.services}
    sectionTitle={aboutStrings.about.whatWeDo}
  />
  <StrengthsSection
    strengths={aboutContent.strengths}
    sectionTitle={aboutStrings.about.whyChooseUs}
  />
  <ValuesSection
    values={aboutContent.values}
    sectionTitle={aboutStrings.about.ourValues}
  />
  <LegalityTeamSection locale={locale} />
  <CommitmentSection commitment={aboutContent.commitment} />
  <FaqSection
    eyebrow={faqStrings.faq.sectionTitle}
    title={faqStrings.faq.sectionAbout}
    items={aboutFaq}
    background="bg-surface-soft"
  />
  <CtaSection cta={aboutContent.cta} />
</MainLayout>

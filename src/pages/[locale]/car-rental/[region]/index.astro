---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import VehicleRegionSection from "@/components/vehicles/VehicleRegionSection.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { getVehicles } from "@/lib/content/car-rental/collection";
import { REGION_LABEL, REGIONS, type RegionKey as Region } from "@/lib/regions";

import { loadFaq } from "@/lib/i18n/loader";
import {
  getCarRentalPageStrings,
  getFaqPageStrings,
  getGlobalStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const vehicles = await getVehicles(locale);
    for (const region of REGIONS) {
      const regionVehicles = vehicles.filter((v) => v.region === region);
      if (regionVehicles.length === 0) continue;
      paths.push({
        params: { locale, region },
        props: { region },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const carRentalStrings = getCarRentalPageStrings(locale!);
const faqStrings = getFaqPageStrings(locale!);

const faqModule = await loadFaq(locale!, "sewa-mobil");
const { sewaMobilFaq } = faqModule;

const faqSchema = generateFAQPageSchema(sewaMobilFaq);

interface Props {
  region: Region;
}

const { region } = Astro.props;
const vehicles = await getVehicles(locale!);
const regionVehicles = vehicles.filter((v) => v.region === region);

const regionName = REGION_LABEL[region];
const regionDescription = carRentalStrings.sewaMobil.allVehicles.replace(
  "{region}",
  regionName,
);

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  { label: globalStrings.breadcrumb.carRental, href: `/${locale}/car-rental` },
  { label: regionName },
];
---

<MainLayout
  title={`${carRentalStrings.sewaMobil.title} ${regionName}`}
  description={regionDescription}
  canonical={`/${locale}/car-rental/${region}`}
  image={regionVehicles[0]?.imageTop}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={carRentalStrings.sewaMobil.vehicleFor.replace("{region}", regionName)}
    title={carRentalStrings.sewaMobil.vehicleFor.replace("{region}", regionName)}
    description={regionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <VehicleRegionSection
      id={region}
      passengersLabel={carRentalStrings.sewaMobil.passengers}
      specificationsLabel={carRentalStrings.sewaMobil.specifications}
      transmissionLabel={carRentalStrings.sewaMobil.transmission}
      featuresLabel={carRentalStrings.sewaMobil.features}
      suitableForLabel={carRentalStrings.sewaMobil.suitableFor}
      viewDetailRentLabel={carRentalStrings.sewaMobil.viewDetailRent}
      title={carRentalStrings.sewaMobil.rentalVehicles.replace("{region}", regionName)}
      description={carRentalStrings.sewaMobil.allVehicles.replace(
        "{region}",
        regionName,
      )}
      vehicles={regionVehicles}
    />
  </SectionContainer>

  <FaqSection
    eyebrow={faqStrings.faq.sectionTitle}
    title={carRentalStrings.sewaMobil.faqTitleFor.replace("{region}", regionName)}
    items={sewaMobilFaq}
    background="bg-surface-soft"
  />
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { generateProductSchema, generateBreadcrumbSchema } from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";

import { getVehicles } from "@/lib/content/car-rental/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import VehicleDetailPanel from "@/components/vehicles/VehicleDetailPanel.astro";
import WhatsAppForm from "@/components/contact/WhatsAppForm.astro";

import { t, NON_DEFAULT_LOCALES } from "@/lib/i18n";
import { getImageSrc } from "@/lib/images";
import { sewaMobilFormFields as idSewaMobilFormFields } from "@/lib/contact-data";
import { sewaMobilFormFields as enSewaMobilFormFields } from "@/lib/i18n/en/shared/contact-data";
import { sewaMobilFormFields as arSewaMobilFormFields } from "@/lib/i18n/ar/shared/contact-data";
import { sewaMobilFormFields as msSewaMobilFormFields } from "@/lib/i18n/ms/shared/contact-data";
import { sewaMobilFormFields as zhSewaMobilFormFields } from "@/lib/i18n/zh/shared/contact-data";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const vehicles = await getVehicles(locale);
    for (const vehicle of vehicles) {
      paths.push({
        params: { locale, region: vehicle.region, slug: vehicle.slug },
        props: { vehicle },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { vehicle } = Astro.props;
const uiStrings = t(locale!);

const formFields =
  locale === "en"
    ? enSewaMobilFormFields
    : locale === "ar"
      ? arSewaMobilFormFields
      : locale === "ms"
        ? msSewaMobilFormFields
        : locale === "zh"
          ? zhSewaMobilFormFields
          : idSewaMobilFormFields;

const vehicleUrl = `${SITE_URL}/${locale}/car-rental/${vehicle.region}/${vehicle.slug}`;
const absoluteImageUrl = new URL(
  getImageSrc(vehicle.imageTop),
  SITE_URL,
).toString();

const productSchema = generateProductSchema(
  vehicle.name,
  vehicle.description,
  vehicle.pricePerDay,
  absoluteImageUrl,
  vehicleUrl,
);

const breadcrumbItems = [
  { name: uiStrings.breadcrumb.home, url: "/" },
  { name: uiStrings.breadcrumb.carRental, url: `/${locale}/car-rental` },
  {
    name: REGION_LABEL[vehicle.region],
    url: `/${locale}/car-rental/${vehicle.region}`,
  },
  {
    name: vehicle.name,
    url: `/${locale}/car-rental/${vehicle.region}/${vehicle.slug}`,
  },
];

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems, SITE_URL);

const r = vehicle.region as Region;
---

<MainLayout
  title={`${vehicle.name} - ${uiStrings.sewaMobil.title} ${REGION_LABEL[r]}`}
  description={vehicle.description}
  canonical={`/${locale}/car-rental/${vehicle.region}/${vehicle.slug}`}
  image={vehicle.imageTop}
  locale={locale}
>
  <StructuredData schema={productSchema} />
  <StructuredData schema={breadcrumbSchema} />

  <PageHeader
    eyebrow={uiStrings.sewaMobil.vehicleDetail}
    title={vehicle.name}
    description={vehicle.description}
    breadcrumbs={[
      { label: uiStrings.breadcrumb.home, href: `/${locale}` },
      { label: uiStrings.breadcrumb.carRental, href: `/${locale}/car-rental` },
      {
        label: REGION_LABEL[r],
        href: `/${locale}/car-rental/${vehicle.region}`,
      },
      { label: vehicle.name },
    ]}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <div class="space-y-8">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto]">
          <VehicleDetailPanel {vehicle} />
          <div class="w-full lg:w-96 overflow-hidden flex lg:flex-col gap-8">
            <OptimizedImage
              src={vehicle.imageTop}
              alt={vehicle.name}
              class="aspect-4/3 w-full object-cover rounded-lg"
              loading="lazy"
            />

            <OptimizedImage
              src={vehicle.imageBottom}
              alt={vehicle.name}
              class="aspect-4/3 w-full object-cover rounded-lg"
              loading="lazy"
            />
          </div>
        </div>
        <WhatsAppForm
          context="sewa-mobil"
          fields={formFields}
          mode="sidebar"
          itemName={vehicle.name}
          region={REGION_LABEL[r]}
        />
      </div>
    </div>
  </SectionContainer>
</MainLayout>

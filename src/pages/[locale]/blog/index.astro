---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { BlogCard } from "@/components/blog";
import { getBlogPosts } from "@/lib/content/blog";

import { t, NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const uiStrings = t(locale!);
const posts = await getBlogPosts(locale!);

const homeHref = `/${locale}`;
const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: homeHref },
  { label: "Blog" },
];
---

<MainLayout
  title="Blog - Sungkar Group"
  description="Tips, inspirasi, dan informasi terbaru seputar wisata Lombok, Sumbawa, dan Labuan Bajo."
  canonical={`/${locale}/blog`}
  locale={locale}
>
  <PageHeader
    eyebrow="Blog"
    title="Blog & Artikel"
    description="Tips, inspirasi, dan informasi terbaru seputar wisata Lombok, Sumbawa, dan Labuan Bajo."
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-background">
    {posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <BlogCard post={post} locale={locale} />
        ))}
      </div>
    ) : (
      <div class="py-16 text-center">
        <p class="text-text-muted">Belum ada artikel. Segera hadir!</p>
      </div>
    )}
  </SectionContainer>
</MainLayout>

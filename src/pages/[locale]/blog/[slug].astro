---
import BlogPostPage from "@/components/pages/BlogPostPage.astro";
import { getBlogPosts, getBlogPost } from "@/lib/content/blog";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const posts = await getBlogPosts(locale);
    for (const post of posts) {
      paths.push({
        params: { locale, slug: post.slug },
        props: { slug: post.slug },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { slug } = Astro.props;
const post = await getBlogPost(locale!, slug);

if (!post) {
  return Astro.redirect(`/${locale}/blog`, 404);
}
---

<BlogPostPage locale={locale!} slug={slug} post={post} />

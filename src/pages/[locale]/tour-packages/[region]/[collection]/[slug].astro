---
import PackageDetailPage from "@/components/pages/PackageDetailPage.astro";
import { getPackages } from "@/lib/content/tourPackages/collection";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const localePackages = await getPackages(locale);
    for (const tour of localePackages) {
      paths.push({
        params: {
          locale,
          region: tour.region,
          collection: tour.collectionSlug,
          slug: tour.slug,
        },
        props: { tour },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { tour } = Astro.props;
---

<PackageDetailPage tour={tour} locale={locale!} />

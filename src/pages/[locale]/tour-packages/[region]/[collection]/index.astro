---
import PackageCollectionPage from "@/components/pages/PackageCollectionPage.astro";
import { getPackages } from "@/lib/content/tourPackages/collection";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";
import { type RegionKey as Region } from "@/lib/regions";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const localePackages = await getPackages(locale);
    const uniqueColl = localePackages
      .map((pkg) => ({
        region: pkg.region,
        collection: pkg.collectionSlug,
      }))
      .filter(
        (value, index, self) =>
          index ===
          self.findIndex(
            (item) =>
              item.region === value.region &&
              item.collection === value.collection,
          ),
      );
    for (const item of uniqueColl) {
      paths.push({ params: { locale, ...item } });
    }
  }
  return paths;
}

const { locale, region, collection } = Astro.params;
const packages = await getPackages(locale!);
const collectionPackages = packages.filter(
  (pkg) => pkg.region === region && pkg.collectionSlug === collection,
);
---

<PackageCollectionPage
  locale={locale!}
  region={region as Region}
  collection={collection!}
  packages={collectionPackages}
/>

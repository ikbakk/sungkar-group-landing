---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import PackageCard from "@/components/cards/PackageCard.astro";

import { getPackages } from "@/lib/content/tourPackages/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import { loadContent } from "@/lib/i18n/loader";
import { t, NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const localePackages = await getPackages(locale);
    const uniqueColl = localePackages
      .map((pkg) => ({
        region: pkg.region,
        collection: pkg.collectionSlug,
      }))
      .filter(
        (value, index, self) =>
          index ===
          self.findIndex(
            (item) =>
              item.region === value.region &&
              item.collection === value.collection,
          ),
      );
    for (const item of uniqueColl) {
      paths.push({ params: { locale, ...item } });
    }
  }
  return paths;
}

const { locale, region, collection } = Astro.params;
const r = region as Region;
const uiStrings = t(locale!);
const pageModule = await loadContent(locale!, "packagePage");
const { packagePageContent } = pageModule;

const packages = await getPackages(locale!);
const collectionPackages = packages.filter(
  (pkg) => pkg.region === r && pkg.collectionSlug === collection,
);

const collectionTitle = collectionPackages[0]?.collectionTitle ?? "";
const regionTitle = packagePageContent.regions[r].title;
const normalizedCollectionTitle = collectionTitle.toLowerCase();
const collectionSeoTitle = normalizedCollectionTitle.includes(
  regionTitle.toLowerCase(),
)
  ? collectionTitle
  : `${collectionTitle} ${regionTitle}`;
const collectionDescription = packagePageContent.regions[r].description;

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: `/${locale}` },
  {
    label: uiStrings.breadcrumb.tourPackages,
    href: `/${locale}/tour-packages`,
  },
  { label: REGION_LABEL[r], href: `/${locale}/tour-packages/${r}` },
  { label: collectionTitle },
];
---

<MainLayout
  title={collectionSeoTitle}
  description={collectionDescription}
  canonical={`/${locale}/tour-packages/${r}/${collection}`}
  locale={locale}
>
  <PageHeader
    eyebrow={packagePageContent.regions[r].title}
    title={collectionTitle}
    description={collectionDescription}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        collectionPackages.map((tour, i) => (
          <PackageCard
            tour={tour}
            locale={locale}
            loading={i < 3 ? "eager" : "lazy"}
          />
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

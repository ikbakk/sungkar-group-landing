---
import PackageRegionPage from "@/components/pages/PackageRegionPage.astro";
import { getPackages } from "@/lib/content/tourPackages/collection";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";
import { type RegionKey as Region } from "@/lib/regions";

export function getStaticPaths() {
  const regions: Region[] = [
    "lombok",
    "sumbawa",
    "labuan-bajo",
    "sailing-labuan-bajo",
    "lombok-to-bajo",
    "lombok-bajo",
  ];
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    for (const region of regions) {
      paths.push({ params: { locale, region } });
    }
  }
  return paths;
}

const { locale, region } = Astro.params;
const packages = await getPackages(locale!);
const regionPackages = packages.filter((pkg) => pkg.region === region);
---

<PackageRegionPage
  locale={locale!}
  region={region as Region}
  packages={regionPackages}
/>

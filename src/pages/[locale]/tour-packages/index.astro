---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import RelatedContent from "@/components/site/RelatedContent.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";

import StickyNav from "@/components/ui/StickyNav.astro";
import RegionObserver from "@/components/ui/RegionObserver.astro";
import PackageRegionSection from "@/components/packages/PackageRegionSection.astro";
import PackagePageCta from "@/components/packages/PackagePageCta.astro";

import SectionContainer from "@/layouts/SectionContainer.astro";

import { getPackages } from "@/lib/content/tourPackages/collection";
import { REGIONS, REGION_LABEL } from "@/lib/regions";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import {
  getFaqPageStrings,
  getGlobalStrings,
  getTourPackagesPageStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const faqStrings = getFaqPageStrings(locale!);
const packageStrings = getTourPackagesPageStrings(locale!);

const pageModule = await loadContent(locale!, "packagePage");
const { packagePageContent } = pageModule;

const faqModule = await loadFaq(locale!, "package");
const { packageFaq } = faqModule;

const faqSchema = generateFAQPageSchema(packageFaq);

const packages = await getPackages(locale!);

const packageCountByRegion = new Map<string, number>(
  REGIONS.map((id) => [id, 0]),
);
for (const pkg of packages) {
  if (!packageCountByRegion.has(pkg.region)) continue;
  packageCountByRegion.set(
    pkg.region,
    (packageCountByRegion.get(pkg.region) ?? 0) + 1,
  );
}

const regionSections = REGIONS.filter(
  (id) => (packageCountByRegion.get(id) ?? 0) > 0,
).map((id) => {
  const content = packagePageContent.regions[id];
  return {
    id,
    label: REGION_LABEL[id],
    count: packageCountByRegion.get(id) ?? 0,
    title: content.title,
    description: content.description,
    packages: packages.filter((pkg) => pkg.region === id),
  };
});

const regions = regionSections.map(({ id, label, count }) => ({
  id,
  label,
  count,
}));

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  { label: globalStrings.breadcrumb.tourPackages },
];
---

<MainLayout
  title={packageStrings.paketWisata.title}
  description={packagePageContent.hero.description}
  canonical={`/${locale}/tour-packages`}
  image={packages[0]?.images[0]}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={packagePageContent.hero.eyebrow}
    title={packagePageContent.hero.title}
    description={packagePageContent.hero.description}
    breadcrumbs={breadcrumbs}
  />

  <StickyNav items={regions} />

  {
    regionSections.map((section, i) => (
      <SectionContainer
        background={i % 2 === 0 ? "bg-surface-soft" : "bg-background"}
      >
        <PackageRegionSection
          id={section.id}
          locale={locale}
          backToTopLabel={globalStrings.common.backToTop}
          moreCountLabel={globalStrings.common.moreCount}
          viewPackageDetailLabel={packageStrings.paketWisata.viewPackageDetail}
          title={section.title}
          description={section.description}
          packages={section.packages}
        />
      </SectionContainer>
    ))
  }

  <FaqSection
    eyebrow={faqStrings.faq.sectionTitle}
    title={faqStrings.faq.sectionPackages}
    items={packageFaq}
  />

  <RelatedContent
    background="bg-surface-soft"
    title={packageStrings.paketWisata.exploreServices}
    items={packagePageContent.relatedContent}
  />

  <PackagePageCta cta={packagePageContent.cta} />
</MainLayout>

<RegionObserver />

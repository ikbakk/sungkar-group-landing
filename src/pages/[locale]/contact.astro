---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import StructuredData from "@/components/seo/StructuredData.astro";

import ContactForm from "@/components/contact/ContactForm.astro";
import ContactInfoSection from "@/components/contact/ContactInfoSection.astro";
import EmbeddedMap from "@/components/contact/EmbeddedMap.astro";

import FaqSection from "@/components/site/Faq.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { loadContent, loadFaq } from "@/lib/i18n/loader";
import {
  getFaqPageStrings,
  getGlobalStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";

import { getPackages } from "@/lib/content/tourPackages/collection";

import {
  generateContactPageSchema,
  generateFAQPageSchema,
} from "@/lib/schemas";
import { SITE_URL } from "@/lib/site-config";
import {
  businessInfo as idBusinessInfo,
  contactFormFields as idContactFormFields,
} from "@/lib/contact-data";
import {
  businessInfo as enBusinessInfo,
  contactFormFields as enContactFormFields,
} from "@/lib/i18n/en/shared/contact-data";
import {
  businessInfo as arBusinessInfo,
  contactFormFields as arContactFormFields,
} from "@/lib/i18n/ar/shared/contact-data";
import {
  businessInfo as msBusinessInfo,
  contactFormFields as msContactFormFields,
} from "@/lib/i18n/ms/shared/contact-data";
import {
  businessInfo as zhBusinessInfo,
  contactFormFields as zhContactFormFields,
} from "@/lib/i18n/zh/shared/contact-data";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const faqStrings = getFaqPageStrings(locale!);
const businessInfo =
  locale === "en"
    ? enBusinessInfo
    : locale === "ar"
      ? arBusinessInfo
      : locale === "ms"
        ? msBusinessInfo
        : locale === "zh"
          ? zhBusinessInfo
          : idBusinessInfo;
const contactFormFields =
  locale === "en"
    ? enContactFormFields
    : locale === "ar"
      ? arContactFormFields
      : locale === "ms"
        ? msContactFormFields
        : locale === "zh"
          ? zhContactFormFields
          : idContactFormFields;

const pageModule = await loadContent(locale!, "contactPage");
const { contactPageContent } = pageModule;

const faqModule = await loadFaq(locale!, "contact");
const { contactFaq } = faqModule;

const packages = await getPackages(locale!);

const siteUrl = Astro.site?.toString() ?? SITE_URL;
const canonicalPath = `/${locale}/contact`;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();

const contactSchema = generateContactPageSchema(canonicalUrl, businessInfo);

const faqSchema = generateFAQPageSchema(contactFaq);

const pageTitle = globalStrings.page.contact;
const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  { label: globalStrings.breadcrumb.contact },
];
---

<MainLayout
  title={pageTitle}
  description={contactPageContent.hero.description}
  canonical={canonicalPath}
  locale={locale}
>
  <StructuredData schema={contactSchema} />
  <StructuredData schema={faqSchema} />
  <PageHeader
    eyebrow={contactPageContent.hero.eyebrow}
    title={contactPageContent.hero.title}
    description={contactPageContent.hero.description}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <EmbeddedMap
      title={contactPageContent.map.title}
      description={contactPageContent.map.description}
      embedUrl={contactPageContent.map.embedUrl}
      googleMapsUrl={contactPageContent.map.googleMapsUrl}
      locale={locale}
      businessName={businessInfo.name}
      businessAddress={`${businessInfo.address.street}, ${businessInfo.address.city}`}
    />
  </SectionContainer>

  <SectionContainer background="bg-background">
    <div class="grid-form">
      <ContactInfoSection
        businessInfo={businessInfo}
        title={contactPageContent.info.title}
        description={contactPageContent.info.description}
        locale={locale}
      />

      <ContactForm
        fields={contactFormFields}
        businessInfo={businessInfo}
        title={contactPageContent.form.title}
        description={contactPageContent.form.description}
        locale={locale}
        packages={packages}
      />
    </div>
  </SectionContainer>

  <SectionContainer background="bg-surface-soft">
    <FaqSection
      eyebrow={faqStrings.faq.sectionTitle}
      title={faqStrings.faq.sectionContact}
      items={contactFaq}
      background="bg-surface-soft"
    />
  </SectionContainer>
</MainLayout>

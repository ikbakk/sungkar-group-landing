---
import DestinationDetailPage from "@/components/pages/DestinationDetailPage.astro";
import { getDestinations } from "@/lib/content/destinations/collection";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  const baseDestinations = await getDestinations("id");
  for (const locale of NON_DEFAULT_LOCALES) {
    const localeDestinations = await getDestinations(locale);
    for (const baseDestination of baseDestinations) {
      const destination = localeDestinations.find(
        (item) => item.slug === baseDestination.slug,
      );
      if (!destination) continue;
      paths.push({
        params: { locale, slug: baseDestination.slug },
        props: { destination },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { destination } = Astro.props;
---

<DestinationDetailPage destination={destination} locale={locale!} />

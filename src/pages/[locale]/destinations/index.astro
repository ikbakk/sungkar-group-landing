---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import FaqSection from "@/components/site/Faq.astro";
import RelatedContent from "@/components/site/RelatedContent.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateFAQPageSchema } from "@/lib/schemas";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StickyNav from "@/components/ui/StickyNav.astro";
import DestinationGroupSection from "@/components/destinations/DestinationGroupSection.astro";

import { loadContent } from "@/lib/i18n/loader";
import {
  getFaqPageStrings,
  getGlobalStrings,
  getTourPackagesPageStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";
import { getDestinations } from "@/lib/content/destinations/collection";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const faqStrings = getFaqPageStrings(locale!);
const packageStrings = getTourPackagesPageStrings(locale!);

const pageModule = await loadContent(locale!, "destinationsPage");
const { destinationsPageContent } = pageModule;

const faqSchema = generateFAQPageSchema(destinationsPageContent.faq);

const allDestinations = await getDestinations(locale!);
const destinationBySlug = new Map(
  allDestinations.map((destination) => [destination.slug, destination]),
);

const groups = destinationsPageContent.groups.map(
  (group: {
    id: string;
    label: string;
    title: string;
    description: string;
    destinationSlugs: readonly string[];
    intro: string;
  }) => ({
    ...group,
    count: group.destinationSlugs.length,
    destinations: group.destinationSlugs
      .map((slug: string) => destinationBySlug.get(slug))
      .filter(Boolean),
  }),
);

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  { label: globalStrings.breadcrumb.destinations },
];
---

<MainLayout
  title={globalStrings.page.destinations}
  description={destinationsPageContent.hero.description}
  canonical={`/${locale}/destinations`}
  image={destinationsPageContent.spotlightImage}
  locale={locale}
>
  <StructuredData schema={faqSchema} />
  <div id="top"></div>

  <PageHeader
    eyebrow={destinationsPageContent.hero.eyebrow}
    title={destinationsPageContent.hero.title}
    description={destinationsPageContent.hero.description}
    breadcrumbs={breadcrumbs}
    image={destinationsPageContent.spotlightImage}
    imageAlt={globalStrings.common.imageAltDestinations}
  />

  <StickyNav
    items={groups.map(
      ({ id, label, count }: { id: string; label: string; count: number }) => ({
        id,
        label,
        count,
      }),
    )}
    dataAttr="destination-group-link"
  />

  {
    groups.map((group: any, index: number) => (
      <SectionContainer
        background={index % 2 === 0 ? "bg-surface-soft" : "bg-background"}
      >
        <DestinationGroupSection
          id={group.id}
          locale={locale}
          title={group.title}
          description={group.description}
          destinations={group.destinations}
          moreCountLabel={globalStrings.common.moreCount}
          viewDetailLabel={globalStrings.common.viewDetail}
          backToTopLabel={globalStrings.common.backToTop}
        />
      </SectionContainer>
    ))
  }

  <FaqSection
    eyebrow={faqStrings.faq.sectionTitle}
    title={destinationsPageContent.detail.faqTitle}
    items={destinationsPageContent.faq}
  />

  <RelatedContent
    title={packageStrings.paketWisata.exploreServices}
    items={destinationsPageContent.relatedContent}
    background="bg-surface-soft"
  />
</MainLayout>

---
import { TypographyH1 } from "@/components/ui/typography";
import MainLayout from "@/layouts/MainLayout.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Button } from "@/components/ui/button";
import { getGlobalStrings, NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const homeHref = `/${locale}`;
---

<MainLayout
  title={`404 - ${globalStrings.common.pageNotFound}`}
  description={globalStrings.common.pageNotFoundDesc}
  noIndex={true}
  locale={locale}
>
  <SectionContainer background="bg-surface-soft" padding="py-24 sm:py-32">
    <div class="mx-auto max-w-xl text-center">
      <p class="text-8xl font-bold text-brand-600">404</p>
      <TypographyH1 class="mt-4 text-3xl leading-tight sm:text-4xl">
        {globalStrings.common.pageNotFound}
      </TypographyH1>
      <p class="mt-4 text-base leading-7 text-text-muted">
        {globalStrings.common.pageNotFoundDesc}
      </p>
      <div class="mt-8">
        <Button as="a" href={homeHref} variant="default" size="lg">
          {globalStrings.common.back}
        </Button>
      </div>
    </div>
  </SectionContainer>
</MainLayout>

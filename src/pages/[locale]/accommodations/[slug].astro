---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";

import { getAccommodations } from "@/lib/content/accommodations/collection";
import { REGION_LABEL, type RegionKey as Region } from "@/lib/regions";

import AccommodationCard from "@/components/cards/AccommodationCard.astro";

import { loadContent } from "@/lib/i18n/loader";
import {
  getAccommodationsPageStrings,
  getGlobalStrings,
  NON_DEFAULT_LOCALES,
} from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  const regions: Region[] = ["lombok", "sumbawa", "labuan-bajo"];
  for (const locale of NON_DEFAULT_LOCALES) {
    const accommodations = await getAccommodations(locale);
    for (const region of regions) {
      const regionAcc = accommodations.filter((acc) => acc.region === region);
      if (regionAcc.length === 0) continue;
      paths.push({ params: { locale, slug: region }, props: { region } });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const globalStrings = getGlobalStrings(locale!);
const accommodationsStrings = getAccommodationsPageStrings(locale!);
const pageModule = await loadContent(locale!, "akomodasiPage");
const { akomodasiPageContent } = pageModule;

interface Props {
  region: Region;
}

const { region } = Astro.props as Props;
const accommodations = await getAccommodations(locale!);
const regionAccommodations = accommodations.filter(
  (acc) => acc.region === region,
);

const regionName = REGION_LABEL[region];

const breadcrumbs = [
  { label: globalStrings.breadcrumb.home, href: `/${locale}` },
  {
    label: globalStrings.breadcrumb.accommodations,
    href: `/${locale}/accommodations`,
  },
  { label: regionName },
];
---

<MainLayout
  title={`${akomodasiPageContent.hero.title} ${regionName}`}
  description={akomodasiPageContent.regions[region].description}
  canonical={`/${locale}/accommodations/${region}`}
  image={regionAccommodations[0]?.image}
  locale={locale}
>
  <PageHeader
    eyebrow={accommodationsStrings.akomodasi.eyebrow}
    title={accommodationsStrings.akomodasi.accommodationChoice.replace(
      "{region}",
      regionName,
    )}
    description={accommodationsStrings.akomodasi.exploreAccommodation.replace(
      "{region}",
      regionName,
    )}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {
        regionAccommodations.map((accommodation) => (
          <AccommodationCard
            accommodation={accommodation}
            featuresLabel={accommodationsStrings.akomodasi.features}
            morePerksLabel={accommodationsStrings.akomodasi.morePerks}
          />
        ))
      }
    </div>
  </SectionContainer>
</MainLayout>

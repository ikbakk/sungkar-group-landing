---
import { TypographyH2 } from "@/components/ui/typography";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { t, NON_DEFAULT_LOCALES } from "@/lib/i18n";
import { HERO } from "@/assets/images";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const uiStrings = t(locale!);

const metaDescriptions = {
  en: "Read Sungkar Group terms and conditions covering bookings, payments, cancellations, itinerary changes, responsibilities, and use of our travel services.",
  ar: "اقرأ الشروط والأحكام الخاصة بـ Sungkar Group والتي تغطي الحجز والدفع والإلغاء وتغييرات خط السير والمسؤوليات واستخدام خدمات السفر لدينا.",
  ms: "Baca terma dan syarat Sungkar Group yang merangkumi tempahan, pembayaran, pembatalan, perubahan itinerari, tanggungjawab, dan penggunaan perkhidmatan perjalanan kami.",
  zh: "阅读 Sungkar Group 的条款与条件，内容涵盖预订、付款、取消、行程变更、责任范围以及旅游服务的使用。",
} as const;

const metaDescription = metaDescriptions[locale as keyof typeof metaDescriptions];

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: `/${locale}` },
  { label: uiStrings.footer.terms },
];
---

<MainLayout
  title={uiStrings.footer.terms}
  description={metaDescription}
  canonical={`/${locale}/terms-conditions`}
  image={HERO.heroLombok}
  locale={locale}
>
  <PageHeader
    eyebrow={uiStrings.footer.terms}
    title={uiStrings.footer.terms}
    description={metaDescription}
    breadcrumbs={breadcrumbs}
    image={HERO.heroLombok}
    imageAlt={uiStrings.common.imageAltSunrise}
  />

  <SectionContainer background="bg-surface-soft" padding="pb-20">
    <div class="prose prose-sm prose-gray mx-auto max-w-3xl">
      <TypographyH2>1. Pemesanan</TypographyH2>
      <p>
        Pemesanan dapat dilakukan melalui WhatsApp, formulir kontak di website,
        atau dengan menghubungi tim kami secara langsung. Pemesanan dianggap sah
        setelah kami mengonfirmasi ketersediaan dan menerima pembayaran sesuai
        ketentuan.
      </p>

      <TypographyH2>2. Pembayaran</TypographyH2>
      <p>
        Pembayaran dapat dilakukan melalui transfer bank atau metode pembayaran
        lain yang disepakati. DP (uang muka) diperlukan untuk mengamankan
        pemesanan, dengan pelunasan sesuai jadwal yang ditentukan. Pembayaran
        yang diterima akan dikonfirmasi melalui WhatsApp atau email.
      </p>

      <TypographyH2>3. Pembatalan dan Pengembalian Dana</TypographyH2>
      <ul>
        <li>
          Pembatalan 7 hari atau lebih sebelum keberangkatan: pengembalian dana
          penuh dikurangi biaya administrasi.
        </li>
        <li>
          Pembatalan 3-6 hari sebelum keberangkatan: pengembalian 50% dari total
          pembayaran.
        </li>
        <li>Pembatalan kurang dari 3 hari: tidak ada pengembalian dana.</li>
        <li>
          Pembatalan dari pihak kami karena force majeure: pengembalian dana
          penuh atau penjadwalan ulang.
        </li>
      </ul>

      <TypographyH2>4. Perubahan Itinerary</TypographyH2>
      <p>
        Perubahan itinerary dapat dilakukan sebelum keberangkatan sesuai
        kesepakatan. Selama perjalanan, perubahan dapat dilakukan dengan
        mempertimbangkan kondisi cuaca, aksesibilitas, dan situasi di lapangan
        demi kenyamanan dan keselamatan tamu.
      </p>

      <TypographyH2>5. Tanggung Jawab</TypographyH2>
      <p>
        Sungkar Group bertanggung jawab atas layanan yang telah disepakati dalam
        itinerary. Kami tidak bertanggung jawab atas:
      </p>
      <ul>
        <li>
          Keterlambatan atau pembatalan transportasi umum (pesawat, kapal)
        </li>
        <li>Kehilangan barang pribadi selama perjalanan</li>
        <li>
          Kejadian di luar kendali kami (force majeure, bencana alam, kerusuhan)
        </li>
      </ul>

      <TypographyH2>6. Keselamatan dan Asuransi</TypographyH2>
      <p>
        Keselamatan tamu adalah prioritas utama kami. Kami merekomendasikan tamu
        untuk memiliki asuransi perjalanan pribadi. Untuk aktivitas tertentu
        (seperti trekking atau snorkeling) kami menyediakan peralatan
        keselamatan standar dan panduan yang berpengalaman.
      </p>

      <TypographyH2>7. Perilaku Tamu</TypographyH2>
      <p>
        Tamu diharapkan menghormati budaya lokal, lingkungan, dan sesama peserta
        perjalanan. Perilaku yang mengganggu atau merusak dapat mengakibatkan
        pembatalan layanan tanpa pengembalian dana.
      </p>

      <TypographyH2>8. Hak Kekayaan Intelektual</TypographyH2>
      <p>
        Seluruh konten di website ini, termasuk teks, gambar, video, dan logo,
        adalah milik Sungkar Group dan dilindungi oleh hak cipta. Dilarang
        menggunakan atau mereproduksi tanpa izin tertulis.
      </p>

      <TypographyH2>9. Perubahan Ketentuan</TypographyH2>
      <p>
        Sungkar Group berhak mengubah syarat dan ketentuan ini sewaktu-waktu.
        Perubahan akan diinformasikan melalui website ini.
      </p>

      <TypographyH2>10. Hukum yang Berlaku</TypographyH2>
      <p>
        Syarat dan ketentuan ini diatur oleh hukum Republik Indonesia. Setiap
        perselisihan akan diselesaikan melalui musyawarah atau jalur hukum yang
        berlaku.
      </p>
    </div>
  </SectionContainer>
</MainLayout>

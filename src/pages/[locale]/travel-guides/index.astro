---
import TravelGuidesIndexPage from "@/components/pages/TravelGuidesIndexPage.astro";
import { getGuides } from "@/lib/content/guides";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const guides = await getGuides(locale!);
---

<TravelGuidesIndexPage locale={locale!} guides={guides} />

---
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import KeyTakeaways from "@/components/guides/KeyTakeaways.astro";
import GuideCard from "@/components/guides/GuideCard.astro";
import DestinationCard from "@/components/cards/DestinationCard.astro";
import PackageCard from "@/components/cards/PackageCard.astro";
import { HugeiconsIcon } from "@hugeicons/react";
import { AlarmClockIcon, Calendar03Icon } from "@hugeicons/core-free-icons";
import { generateHowToSchema } from "@/lib/schemas";
import { getGuides, getGuide } from "@/lib/content/guides";
import { getDestinations } from "@/lib/content/destinations/collection";
import { getPackages } from "@/lib/content/tourPackages/collection";

import { t, NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const guides = await getGuides(locale);
    for (const guide of guides) {
      paths.push({
        params: { locale, slug: guide.slug },
        props: { slug: guide.slug },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { slug } = Astro.props;
const uiStrings = t(locale!);
const guide = await getGuide(locale!, slug);

if (!guide) {
  return Astro.redirect(`/${locale}/travel-guides`, 404);
}

const {
  Content,
  title,
  description,
  readingTime,
  publishDate,
  keyTakeaways,
  relatedDestinations: relatedDestSlugs,
  relatedPackages: relatedPkgSlugs,
  featuredImage,
} = guide;

const allDestinations = await getDestinations(locale!);
const relatedDestinations = allDestinations.filter((d) =>
  relatedDestSlugs.includes(d.slug),
);

const packages = await getPackages(locale!);
const relatedPackages = packages.filter((p) =>
  relatedPkgSlugs.includes(p.slug),
);

const breadcrumbs = [
  { label: uiStrings.breadcrumb.home, href: `/${locale}` },
  {
    label: uiStrings.breadcrumb.travelGuides,
    href: `/${locale}/travel-guides`,
  },
  { label: title },
];

const howToSteps = keyTakeaways.map((takeaway: string, index: number) => ({
  name: uiStrings.guides.stepName.replace("{n}", String(index + 1)),
  description: takeaway,
}));

const guideSchema = generateHowToSchema(title, description, howToSteps);
---

<MainLayout
  title={title}
  description={description}
  canonical={`/${locale}/travel-guides/${slug}`}
  image={featuredImage}
  imageAlt={title}
  locale={locale}
>
  <StructuredData schema={guideSchema} />

  <PageHeader
    eyebrow={uiStrings.page.travelGuides}
    title={title}
    description={description}
    breadcrumbs={breadcrumbs}
  />

  <SectionContainer background="bg-surface-soft">
    <article class="article-content mx-auto max-w-4xl">
      <div
        class="mb-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-text-muted"
      >
        <span class="inline-flex items-center gap-2">
          <HugeiconsIcon icon={AlarmClockIcon} size={16} />
          {readingTime}
          {uiStrings.guides.readingTime}
        </span>
        <span class="hidden sm:inline text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <HugeiconsIcon icon={Calendar03Icon} size={16} />
          <time datetime={publishDate}>
            {
              new Date(publishDate).toLocaleDateString(
                locale === "id"
                  ? "id-ID"
                  : locale === "en"
                    ? "en-US"
                    : locale === "ar"
                      ? "ar-SA"
                      : locale === "ms"
                        ? "ms-MY"
                        : "zh-CN",
                {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                },
              )
            }
          </time>
        </span>
      </div>

      <Content />
    </article>
  </SectionContainer>

  <SectionContainer background="bg-background">
    <KeyTakeaways takeaways={keyTakeaways} />
  </SectionContainer>

  {
    relatedDestinations.length > 0 && (
      <SectionContainer background="bg-surface-soft">
        <div class="mb-8">
          <h2 class="text-3xl leading-tight text-foreground">
            {uiStrings.guides.destinationRelated}
          </h2>
          <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
            {uiStrings.guides.relatedDestinationsDesc}
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {relatedDestinations.map((dest) => (
            <DestinationCard destination={dest} locale={locale} />
          ))}
        </div>
      </SectionContainer>
    )
  }

  {
    relatedPackages.length > 0 && (
      <SectionContainer background="bg-background">
        <div class="mb-8">
          <h2 class="text-3xl leading-tight text-foreground">
            {uiStrings.guides.packageRelated}
          </h2>
          <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
            {uiStrings.guides.relatedPackagesDesc}
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {relatedPackages.map((pkg) => (
            <PackageCard tour={pkg} locale={locale} />
          ))}
        </div>
      </SectionContainer>
    )
  }

  <SectionContainer background="bg-background">
    <div class="mb-8">
      <h2 class="text-3xl leading-tight text-foreground">
        {uiStrings.guides.otherGuides}
      </h2>
    </div>
    <div
      class="-mx-4 flex gap-6 overflow-x-auto px-4 snap-x snap-mandatory sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8"
    >
      {
        (await getGuides(locale!))
          .filter((g) => g.slug !== slug)
          .slice(0, 5)
          .map((g) => (
            <div class="w-[85vw] shrink-0 snap-start sm:w-[380px]">
              <GuideCard guide={g} locale={locale} />
            </div>
          ))
      }
    </div>
  </SectionContainer>
</MainLayout>

<style is:global>
  .article-content h1 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .article-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-content p {
    color: var(--color-foreground);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  .article-content ul,
  .article-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  .article-content ul {
    list-style-type: disc;
  }

  .article-content ol {
    list-style-type: decimal;
  }

  .article-content li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
    color: var(--color-foreground);
  }

  .article-content strong {
    font-weight: 600;
    color: var(--color-foreground);
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .article-content th {
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-soft);
    padding: 0.75rem;
    font-weight: 600;
    text-align: left;
  }

  .article-content td {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
  }
</style>

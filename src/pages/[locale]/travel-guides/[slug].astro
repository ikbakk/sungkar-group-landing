---
import TravelGuidePage from "@/components/pages/TravelGuidePage.astro";
import { getGuides, getGuide } from "@/lib/content/guides";
import { NON_DEFAULT_LOCALES } from "@/lib/i18n";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const guides = await getGuides(locale);
    for (const guide of guides) {
      paths.push({
        params: { locale, slug: guide.slug },
        props: { slug: guide.slug },
      });
    }
  }
  return paths;
}

const { locale } = Astro.params;
const { slug } = Astro.props;
const guide = await getGuide(locale!, slug);

if (!guide) {
  return Astro.redirect(`/${locale}/travel-guides`, 404);
}
---

<TravelGuidePage locale={locale!} slug={slug} guide={guide} />

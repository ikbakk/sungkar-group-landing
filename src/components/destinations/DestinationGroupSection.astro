---
import { TypographyH2 } from "@/components/ui/typography";
import { t } from "@/lib/i18n";
import DestinationCard from "@/components/cards/DestinationCard.astro";
import type { Destination } from "@/lib/content/destinations";

const {
  id,
  locale = "id",
  title,
  description,
  destinations,
} = Astro.props as {
  id: string;
  locale?: string;
  title: string;
  description: string;
  destinations: Destination[];
};

const uiStrings = t(locale);
---

<div id={id} class="scroll-mt-48" data-scroll-section>
  <div class="mb-8">
    <TypographyH2 class="text-3xl leading-tight">{title}</TypographyH2>
    <p class="mt-2 max-w-3xl font-sans text-sm leading-7 text-text-muted">
      {description}
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {
      destinations.map((destination) => (
        <DestinationCard destination={destination} />
      ))
    }
  </div>

  <div class="mt-8 flex justify-center">
    <a
      href="#top"
      class="rounded-lg border border-border bg-white px-4 py-2 text-sm font-medium"
    >
      {uiStrings.common.backToTop}
    </a>
  </div>
</div>

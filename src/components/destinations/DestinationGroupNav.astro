---
interface Group {
  id: string;
  label: string;
  count: number;
}

interface Props {
  groups: Group[];
}

const { groups } = Astro.props as Props;
---

<nav
  class="sticky top-28 z-20 mx-auto mb-8 flex max-w-7xl gap-2 overflow-x-auto rounded-xl border border-border bg-white p-2"
>
  {
    groups.map((group) => (
      <a
        href={`#${group.id}`}
        data-destination-group-link
        class="whitespace-nowrap rounded-lg border border-border px-4 py-2 text-sm font-medium transition"
      >
        {group.label} ({group.count})
      </a>
    ))
  }
</nav>

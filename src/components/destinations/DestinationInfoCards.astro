---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";

interface Props {
  summary: string;
  content: {
    summaryTitle: string;
    transportTitle: string;
    transportDescription: string;
    transportNote: string;
  };
}

const { summary, content } = Astro.props;
---

<div class="mt-10 grid gap-6 lg:grid-cols-2">
  <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
    <CardHeader>
      <CardTitle className="text-3xl leading-tight">
        {content.summaryTitle}
      </CardTitle>
    </CardHeader>
    <CardContent>
      <p class="text-sm leading-7 text-text-muted">{summary}</p>
    </CardContent>
  </Card>

  <Card className="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
    <CardHeader>
      <CardTitle className="text-3xl leading-tight">
        {content.transportTitle}
      </CardTitle>
    </CardHeader>
    <CardContent>
      <div class="grid gap-3 text-sm leading-7 text-text-muted">
        <p>{content.transportDescription}</p>
        <Separator />
        <p>{content.transportNote}</p>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/kontak" variant="outline">
          Cek Ketersediaan
        </Button>
        <Button href="/kontak">Chat WhatsApp</Button>
      </div>
    </CardContent>
  </Card>
</div>

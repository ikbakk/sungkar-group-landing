---
import { TypographyH2 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import type { Destination } from "@/lib/content/destinations";

interface Props {
  destination: Destination;
  content: {
    activitiesTitle: string;
    summaryTitle: string;
    descriptionTitle: string;
    highlightsTitle: string;
    bestTimeToVisitTitle: string;
    howToGetThereTitle: string;
    localTipsTitle: string;
  };
}

const { destination, content } = Astro.props;
---

<div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
  <div class="overflow-hidden rounded-2xl border border-border">
    <OptimizedImage
      src={destination.image}
      alt={destination.title}
      class="aspect-4/3 w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="flex flex-col gap-8">
    <div>
      <TypographyH2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
        {content.activitiesTitle}
      </TypographyH2>
      <ul class="mt-5 flex flex-wrap gap-3">
        {
          destination.thingsToDo.map((item) => (
            <li class="rounded-xl border border-border bg-surface-soft px-4 py-2.5 text-sm font-medium text-foreground">
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="h-px w-16 bg-brand-600"></div>

    <div>
      <TypographyH2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
        {content.summaryTitle}
      </TypographyH2>
      <p class="mt-4 text-sm leading-7 text-text-muted sm:text-base">
        {destination.summary}
      </p>
    </div>
  </div>
</div>

{
  (destination.description ||
    destination.highlights?.length ||
    destination.bestTimeToVisit ||
    destination.howToGetThere ||
    destination.localTips?.length) && (
    <div class="mt-16 grid gap-12">
      {destination.description && (
        <div>
          <TypographyH2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
            {content.descriptionTitle}
          </TypographyH2>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-text-muted sm:text-base whitespace-pre-line">
            {destination.description}
          </p>
        </div>
      )}

      {destination.highlights && destination.highlights.length > 0 && (
        <div>
          <TypographyH2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
            {content.highlightsTitle}
          </TypographyH2>
          <ul class="mt-5 grid gap-3 sm:grid-cols-2">
            {destination.highlights.map((item) => (
              <li class="flex items-start gap-3 rounded-xl border border-border bg-surface-soft p-4 text-sm text-foreground">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">
                  ✓
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      )}

      {(destination.bestTimeToVisit || destination.howToGetThere) && (
        <div class="grid gap-8 sm:grid-cols-2">
          {destination.bestTimeToVisit && (
            <div>
              <TypographyH2 class="text-xl leading-tight tracking-tight sm:text-2xl">
                {content.bestTimeToVisitTitle}
              </TypographyH2>
              <p class="mt-3 text-sm leading-7 text-text-muted sm:text-base">
                {destination.bestTimeToVisit}
              </p>
            </div>
          )}
          {destination.howToGetThere && (
            <div>
              <TypographyH2 class="text-xl leading-tight tracking-tight sm:text-2xl">
                {content.howToGetThereTitle}
              </TypographyH2>
              <p class="mt-3 text-sm leading-7 text-text-muted sm:text-base">
                {destination.howToGetThere}
              </p>
            </div>
          )}
        </div>
      )}

      {destination.localTips && destination.localTips.length > 0 && (
        <div>
          <TypographyH2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
            {content.localTipsTitle}
          </TypographyH2>
          <ul class="mt-5 space-y-3">
            {destination.localTips.map((tip) => (
              <li class="rounded-xl border border-border bg-surface-soft px-5 py-3 text-sm leading-7 text-text-muted">
                💡 {tip}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  )
}

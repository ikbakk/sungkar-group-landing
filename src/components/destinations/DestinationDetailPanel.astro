---
import { Image } from "astro:assets";
import type { Destination } from "@/lib/content/destinationsData";

interface Props {
  destination: Destination;
  content: {
    activitiesTitle: string;
    summaryTitle: string;
  };
}

const { destination, content } = Astro.props;
---

<div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
  <div class="overflow-hidden rounded-2xl border border-border">
    <Image
      src={destination.image}
      alt={destination.title}
      class="aspect-4/3 w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="flex flex-col gap-8">
    <div>
      <h2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
        {content.activitiesTitle}
      </h2>
      <ul class="mt-5 flex flex-wrap gap-3">
        {
          destination.thingsToDo.map((item) => (
            <li class="rounded-xl border border-border bg-surface-soft px-4 py-2.5 text-sm font-medium text-foreground">
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="h-px w-16 bg-brand-600" />

    <div>
      <h2 class="text-2xl leading-tight tracking-tight sm:text-3xl">
        {content.summaryTitle}
      </h2>
      <p class="mt-4 text-sm leading-7 text-text-muted sm:text-base">
        {destination.summary}
      </p>
    </div>
  </div>
</div>

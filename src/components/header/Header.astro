---
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { BRAND } from "@/assets/images";

import NavigationDesktop from "./NavigationDesktop.astro";
import NavigationMobile from "./NavigationMobile";

import { loadContent } from "@/lib/i18n/loader";
import { getHeaderStrings } from "@/lib/i18n";

import LocaleSwitcher from "./LocaleSwitcher.astro";
import { localizeHref } from "@/lib/i18n/localize";
import { getPackages } from "@/lib/content/tourPackages/collection";
import { getAccommodations } from "@/lib/content/accommodations/collection";
import { getVehicles } from "@/lib/content/car-rental/collection";
import type { NavGroup, NavItem } from "@/lib/content/shared/types";

interface Props {
  locale?: string;
}

const { locale = "id" } = Astro.props as Props;
const navModule = await loadContent(locale, "navigation");
const packages = await getPackages(locale);
const accommodations = await getAccommodations(locale);
const vehicles = await getVehicles(locale);

const availableAccommodationHrefs = new Set(
  accommodations.map((item) => `/akomodasi/${item.region}`),
);
const availableVehicleHrefs = new Set(
  vehicles.map((item) => `/sewa-mobil/${item.region}`),
);

function isAvailableHref(href?: string) {
  if (!href) return true;
  if (href.startsWith("/akomodasi/")) {
    return availableAccommodationHrefs.has(href);
  }
  if (href.startsWith("/sewa-mobil/")) {
    return availableVehicleHrefs.has(href);
  }
  return true;
}

function pruneGroup(group: NavGroup): NavGroup | null {
  const items = group.items?.filter((item) => isAvailableHref(item.href));
  const collections = group.collections
    ?.map((collection) => ({
      ...collection,
      items: collection.items.filter((item) => isAvailableHref(item.href)),
    }))
    .filter((collection) => collection.items.length > 0);

  if ((items?.length ?? 0) === 0 && (collections?.length ?? 0) === 0) {
    return null;
  }

  return { ...group, items, collections };
}

function pruneNavigation(items: NavItem[]): NavItem[] {
  return items
    .map((item) => {
      if (item.variant === "link")
        return isAvailableHref(item.href) ? item : null;

      if (item.variant === "dropdown") {
        const dropdownItems = item.items?.filter((subItem) =>
          isAvailableHref(subItem.href),
        );
        return (dropdownItems?.length ?? 0) > 0
          ? { ...item, items: dropdownItems }
          : null;
      }

      const groups = item.groups
        ?.map(pruneGroup)
        .filter((group): group is NavGroup => Boolean(group));

      return (groups?.length ?? 0) > 0 ? { ...item, groups } : null;
    })
    .filter((item): item is NavItem => Boolean(item));
}

const navigation = pruneNavigation(navModule.createNavigation(packages));
const headerStrings = getHeaderStrings(locale);
---

<header class="fixed top-0 z-50 w-full px-4 pt-4 sm:pt-6">
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 rounded-full bg-brand-900/80 px-4 py-3 ring-1 ring-white/10 backdrop-blur-xl sm:px-6 text-white"
    style="box-shadow: 0 2px 8px rgba(0,0,0,0.15), 0 8px 32px rgba(0,0,0,0.1);"
  >
    <a href={localizeHref("/", locale)} class="flex items-center gap-3">
      <OptimizedImage
        src={BRAND.logo}
        alt={headerStrings.siteName}
        class="h-14 w-auto"
        loading="eager"
      />
    </a>

    <nav class="hidden flex-1 justify-center lg:flex lg:max-w-6xl">
      <NavigationDesktop items={navigation} locale={locale} />
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <LocaleSwitcher locale={locale} />
    </div>

    <NavigationMobile items={navigation} locale={locale} client:only="react" />
  </div>
</header>

---
import { TypographyH2 } from "@/components/ui/typography";
import MainLayout from "@/layouts/MainLayout.astro";
import PageHeader from "@/components/site/PageHeader.astro";
import SectionContainer from "@/layouts/SectionContainer.astro";
import GuideCard from "@/components/guides/GuideCard.astro";
import { REGION_LABEL } from "@/lib/regions";
import type { GuideMeta } from "@/lib/content/guides";

import { getGlobalStrings, getTravelGuidesPageStrings } from "@/lib/i18n";

interface Props {
  locale: string;
  guides: GuideMeta[];
}

const { locale, guides } = Astro.props as Props;
const isDefaultLocale = locale === "id";
const globalStrings = getGlobalStrings(locale);
const guideStrings = getTravelGuidesPageStrings(locale);

const regions = ["lombok", "sumbawa", "labuan-bajo", "general"] as const;

function guidesByRegion(region: string) {
  return guides.filter((g) => g.region === region);
}

const breadcrumbs = [
  {
    label: globalStrings.breadcrumb.home,
    href: isDefaultLocale ? "/" : `/${locale}`,
  },
  { label: globalStrings.breadcrumb.travelGuides },
];
const canonicalPath = isDefaultLocale
  ? "/panduan-wisata"
  : `/${locale}/travel-guides`;
---

<MainLayout
  title={globalStrings.page.travelGuides}
  description={guideStrings.guides.guidesIndexDesc}
  canonical={canonicalPath}
  locale={locale}
>
  <PageHeader
    eyebrow={globalStrings.page.travelGuides}
    title={guideStrings.guides.general}
    description={guideStrings.guides.guidesIndexDesc}
    breadcrumbs={breadcrumbs}
  />

  {
    regions.map((region) => {
      const regionGuides = guidesByRegion(region);
      if (regionGuides.length === 0) return null;

      const label =
        region === "general"
          ? guideStrings.guides.general
          : guideStrings.guides.guideFor.replace(
              "{region}",
              REGION_LABEL[region as keyof typeof REGION_LABEL],
            );

      const regionDesc =
        region === "lombok"
          ? guideStrings.guides.regionLombok
          : region === "sumbawa"
            ? guideStrings.guides.regionSumbawa
            : region === "labuan-bajo"
              ? guideStrings.guides.regionLabuanBajo
              : guideStrings.guides.regionGeneral;

      return (
        <SectionContainer
          background={region === "lombok" ? "bg-surface-soft" : "bg-background"}
        >
          <div class="mb-12">
            <TypographyH2 class="text-3xl leading-tight text-foreground">
              {label}
            </TypographyH2>
            <p class="mt-3 max-w-2xl text-base leading-7 text-text-muted">
              {regionDesc}
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {regionGuides.map((guide) => (
              <GuideCard
                guide={guide}
                locale={locale}
                readingTimeLabel={guideStrings.guides.readingTime}
              />
            ))}
          </div>
        </SectionContainer>
      );
    })
  }
</MainLayout>

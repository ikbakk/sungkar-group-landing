---
import { TypographyH2 } from "@/components/ui/typography";
import type { Vehicle } from "@/lib/content/shared/types";
import VehicleCard from "@/components/cards/VehicleCard.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  vehicles: Vehicle[];
  locale?: string;
  passengersLabel: string;
  specificationsLabel: string;
  transmissionLabel: string;
  featuresLabel: string;
  suitableForLabel: string;
  viewDetailRentLabel: string;
  prioritizeImages?: boolean;
}

const {
  id,
  title,
  description,
  vehicles,
  locale = "id",
  passengersLabel,
  specificationsLabel,
  transmissionLabel,
  featuresLabel,
  suitableForLabel,
  viewDetailRentLabel,
  prioritizeImages = false,
} = Astro.props;
---

{
  vehicles.length > 0 && (
    <div id={id} data-scroll-section class="py-12">
      <div class="mb-8">
        <TypographyH2 class="mb-3 text-3xl leading-tight">{title}</TypographyH2>
        <p class="max-w-3xl text-sm leading-7 text-text-muted">{description}</p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        {vehicles.map((vehicle, i) => (
          <VehicleCard
            vehicle={vehicle}
            locale={locale}
            passengersLabel={passengersLabel}
            specificationsLabel={specificationsLabel}
            transmissionLabel={transmissionLabel}
            featuresLabel={featuresLabel}
            suitableForLabel={suitableForLabel}
            viewDetailRentLabel={viewDetailRentLabel}
            loading={prioritizeImages && i < 2 ? "eager" : "lazy"}
            fetchpriority={prioritizeImages && i === 0 ? "high" : "auto"}
          />
        ))}
      </div>
    </div>
  )
}

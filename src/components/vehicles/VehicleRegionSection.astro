---
import type { Vehicle } from "@/lib/content/sewaModilData";
import VehicleCard from "@/components/cards/VehicleCard.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  vehicles: Vehicle[];
}

const { id, title, description, vehicles } = Astro.props;
---

{vehicles.length > 0 && (
  <section id={id} data-scroll-section class="py-12">
    <div class="mb-8">
      <h2 class="mb-3 text-3xl font-heading leading-tight">{title}</h2>
      <p class="max-w-3xl text-sm leading-7 text-text-muted">
        {description}
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {vehicles.map((vehicle) => <VehicleCard vehicle={vehicle} />)}
    </div>
  </section>
)}

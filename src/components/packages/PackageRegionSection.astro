---
import PackageCard from "@/components/cards/PackageCard.astro";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";

const { id, title, description, packages, locale = "id" } = Astro.props as {
  id: string;
  title: string;
  description: string;
  packages: TourPackage[];
  locale?: string;
};

const uiStrings = t(locale);
---

<div id={id} class="scroll-mt-48" data-scroll-section>
  <div class="mb-8">
    <h2 class="text-3xl leading-tight">{title}</h2>
    <p class="mt-2 max-w-3xl text-sm leading-7 text-text-muted font-sans">
      {description}
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {packages.map((tour) => <PackageCard tour={tour} />)}
  </div>

  <div class="mt-8 flex justify-center">
    <a
      href="#top"
      class="rounded-lg border border-border bg-white px-4 py-2 text-sm font-medium"
    >
      {uiStrings.common.backToTop}
    </a>
  </div>
</div>

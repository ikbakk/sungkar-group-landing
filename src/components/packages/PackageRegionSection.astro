---
import { TypographyH2 } from "@/components/ui/typography";
import PackageCard from "@/components/cards/PackageCard.astro";
import type { TourPackage } from "@/lib/content/tourPackages/types";

const {
  id,
  title,
  description,
  packages,
  locale = "id",
  backToTopLabel,
  moreCountLabel,
  viewPackageDetailLabel,
} = Astro.props as {
  id: string;
  title: string;
  description: string;
  packages: TourPackage[];
  locale?: string;
  backToTopLabel: string;
  moreCountLabel: string;
  viewPackageDetailLabel: string;
};
---

<div id={id} class="scroll-mt-48" data-scroll-section>
  <div class="mb-8">
    <TypographyH2 class="text-3xl leading-tight">{title}</TypographyH2>
    <p class="mt-2 max-w-3xl text-sm leading-7 text-text-muted font-sans">
      {description}
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {
      packages.map((tour, i) => (
        <PackageCard
          tour={tour}
          locale={locale}
          moreCountLabel={moreCountLabel}
          viewPackageDetailLabel={viewPackageDetailLabel}
          loading={i < 3 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "auto"}
        />
      ))
    }
  </div>

  <div class="mt-8 flex justify-center">
    <a
      href="#top"
      class="rounded-lg border border-border bg-white px-4 py-2 text-sm font-medium"
    >
      {backToTopLabel}
    </a>
  </div>
</div>

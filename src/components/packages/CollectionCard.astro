---
import { Card, CardContent } from "@/components/ui/card";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";

interface Props {
  collection: {
    slug: string;
    title: string;
    packages: TourPackage[];
  };
  region: string;
  locale?: string;
}

const { collection, region, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<a href={`/paket-wisata/${region}/${collection.slug}`}>
  <Card
    class="h-full
      transition-all
      hover:-translate-y-1
      hover:shadow-lg
      cursor-pointer"
  >
    <CardContent class="p-6">
      <h2 class="text-xl">{collection.title}</h2>
      <p class="mt-2 text-sm text-text-muted">
        {
          uiStrings.paketWisata.packagesAvailable.replace(
            "{n}",
            String(collection.packages.length),
          )
        }
      </p>
      <ul class="mt-4 space-y-2 text-sm text-text-muted">
        {
          collection.packages.slice(0, 3).map((pkg) => (
            <li class="flex gap-2">
              <span>•</span>
              <span>{pkg.title}</span>
            </li>
          ))
        }
        {
          collection.packages.length > 3 && (
            <li class="font-medium text-brand-700">
              {uiStrings.paketWisata.morePackages.replace(
                "{n}",
                String(collection.packages.length - 3),
              )}
            </li>
          )
        }
      </ul>
    </CardContent>
  </Card>
</a>

---
import { TypographyH2 } from "@/components/ui/typography";
import { Card, CardContent } from "@/components/ui/card";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { localizeHref } from "@/lib/i18n/localize";

interface Props {
  collection: {
    slug: string;
    title: string;
    packages: TourPackage[];
  };
  region: string;
  locale?: string;
  packagesAvailableLabel: string;
  morePackagesLabel: string;
}

const {
  collection,
  region,
  locale = "id",
  packagesAvailableLabel,
  morePackagesLabel,
} = Astro.props;
---

<a href={localizeHref(`/paket-wisata/${region}/${collection.slug}`, locale)}>
  <Card
    class="h-full
      transition-all
      hover:-translate-y-1
      hover:shadow-lg
      cursor-pointer"
  >
    <CardContent class="p-6">
      <TypographyH2 class="text-xl">{collection.title}</TypographyH2>
      <p class="mt-2 text-sm text-text-muted">
        {
          packagesAvailableLabel.replace(
            "{n}",
            String(collection.packages.length),
          )
        }
      </p>
      <ul class="mt-4 space-y-2 text-sm text-text-muted">
        {
          collection.packages.slice(0, 3).map((pkg) => (
            <li class="flex gap-2">
              <span>•</span>
              <span>{pkg.title}</span>
            </li>
          ))
        }
        {
          collection.packages.length > 3 && (
            <li class="font-medium text-brand-700">
              {morePackagesLabel.replace(
                "{n}",
                String(collection.packages.length - 3),
              )}
            </li>
          )
        }
      </ul>
    </CardContent>
  </Card>
</a>

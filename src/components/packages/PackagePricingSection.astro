---
import { TypographyH2, TypographyP } from "@/components/ui/typography";
import { t } from "@/lib/i18n";
import {
  Table,
  TableHeader,
  TableBody,
  TableFooter,
  TableRow,
  TableHead,
  TableCell,
} from "@/components/ui/table";

interface Props {
  priceList: Record<string, Record<string, number>>;
  locale?: string;
  durationLabels?: Record<string, string>;
}

const { priceList, locale = "id", durationLabels } = Astro.props;
const uiStrings = t(locale);

const labels = {
  title: uiStrings.paketWisata.packagePrice,
  desc: uiStrings.paketWisata.packagePriceDesc,
  participants: uiStrings.paketWisata.participants,
  addPerPax: uiStrings.paketWisata.additionalPax,
};

const durationKeys = durationLabels
  ? Object.keys(durationLabels).filter((key) => priceList[key])
  : Object.keys(priceList);

const tierKeys = Array.from(
  new Set(
    durationKeys.flatMap((durationKey) =>
      Object.keys(priceList[durationKey] ?? {}).filter(
        (key) => key !== "addPerPax" && key !== "maxPax",
      ),
    ),
  ),
).sort((a, b) => {
  const aMin = Number.parseInt(a.split("-")[0] ?? a, 10);
  const bMin = Number.parseInt(b.split("-")[0] ?? b, 10);
  return aMin - bMin;
});
const hasAddPerPax = durationKeys.some(
  (durationKey) => priceList[durationKey]?.addPerPax,
);

function formatRupiah(value?: number): string {
  if (!value) return "—";
  return new Intl.NumberFormat("id-ID", {
    style: "currency",
    currency: "IDR",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(value);
}

function formatTierLabel(key: string): string {
  return key.includes("-") ? `${key} pax` : key;
}
---

<div class="w-full">
  <!-- Eyebrow + heading -->
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {labels.title}
  </div>

  <TypographyH2 class="mt-2">{labels.title}</TypographyH2>
  <TypographyP class="mt-3 max-w-3xl text-muted-foreground">
    {labels.desc}
  </TypographyP>

  <!-- Pricing table: always shown when priceList is present -->
  <div class="mt-8">
    <Table class="w-full">
      <TableHeader>
        <TableRow>
          <TableHead class="font-semibold">
            {labels.participants}
          </TableHead>
          {
            durationKeys.map((durationKey) => (
              <TableHead class="text-right font-semibold">
                {durationLabels?.[durationKey] ?? durationKey}
              </TableHead>
            ))
          }
        </TableRow>
      </TableHeader>
      <TableBody>
        {
          tierKeys.map((tierKey) => (
            <TableRow>
              <TableCell class="font-medium text-foreground">
                {formatTierLabel(tierKey)}
              </TableCell>
              {durationKeys.map((durationKey) => (
                <TableCell class="text-right font-semibold text-brand-700">
                  {formatRupiah(priceList[durationKey]?.[tierKey])}
                </TableCell>
              ))}
            </TableRow>
          ))
        }
      </TableBody>
      {
        hasAddPerPax ? (
          <TableFooter>
            <TableRow>
              <TableCell class="font-medium">{labels.addPerPax}</TableCell>
              {durationKeys.map((durationKey) => (
                <TableCell class="text-right font-semibold text-brand-700">
                  {formatRupiah(priceList[durationKey]?.addPerPax)}
                </TableCell>
              ))}
            </TableRow>
          </TableFooter>
        ) : null
      }
    </Table>
  </div>
</div>

---
import { TypographyH2 } from "@/components/ui/typography";
import { t } from "@/lib/i18n";

interface Props {
  content: string[];
  locale?: string;
}

const { content, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<div>
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.termsAndConditions}
  </div>

  <TypographyH2 class="mt-2">
    {uiStrings.paketWisata.termsAndConditions}
  </TypographyH2>

  <ul class="mt-6 space-y-2.5">
    {
      content.map((line) => (
        <li class="flex gap-3 text-sm leading-6 text-text-muted">
          <span class="mt-1.75 size-1 shrink-0 rounded-full bg-brand-300/60" />
          <span>{line}</span>
        </li>
      ))
    }
  </ul>
</div>

---
import { t } from "@/lib/i18n";

interface Props {
  content: string;
  locale?: string;
}

const { content, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<div class="mx-auto max-w-3xl">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.termsAndConditions}
  </div>

  <h2 class="mt-2 text-3xl leading-tight sm:text-4xl">
    {uiStrings.paketWisata.termsAndConditions}
  </h2>

  <div class="mt-6">
    {content.split("\n").filter(Boolean).map((line) => (
      <p class="text-sm leading-7 text-text-muted">{line}</p>
    ))}
  </div>
</div>

---
import { t } from "@/lib/i18n";
import { TypographyH2, TypographyP } from "@/components/ui/typography";

interface Props {
  content: string;
  locale?: string;
}

const { content, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<div class="mx-auto max-w-3xl">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.termsAndConditions}
  </div>

  <TypographyH2 class="mt-2">
    {uiStrings.paketWisata.termsAndConditions}
  </TypographyH2>

  <div class="mt-6 grid gap-2">
    {content.split("\n").filter(Boolean).map((line) => (
      <TypographyP class="m-0 text-sm leading-7 text-muted-foreground">{line}</TypographyP>
    ))}
  </div>
</div>

---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
import WhatsAppForm from "@/components/contact/WhatsAppForm.astro";
import { paketWisataFormFields } from "@/lib/contact-data";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { REGION_LABEL } from "@/lib/regions";

interface Props {
  tour: TourPackage;
}

const { tour } = Astro.props;
---

<div class="flex h-full flex-col gap-6">
  <Card
    className="flex-1 border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]"
  >
    <CardHeader>
      <Badge variant="outline" className="w-fit rounded-lg px-3 py-1">
        {tour.category}
      </Badge>
      <CardTitle className="text-3xl leading-tight">
        Informasi Paket
      </CardTitle>
    </CardHeader>
    <CardContent>
      <div class="grid gap-4 text-sm">
        <div class="flex items-center justify-between">
          <span class="text-text-muted">Durasi</span>
          <span class="font-medium">{tour.duration}</span>
        </div>
        <Separator />
        <div>
          <div class="mb-2 text-text-muted">Termasuk</div>
          <ul class="grid gap-1">
            {tour.includes.slice(0, 4).map((item) => <li>✓ {item}</li>)}
          </ul>
        </div>
        <Separator />
        <div class="flex flex-wrap gap-2">
          {tour.highlights.map((item) => (
            <Badge variant="default" className="rounded-lg px-3 py-1">
              {item}
            </Badge>
          ))}
        </div>
      </div>
    </CardContent>
  </Card>

  <WhatsAppForm
    context="paket-wisata"
    fields={paketWisataFormFields}
    mode="sidebar"
    itemName={tour.title}
    region={REGION_LABEL[tour.region]}
  />
</div>

---
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon, Cancel01Icon } from "@hugeicons/core-free-icons";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";

interface Props {
  tour: TourPackage;
  locale?: string;
}

const { tour, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<div class="mx-auto">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.facilitiesLabel}
  </div>

  <h2 class="mt-2 text-3xl leading-tight sm:text-4xl">
    {uiStrings.paketWisata.includedExcluded}
  </h2>

  <p class="mt-3 text-sm leading-7 text-text-muted">
    {uiStrings.paketWisata.includedExcludedDesc}
  </p>
</div>

<div class="mx-auto mt-10 grid gap-6 md:grid-cols-2">
  <div
    class="rounded-xl border border-border bg-white p-6 shadow-[0_8px_30px_rgba(17,24,39,0.04)]"
  >
    <h3
      class="mb-5 flex items-center gap-2 text-lg leading-tight text-emerald-700"
    >
      <span
        class="flex size-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-600"
      >
        <HugeiconsIcon icon={Tick02Icon} size={14} />
      </span>
      {uiStrings.paketWisata.included}
    </h3>

    <ul class="space-y-2.5">
      {
        tour.includes.map((item) => (
          <li class="flex gap-3 text-sm leading-6 text-text-muted">
            <span class="mt-1.75 size-1 shrink-0 rounded-full bg-emerald-400/60" />
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div
    class="rounded-xl border border-border bg-white p-6 shadow-[0_8px_30px_rgba(17,24,39,0.04)]"
  >
    <h3 class="mb-5 flex items-center gap-2 text-lg leading-tight text-red-600">
      <span
        class="flex size-6 items-center justify-center rounded-full bg-red-100 text-red-500"
      >
        <HugeiconsIcon icon={Cancel01Icon} size={14} />
      </span>
      {uiStrings.paketWisata.excluded}
    </h3>

    <ul class="space-y-2.5">
      {
        tour.excludes.map((item) => (
          <li class="flex gap-3 text-sm leading-6 text-text-muted">
            <span class="mt-1.75 size-1 shrink-0 rounded-full bg-red-300/60" />
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>

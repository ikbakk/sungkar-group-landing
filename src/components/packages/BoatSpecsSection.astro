---
import { TypographyH2 } from "@/components/ui/typography";
import type { BoatSpec } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "@/components/ui/accordion";

interface Props {
  boatName: string;
  boatType?: string;
  boatCapacity?: number;
  specs?: BoatSpec[];
  locale?: string;
}

const { boatName, boatType, boatCapacity, specs, locale = "id" } = Astro.props;
const uiStrings = t(locale);

const INITIAL_COUNT = 6;
const visibleSpecs = specs?.slice(0, INITIAL_COUNT) ?? [];
const hiddenSpecs = specs?.slice(INITIAL_COUNT) ?? [];
const hasMore = hiddenSpecs.length > 0;
---

<div class="w-full">
  <div class="text-sm uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.boatSpecs}
  </div>

  <TypographyH2 class="mt-2 font-normal">{boatName}</TypographyH2>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      boatType && (
        <div class="rounded-xl border border-border bg-card p-4 shadow-xs">
          <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
            {uiStrings.paketWisata.boatType}
          </p>
          <p class="mt-1 text-base">{boatType}</p>
        </div>
      )
    }

    {
      boatCapacity && (
        <div class="rounded-xl border border-border bg-card p-4 shadow-xs">
          <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
            {uiStrings.paketWisata.boatCapacity}
          </p>
          <p class="mt-1 text-base">{boatCapacity}</p>
        </div>
      )
    }

    {visibleSpecs.map((spec) => (
      <div class="rounded-xl border border-border bg-card p-4 shadow-xs">
        <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
          {spec.label}
        </p>
        <p class="mt-1 text-base">{spec.value}</p>
      </div>
    ))}
  </div>

  {
    hasMore && (
      <Accordion class="mt-4" collapsible>
        <AccordionItem value="more-specs" class="border-0">
          <AccordionTrigger class="py-3 text-sm font-medium text-brand-700 hover:no-underline hover:text-brand-600 [&>svg]:text-brand-500 [&>svg]:size-5">
            <span class="group-aria-expanded/accordion-trigger:hidden">
              {locale === "id"
                ? `Lihat Semua Spesifikasi (${hiddenSpecs.length} lainnya)`
                : locale === "en"
                  ? `See All Specifications (${hiddenSpecs.length} more)`
                  : `Lihat Semua Spesifikasi (${hiddenSpecs.length})`}
            </span>
            <span class="hidden group-aria-expanded/accordion-trigger:inline">
              {locale === "id"
                ? "Sembunyikan Spesifikasi"
                : locale === "en"
                  ? "Hide Specifications"
                  : "Sembunyikan Spesifikasi"}
            </span>
          </AccordionTrigger>
          <AccordionContent class="pt-0">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {hiddenSpecs.map((spec) => (
                <div class="rounded-xl border border-border bg-card p-4 shadow-xs">
                  <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
                    {spec.label}
                  </p>
                  <p class="mt-1 text-base">{spec.value}</p>
                </div>
              ))}
            </div>
          </AccordionContent>
        </AccordionItem>
      </Accordion>
    )
  }
</div>

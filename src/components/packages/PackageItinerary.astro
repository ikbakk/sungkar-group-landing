---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  itineraryByDay: [string, string[]][];
}

const { itineraryByDay } = Astro.props;
---

<Card className="border-border bg-white">
  <CardHeader>
    <CardTitle className="text-3xl leading-tight">Itinerary</CardTitle>
  </CardHeader>
  <CardContent>
    <div class="grid gap-4">
      {itineraryByDay.map(([day, activities]) => (
        <div class="rounded-lg border border-border bg-surface-soft p-4">
          <div class="text-xs font-medium uppercase tracking-[0.22em] text-brand-700">
            {day}
          </div>
          <ul class="mt-3 grid gap-2 text-sm leading-7 text-text-muted">
            {activities.map((activity) => (
              <li class="flex gap-2">
                <span>•</span>
                <span>{activity}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </CardContent>
</Card>

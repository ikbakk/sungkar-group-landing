---
import { TypographyH2 } from "@/components/ui/typography";
import { t } from "@/lib/i18n";
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "@/components/ui/accordion";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "@/components/ui/tabs";

import PackageDayTimeline from "./PackageDayTimeline.astro";

interface Props {
  itineraryByDay: [string, string[]][];
  locale?: string;
  durationLabels?: Record<string, string>;
}

const { itineraryByDay, locale = "id", durationLabels } = Astro.props;
const uiStrings = t(locale);
const multiDuration = !!durationLabels;
const firstKey = itineraryByDay[0]?.[0] ?? "";

interface DayGroup {
  day: string;
  activities: string[];
}

interface TabGroup {
  key: string;
  dayGroups: DayGroup[];
}

const tabGroups: TabGroup[] = multiDuration
  ? itineraryByDay.map(([key, activities]) => {
      const dayMap: Record<string, string[]> = {};
      for (const item of activities) {
        const [day, ...rest] = item.split(" - ");
        const desc = rest.join(" - ");
        if (!dayMap[day]) dayMap[day] = [];
        dayMap[day].push(desc);
      }
      return { key, dayGroups: Object.entries(dayMap).map(([day, acts]) => ({ day, activities: acts })) };
    })
  : [];

const singleDayGroups: DayGroup[] = !multiDuration
  ? itineraryByDay.map(([day, activities]) => ({ day, activities }))
  : [];
---

<div class="w-full">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.itineraryLabel}
  </div>
  <TypographyH2 class="mt-2 text-3xl leading-tight sm:text-4xl">
    {uiStrings.paketWisata.itinerary}
  </TypographyH2>
  <p class="mt-3 text-sm leading-7 text-text-muted">
    {uiStrings.paketWisata.itineraryDesc}
  </p>
</div>

{
  multiDuration ? (
    <>
      <Tabs defaultValue={firstKey} class="mt-14 hidden md:block w-full">
        <TabsList
          class="grid w-full"
          style={`grid-template-columns: repeat(${itineraryByDay.length}, 1fr)`}
        >
          {tabGroups.map(({ key }) => (
            <TabsTrigger value={key}>
              {durationLabels[key] || key}
            </TabsTrigger>
          ))}
        </TabsList>

        {tabGroups.map(({ key, dayGroups }) => (
          <TabsContent value={key} class="mt-0">
            <PackageDayTimeline dayGroups={dayGroups} />
          </TabsContent>
        ))}
      </Tabs>

      <Accordion class="mt-14 block md:hidden rounded-lg border">
        {tabGroups.map(({ key, dayGroups }) => (
          <AccordionItem value={key} class="border-b last:border-b-0">
            <AccordionTrigger class="px-4 py-3">
              {durationLabels[key] || key}
            </AccordionTrigger>
            <AccordionContent class="px-4">
              <PackageDayTimeline dayGroups={dayGroups} />
            </AccordionContent>
          </AccordionItem>
        ))}
      </Accordion>
    </>
  ) : (
    <div class="mt-14">
      <PackageDayTimeline dayGroups={singleDayGroups} />
    </div>
  )
}

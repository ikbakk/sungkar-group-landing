---
interface Props {
  itineraryByDay: [string, string[]][];
}

const { itineraryByDay } = Astro.props;
---

TODO: hardcoded need localization
<div class="w-full">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    Perjalanan
  </div>
  <h2 class="mt-2 text-3xl leading-tight sm:text-4xl">Jalur Perjalanan</h2>
  <p class="mt-3 text-sm leading-7 text-text-muted">
    Setiap hari dirancang untuk memberikan pengalaman terbaik selama perjalanan
    Anda.
  </p>
</div>

<div class="relative mx-auto mt-14">
  <div class="absolute left-2.75 top-3 bottom-3 w-px bg-brand-200/50"></div>

  {
    itineraryByDay.map(([day, activities]) => (
      <div class="relative pl-11 pb-14 last:pb-0">
        <div class="absolute left-0 top-2 z-10 flex size-6 items-center justify-center rounded-full border-2 border-brand-500 bg-white">
          <span class="size-2 rounded-full bg-brand-500" />
        </div>

        <h3 class="text-xl leading-tight text-foreground">{day}</h3>

        <ul class="mt-4 space-y-3">
          {activities.map((activity) => (
            <li class="flex gap-3 text-sm leading-6 text-text-muted">
              <span class="mt-1.75 size-1 shrink-0 rounded-full bg-brand-300/60" />
              <span>{activity}</span>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

---
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import PackageGallery from "./PackageGallery";

interface Props {
  tour: TourPackage;
}

const { tour } = Astro.props;
const images = tour.images;
const extraCount = images.length - 1;
---

<div class="grid h-full min-h-0 gap-3 lg:grid-cols-[1.5fr_1fr]">
  <button
    type="button"
    data-image-index="0"
    class="overflow-hidden rounded-lg border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)] cursor-zoom-in"
    aria-label={`Preview ${tour.title}`}
  >
    <OptimizedImage
      src={images[0]}
      alt={tour.title}
      class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]"
      loading="eager"
      fetchpriority="high"
      width={800}
    />
  </button>

  {
    extraCount > 0 && (
      <div
        class:list={{
          "grid gap-3": true,
          "grid-cols-1 grid-rows-1": extraCount === 1,
          "grid-cols-2 grid-rows-1": extraCount === 2,
          "grid-cols-2": extraCount >= 3,
        }}
      >
    <!-- TODO: button should use Button component -->
        {images.slice(1, 5).map((img, i) => (
          <button
            type="button"
            data-image-index={i + 1}
            class="overflow-hidden rounded-lg border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)] cursor-zoom-in"
            aria-label={`View image ${i + 2}`}
          >
      <!-- TODO: OptimizedImage need to have alt, so for every data that have image need to have alt based on locale -->
            <OptimizedImage
              src={img}
              alt=""
              class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]"
              loading="lazy"
              width={400}
            />
          </button>
        ))}
      </div>
    )
  }
</div>

<PackageGallery images={images} client:load />

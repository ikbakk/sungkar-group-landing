---
import { Image } from "astro:assets";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import PackageGallery from "./PackageGallery";

interface Props {
  tour: TourPackage;
}

const { tour } = Astro.props;
---

<div class="flex h-full min-h-0 flex-col gap-3">
  <div
    class="flex-1 overflow-hidden rounded-lg border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)] min-h-0"
  >
    <button
      type="button"
      id="open-image-preview"
      class="block h-full w-full cursor-zoom-in"
      aria-label={`Preview ${tour.title}`}
    >
      <Image
        src={tour.images[0]}
        alt={tour.title}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]"
        loading="eager"
        fetchpriority="high"
      />
    </button>
  </div>

  {
    tour.images.length > 1 && (
      <div class="flex shrink-0 gap-2 overflow-x-auto pb-1">
        {
          tour.images.slice(1).map((img, i) => (
            <button
              key={i}
              class="size-16 shrink-0 overflow-hidden rounded-md border border-border opacity-80 transition-opacity hover:opacity-100"
              aria-label={`View image ${i + 2}`}
            >
              <Image
                src={img}
                alt=""
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </button>
          ))
        }
      </div>
    )
  }
</div>

<PackageGallery images={tour.images} client:load />

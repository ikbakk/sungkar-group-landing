---
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import PackageGallery from "./PackageGallery";
import { Button } from "@/components/ui/button";
import { t } from "@/lib/i18n";

interface Props {
  tour: TourPackage;
  locale?: string;
}

const { tour, locale = "id" } = Astro.props;
const uiStrings = t(locale);
const images = tour.images;
const extraCount = images.length - 1;
---

<div class="grid h-full min-h-0 gap-3 lg:grid-cols-[1.5fr_1fr]">
  <Button
    type="button"
    data-image-index="0"
    variant="ghost"
    class="overflow-hidden rounded-lg border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)] cursor-zoom-in p-0"
    aria-label={`${uiStrings.common.viewDetail}: ${tour.title}`}
  >
    <OptimizedImage
      src={images[0]}
      alt={tour.title}
      class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]"
      loading="eager"
      fetchpriority="high"
      width={800}
    />
  </Button>

  {
    extraCount > 0 && (
      <div
        class:list={{
          "grid gap-3": true,
          "grid-cols-1 grid-rows-1": extraCount === 1,
          "grid-cols-2 grid-rows-1": extraCount === 2,
          "grid-cols-2": extraCount >= 3,
        }}
      >
        {images.slice(1, 5).map((img, i) => (
          <Button
            type="button"
            data-image-index={i + 1}
            variant="ghost"
            class="overflow-hidden rounded-lg border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)] cursor-zoom-in p-0"
            aria-label={`${uiStrings.gallery.photos} ${i + 2}`}
          >
            <OptimizedImage
              src={img}
              alt={tour.title}
              class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02]"
              loading="lazy"
              width={400}
            />
          </Button>
        ))}
      </div>
    )
  }
</div>

<PackageGallery images={images} locale={locale} client:only="react" />

---
import { TypographyH3 } from "@/components/ui/typography";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";

interface Props {
  tour: TourPackage;
  locale?: string;
}

const { tour, locale = "id" } = Astro.props;
const uiStrings = t(locale);
const additionalItems = tour.additionalServices ?? [];
const forgetItems = tour.dontForgetToBring ?? [];
const hasAdditional = additionalItems.length > 0;
const hasDontForget = forgetItems.length > 0;
const hasAny = hasAdditional || hasDontForget;
---

{
  hasAny && (
    <div class="grid gap-6 md:grid-cols-2">
      {
        hasAdditional && (
          <div class="rounded-xl border border-border bg-white p-6 shadow-[0_8px_30px_rgba(17,24,39,0.04)]">
            <TypographyH3 class="mb-5 flex items-center gap-2 text-lg leading-tight text-brand-700">
              {uiStrings.paketWisata.additionalServices}
            </TypographyH3>
            <ul class="space-y-2.5">
              {additionalItems.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-text-muted">
                  <span class="mt-1.75 size-1 shrink-0 rounded-full bg-brand-300/60" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        hasDontForget && (
          <div class="rounded-xl border border-border bg-white p-6 shadow-[0_8px_30px_rgba(17,24,39,0.04)]">
            <TypographyH3 class="mb-5 flex items-center gap-2 text-lg leading-tight text-brand-700">
              {uiStrings.paketWisata.dontForgetToBring}
            </TypographyH3>
            <ul class="space-y-2.5">
              {forgetItems.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-text-muted">
                  <span class="mt-1.75 size-1 shrink-0 rounded-full bg-brand-300/60" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  )
}

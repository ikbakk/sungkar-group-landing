---
import { TypographyH2 } from "@/components/ui/typography";
import type { Cabin } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";
import CabinCard from "./CabinCard.astro";

interface Props {
  cabins: Cabin[];
  locale?: string;
  durationLabels?: Record<string, string>;
  priceList?: Record<string, Record<string, number>>;
  showPrice?: boolean;
}

const {
  cabins,
  locale = "id",
  durationLabels,
  priceList,
  showPrice = true,
} = Astro.props;
const uiStrings = t(locale);
---

<div class="w-full">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.cabins}
  </div>

  <TypographyH2 class="mt-2">{uiStrings.paketWisata.cabins}</TypographyH2>

  <div class="mt-8 grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
    {
      cabins.map((cabin) => (
        <CabinCard
          cabin={cabin}
          locale={locale}
          durationLabels={durationLabels}
          priceList={priceList}
          showPrice={showPrice}
        />
      ))
    }
  </div>
</div>

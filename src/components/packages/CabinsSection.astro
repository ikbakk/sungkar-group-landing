---
import type { Cabin } from "@/lib/content/tourPackages/types";
import { t } from "@/lib/i18n";
import { getImageSrc } from "@/lib/images";
import { TypographyH2, TypographyH3 } from "@/components/ui/typography";
import { Card, CardContent } from "@/components/ui/card";
import { Price } from "@/components/ui/price";

interface Props {
  cabins: Cabin[];
  locale?: string;
}

const { cabins, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<div class="w-full">
  <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
    {uiStrings.paketWisata.cabins}
  </div>

  <TypographyH2 class="mt-2">{uiStrings.paketWisata.cabins}</TypographyH2>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {cabins.map((cabin, i) => (
      <Card size="sm" class="overflow-hidden">
        <div class="aspect-[4/3] overflow-hidden">
          <img
            src={getImageSrc(cabin.image)}
            alt={cabin.name}
            class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
            loading={i < 2 ? "eager" : "lazy"}
          />
        </div>
        <CardContent>
          <TypographyH3 class="!mt-0">{cabin.name}</TypographyH3>
          {cabin.description && (
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {cabin.description}
            </p>
          )}
          <Price class="mt-4">
            <span class="text-lg font-bold text-brand-700">
              {cabin.price}
            </span>
            <span class="text-xs text-muted-foreground">
              /{uiStrings.paketWisata.cabinPrice}
            </span>
          </Price>
        </CardContent>
      </Card>
    ))}
  </div>
</div>

---
import { Image } from "astro:assets";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import type { TourPackage } from "@/lib/content/tourPackages";
import { REGION_MAP } from "@/lib/regions";
import { CTA_CLASS } from "@/lib/card-styles";

interface Props {
  tour: TourPackage;
}

const { tour } = Astro.props;

const region = REGION_MAP[tour.region];

const cardHref = `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`;
---

<a href={cardHref} class="block">
  <Card
    className="
      group
      h-fit
      overflow-hidden
      py-0
      card-interactive
    "
  >
    <!-- Image -->

    <div class="relative overflow-hidden">
      <Image
        src={tour.image}
        alt={tour.title}
        class="aspect-4/3
          w-full
          object-cover
          transition-transform
          duration-700
          ease-out
          group-hover:scale-105"
        loading="lazy"
      />

      <div class="absolute left-4 top-4 font-sans">
        <Badge className={region.className}>
          {region.label}
        </Badge>
      </div>
    </div>

    <!-- Content -->

    <CardContent className="flex h-full flex-col gap-4 p-6">
      <div class="flex flex-wrap items-center gap-2">
        <Badge
          variant="outline"
          className="
            rounded-full
            px-3
            py-1
            text-xs
            font-medium
          "
        >
          {tour.duration}
        </Badge>

        <Badge
          variant="secondary"
          className="
            rounded-full
            px-3
            py-1
            text-xs
            font-medium
          "
        >
          {tour.collectionTitle}
        </Badge>
      </div>

      <div>
        <h3
          class="text-xl
            font-heading
            leading-tight
            text-foreground"
        >
          {tour.title}
        </h3>

        <p
          class="mt-3
            font-sans
            line-clamp-2
            text-sm
            leading-7
            text-text-muted"
        >
          {tour.summary}
        </p>
      </div>

      <ul class="space-y-2 text-sm font-sans">
        {
          tour.highlights.slice(0, 3).map((item) => (
            <li
              class="
                flex
                items-center
                gap-2
                text-text-muted
              "
            >
              <span class="font-semibold text-brand-700">✓</span>

              <span>{item}</span>
            </li>
          ))
        }
        {
          tour.highlights.length > 3 && (
            <li class="text-sm text-text-muted font-sans">
              + {tour.highlights.length - 3} lainnya
            </li>
          )
        }
      </ul>

      <div class="mt-auto pt-2">
        <span class={CTA_CLASS}>
          Cek Detail Paket
        </span>
      </div>
    </CardContent>
  </Card>
</a>

---
import { TypographyH3 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { REGION_MAP } from "@/lib/regions";
import { localizeHref } from "@/lib/i18n/localize";
import { Button } from "@/components/ui/button";
import { t } from "@/lib/i18n";

interface Props {
  tour: TourPackage;
  locale?: string;
  moreCountLabel: string;
  viewPackageDetailLabel: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  tour,
  locale = "id",
  moreCountLabel,
  viewPackageDetailLabel,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const uiStrings = t(locale);
const region = REGION_MAP[tour.region];

const cardHref = localizeHref(
  `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`,
  locale,
);

function parsePriceNumbers(value: string): number[] {
  return Array.from(
    value.matchAll(/(?:IDR|Rp)\s*(\d{1,3}(?:[.,]\d{3})+|\d{6,})/gi),
    (match) => Number(match[1]?.replace(/\D/g, "")),
  ).filter((price) => price > 0);
}

const priceListPrices = tour.priceList
  ? Object.values(tour.priceList).flatMap((priceGroup) =>
      Object.values(priceGroup),
    )
  : [];
const cabinPrices = tour.cabins
  ? tour.cabins.flatMap((cabin) =>
      Object.values(cabin.prices ?? {}).flatMap(parsePriceNumbers),
    )
  : [];
const prices = [...priceListPrices, ...cabinPrices].filter(
  (price) => price > 0,
);
const startingPrice = prices.length > 0 ? Math.min(...prices) : undefined;
const formattedStartingPrice = startingPrice
  ? new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(startingPrice)
  : undefined;
---

<Card
  class="group h-fit overflow-hidden py-0 transition-shadow duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.12)]"
>
  <!-- Image -->
  <div class="relative overflow-hidden">
    <OptimizedImage
      src={tour.images[0]}
      alt={tour.title}
      class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading={loading}
      fetchpriority={fetchpriority}
      widths={[320, 480, 640, 800]}
      sizes="(min-width: 1280px) 33vw, (min-width: 768px) 50vw, 100vw"
      quality={68}
    />

    <!-- Region badge -->
    <div class="absolute left-3 top-3">
      <Badge class:list={[region.className, "shadow-sm"]}>
        {region.label}
      </Badge>
    </div>

    <!-- Price on image -->
    {
      startingPrice && (
        <div class="absolute bottom-3 right-3">
          <div class="rounded-lg bg-white/95 px-3 py-1.5 shadow-sm backdrop-blur-sm">
            <span class="text-xs text-text-muted">
              {uiStrings.paketWisata.startingFrom}
            </span>
            <div class="whitespace-nowrap text-lg font-bold tracking-tight text-brand-700">
              {formattedStartingPrice}
            </div>
          </div>
        </div>
      )
    }
  </div>

  <!-- Content -->
  <CardContent class="flex h-full flex-col gap-3 p-5">
    <div class="flex flex-wrap items-center gap-2">
      <Badge
        variant="outline"
        class="rounded-full px-3 py-1 text-xs font-medium"
      >
        {tour.duration}
      </Badge>
      <Badge
        variant="secondary"
        class="rounded-full px-3 py-1 text-xs font-medium"
      >
        {tour.collectionTitle}
      </Badge>
    </div>

    <div>
      <TypographyH3
        class="text-lg leading-snug text-foreground group-hover:text-brand-600 transition-colors"
      >
        {tour.title}
      </TypographyH3>
      <p
        class="mt-2 font-sans text-sm leading-relaxed text-text-muted line-clamp-2"
      >
        {tour.summary}
      </p>
    </div>

    <ul class="space-y-1.5 text-sm font-sans">
      {
        tour.highlights.slice(0, 3).map((item) => (
          <li class="flex items-center gap-2 text-text-muted">
            <HugeiconsIcon
              icon={Tick02Icon}
              size={14}
              className="shrink-0 text-brand-500"
            />
            <span class="line-clamp-1">{item}</span>
          </li>
        ))
      }
      {
        tour.highlights.length > 3 && (
          <li class="text-xs text-text-muted">
            {moreCountLabel.replace("{n}", String(tour.highlights.length - 3))}
          </li>
        )
      }
    </ul>

    <div class="mt-auto pt-2">
      <a href={cardHref}>
        <Button
          size="lg"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white"
        >
          {viewPackageDetailLabel}
        </Button>
      </a>
    </div>
  </CardContent>
</Card>

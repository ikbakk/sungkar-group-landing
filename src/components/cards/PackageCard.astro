---
import { TypographyH3 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { REGION_MAP } from "@/lib/regions";
import { localizeHref } from "@/lib/i18n/localize";
import { Button } from "@/components/ui/button";

interface Props {
  tour: TourPackage;
  locale?: string;
  moreCountLabel: string;
  viewPackageDetailLabel: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  tour,
  locale = "id",
  moreCountLabel,
  viewPackageDetailLabel,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const region = REGION_MAP[tour.region];

const cardHref = localizeHref(
  `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`,
  locale,
);

// Determine tier from collection slug
const tier = tour.collectionSlug?.includes("luxury")
  ? "luxury"
  : tour.collectionSlug?.includes("deluxe")
    ? "premium"
    : "standard";
---

<Card
  class="group h-fit overflow-hidden py-0 transition-shadow duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.12)]"
>
  <!-- Image -->
  <div class="relative overflow-hidden">
    <OptimizedImage
      src={tour.images[0]}
      alt={tour.title}
      class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading={loading}
      fetchpriority={fetchpriority}
      widths={[320, 480, 640, 800]}
      sizes="(min-width: 1280px) 33vw, (min-width: 768px) 50vw, 100vw"
      quality={68}
    />

    <!-- Region badge -->
    <div class="absolute left-3 top-3">
      <Badge class:list={[region.className, "shadow-sm"]}>
        {region.label}
      </Badge>
    </div>

    <!-- Rating badge -->
    {
      tour.rating && (
        <div class="absolute right-3 top-3 flex items-center gap-1 rounded-full bg-white/95 px-2.5 py-1 text-xs font-semibold shadow-sm backdrop-blur-sm">
          <svg
            class="h-3.5 w-3.5 text-warm-500"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span>{tour.rating}</span>
        </div>
      )
    }

    <!-- Price on image -->
    {
      tour.price && (
        <div class="absolute bottom-3 right-3">
          <div class="rounded-lg bg-white/95 px-3 py-1.5 shadow-sm backdrop-blur-sm">
            <span class="text-xs text-text-muted">Mulai dari</span>
            <div class="flex items-baseline gap-0.5">
              <span class="text-[10px] text-text-muted">Rp</span>
              <span
                class:list={[
                  "text-lg font-bold tracking-tight",
                  tier === "premium"
                    ? "text-warm-600"
                    : tier === "luxury"
                      ? "text-brand-600"
                      : "text-foreground",
                ]}
              >
                {new Intl.NumberFormat("id-ID").format(tour.price)}
              </span>
            </div>
          </div>
        </div>
      )
    }
  </div>

  <!-- Content -->
  <CardContent class="flex h-full flex-col gap-3 p-5">
    <div class="flex flex-wrap items-center gap-2">
      <Badge
        variant="outline"
        class="rounded-full px-3 py-1 text-xs font-medium"
      >
        {tour.duration}
      </Badge>
      <Badge
        variant="secondary"
        class="rounded-full px-3 py-1 text-xs font-medium"
      >
        {tour.collectionTitle}
      </Badge>
    </div>

    <div>
      <TypographyH3
        class="text-lg leading-snug text-foreground group-hover:text-brand-600 transition-colors"
      >
        {tour.title}
      </TypographyH3>
      <p
        class="mt-2 font-sans text-sm leading-relaxed text-text-muted line-clamp-2"
      >
        {tour.summary}
      </p>
    </div>

    <ul class="space-y-1.5 text-sm font-sans">
      {
        tour.highlights.slice(0, 3).map((item) => (
          <li class="flex items-center gap-2 text-text-muted">
            <HugeiconsIcon
              icon={Tick02Icon}
              size={14}
              className="shrink-0 text-brand-500"
            />
            <span class="line-clamp-1">{item}</span>
          </li>
        ))
      }
      {
        tour.highlights.length > 3 && (
          <li class="text-xs text-text-muted">
            {moreCountLabel.replace("{n}", String(tour.highlights.length - 3))}
          </li>
        )
      }
    </ul>

    <div class="mt-auto pt-2">
      <a href={cardHref}>
        <Button
          size="lg"
          class="w-full bg-brand-600 hover:bg-brand-700 text-white"
        >
          {viewPackageDetailLabel}
        </Button>
      </a>
    </div>
  </CardContent>
</Card>

---
import { TypographyH3 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";
import type { TourPackage } from "@/lib/content/tourPackages/types";
import { REGION_MAP } from "@/lib/regions";
import { localizeHref } from "@/lib/i18n/localize";
import { t } from "@/lib/i18n";
import { Button } from "@/components/ui/button";

interface Props {
  tour: TourPackage;
  locale?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  tour,
  locale = "id",
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;
const uiStrings = t(locale);

const region = REGION_MAP[tour.region];

const cardHref = localizeHref(
  `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`,
  locale,
);
---

<Card class="group
      h-fit
      overflow-hidden
      py-0">
  <!-- Image -->

  <div class="relative overflow-hidden">
    <OptimizedImage
      src={tour.images[0]}
      alt={tour.title}
      class="aspect-4/3
          w-full
          object-cover
          transition-transform
          duration-700
          ease-out
          group-hover:scale-105"
      loading={loading}
      fetchpriority={fetchpriority}
      widths={[320, 480, 640, 800]}
      sizes="(min-width: 1280px) 33vw, (min-width: 768px) 50vw, 100vw"
      quality={68}
    />

    <div class="absolute left-4 top-4 font-sans">
      <Badge class={region.className}>
        {region.label}
      </Badge>
    </div>
  </div>

  <!-- Content -->

  <CardContent class="flex h-full flex-col gap-4 p-6">
    <div class="flex flex-wrap items-center gap-2">
      <Badge
        variant="outline"
        class="rounded-full
            px-3
            py-1
            text-xs
            font-medium"
      >
        {tour.duration}
      </Badge>

      <Badge
        variant="secondary"
        class="rounded-full
            px-3
            py-1
            text-xs
            font-medium"
      >
        {tour.collectionTitle}
      </Badge>
    </div>

    <div>
      <TypographyH3
        class="text-xl
            
            leading-tight
            text-foreground"
      >
        {tour.title}
      </TypographyH3>

      <p
        class="mt-3
            font-sans
            line-clamp-2
            text-sm
            leading-7
            text-text-muted"
      >
        {tour.summary}
      </p>
    </div>

    <ul class="space-y-2 text-sm font-sans">
      {
        tour.highlights.slice(0, 3).map((item) => (
          <li
            class="
                flex
                items-center
                gap-2
                text-text-muted
              "
          >
            <HugeiconsIcon
              icon={Tick02Icon}
              size={16}
              className="shrink-0 text-brand-700"
            />

            <span>{item}</span>
          </li>
        ))
      }
      {
        tour.highlights.length > 3 && (
          <li class="text-sm text-text-muted font-sans">
            {uiStrings.common.moreCount.replace(
              "{n}",
              String(tour.highlights.length - 3),
            )}
          </li>
        )
      }
    </ul>

    <div class="mt-auto pt-2">
      <a href={cardHref}>
        <Button size="lg" class="w-full"
          >{uiStrings.paketWisata.viewPackageDetail}</Button
        >
      </a>
    </div>
  </CardContent>
</Card>

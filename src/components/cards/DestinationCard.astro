---
import { TypographyH3 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { Card, CardContent } from "@/components/ui/card";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";
import { Badge } from "@/components/ui/badge";
import type { Destination } from "@/lib/content/destinations";
import { localizeHref } from "@/lib/i18n/localize";
import { Button } from "@/components/ui/button";

interface Props {
  destination: Destination;
  locale?: string;
  moreCountLabel: string;
  viewDetailLabel: string;
}

const { destination, locale = "id", moreCountLabel, viewDetailLabel } =
  Astro.props;

const highlightCount = Math.max(destination.thingsToDo.length - 3, 0);

const cardHref = localizeHref("/destinasi/" + destination.slug, locale);
---

<a href={cardHref} class="block">
  <Card class="group h-fit overflow-hidden py-0 card-interactive">
    <div class="relative overflow-hidden">
      <OptimizedImage
        src={destination.image}
        alt={destination.title}
        class="aspect-4/3 w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        loading="lazy"
      />

      <div class="absolute left-4 top-4">
        <Badge variant="outline" class="rounded-full bg-white/90 px-3 py-1">
          {destination.region}
        </Badge>
      </div>
    </div>

    <CardContent class="flex h-full flex-col gap-4 p-6">
      <div>
        <TypographyH3 class="text-xl leading-tight text-foreground">
          {destination.title}
        </TypographyH3>

        <p
          class="mt-3 line-clamp-2 text-sm leading-7 text-text-muted font-sans"
        >
          {destination.summary}
        </p>
      </div>

      <ul class="space-y-2 text-sm font-sans">
        {
          destination.thingsToDo.slice(0, 3).map((item) => (
            <li class="flex items-center gap-2 text-text-muted">
              <HugeiconsIcon
                icon={Tick02Icon}
                size={16}
                className="shrink-0 text-brand-700"
              />
              <span>{item}</span>
            </li>
          ))
        }
        {
          highlightCount > 0 && (
            <li class="text-sm text-text-muted font-sans">
              {moreCountLabel.replace(
                "{n}",
                String(highlightCount),
              )}
            </li>
          )
        }
      </ul>

      <div class="mt-auto pt-2">
        <Button size="lg" class="w-full">{viewDetailLabel}</Button>
      </div>
    </CardContent>
  </Card>
</a>

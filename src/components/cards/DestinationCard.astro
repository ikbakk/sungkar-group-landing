---
import { Image } from "astro:assets";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import type { Destination } from "@/lib/content/destinationsData";

const { destination } = Astro.props as {
  destination: Destination;
};

const highlightCount = Math.max(destination.thingsToDo.length - 3, 0);
---

<Card className="group h-fit overflow-hidden py-0 card-interactive">
  <div class="relative overflow-hidden">
    <Image
      src={destination.image}
      alt={destination.title}
      class="aspect-4/3 w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />

    <div class="absolute left-4 top-4">
      <Badge variant="outline" className="rounded-full bg-white/90 px-3 py-1">
        {destination.region}
      </Badge>
    </div>
  </div>

  <CardContent className="flex h-full flex-col gap-4 p-6">
    <div>
      <h3 class="font-heading text-xl leading-tight text-foreground">
        {destination.title}
      </h3>

      <p class="mt-3 line-clamp-2 text-sm leading-7 text-text-muted font-sans">
        {destination.summary}
      </p>
    </div>

    <ul class="space-y-2 text-sm font-sans">
      {destination.thingsToDo.slice(0, 3).map((item) => (
        <li class="flex items-center gap-2 text-text-muted">
          <span class="font-semibold text-brand-700">✓</span>
          <span>{item}</span>
        </li>
      ))}
      {highlightCount > 0 && (
        <li class="text-sm text-text-muted font-sans">
          + {highlightCount} lainnya
        </li>
      )}
    </ul>

    <div class="mt-auto pt-2">
      <a href={`/destinasi/${destination.slug}`}>
        <Button
          className="group/button w-full font-sans"
          size={"lg"}
        >
          <span>Lihat Detail</span>
        </Button>
      </a>
    </div>
  </CardContent>
</Card>

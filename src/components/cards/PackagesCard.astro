---
import { Image } from "astro:assets";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import type { TourPackage } from "@/lib/content/tourPackages";

const { tour } = Astro.props as {
  tour: TourPackage;
};

const regionMap = {
  lombok: {
    label: "Lombok",
    className: "bg-brand-700 text-white border-brand-700",
  },
  sumbawa: {
    label: "Sumbawa",
    className: "bg-emerald-600 text-white border-emerald-600",
  },
  "labuan-bajo": {
    label: "Labuan Bajo",
    className: "bg-violet-600 text-white border-violet-600",
  },
};

const region = regionMap[tour.region];
---

<Card
  className="
    group
    h-fit
    overflow-hidden
    border-border
    bg-white
    py-0
    transition-all
    duration-300
    ease-out
    hover:-translate-y-2
    hover:shadow-[0_24px_48px_rgba(17,24,39,0.12)]
  "
>
  <!-- Image -->

  <div class="relative overflow-hidden">
    <Image
      src={tour.image}
      alt={tour.title}
      class="aspect-4/3
        w-full
        object-cover
        transition-transform
        duration-700
        ease-out
        group-hover:scale-105"
      loading="lazy"
    />

    <div class="absolute left-4 top-4">
      <Badge className={region.className}>
        {region.label}
      </Badge>
    </div>
  </div>

  <!-- Content -->

  <CardContent className="flex h-full flex-col gap-4 p-6">
    <div class="flex flex-wrap items-center gap-2">
      <Badge
        variant="outline"
        className="
          rounded-full
          px-3
          py-1
          text-xs
          font-medium
        "
      >
        {tour.duration}
      </Badge>
    </div>

    <div>
      <h3
        class="text-xl
          font-semibold
          leading-tight
          text-foreground"
      >
        {tour.title}
      </h3>

      <p
        class="mt-3
          line-clamp-2
          text-sm
          leading-7
          text-text-muted"
      >
        {tour.summary}
      </p>
    </div>

    <ul class="space-y-2 text-sm">
      {
        tour.highlights.slice(0, 3).map((item) => (
          <li
            class="
              flex
              items-center
              gap-2
              text-text-muted
            "
          >
            <span class="font-semibold text-brand-700">✓</span>

            <span>{item}</span>
          </li>
        ))
      }
      {
        tour.highlights.length > 3 && (
          <li class="text-sm text-text-muted">
            +{tour.highlights.length - 3} lainnya
          </li>
        )
      }
    </ul>

    <div class="mt-auto pt-2">
      <a href={`/paket-wisata/${tour.slug}`}>
        <Button
          className="
          group/button
          w-full
        "
          size={"lg"}
        >
          <span>Cek Detail Paket</span>
        </Button>
      </a>
    </div>
  </CardContent>
</Card>

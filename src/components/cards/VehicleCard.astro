---
import type { Vehicle } from "@/lib/content/sewaModilData";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardFooter,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Image } from "astro:assets";

interface Props {
  vehicle: Vehicle;
}

const { vehicle } = Astro.props;

const cardHref = "/kontak";
---

<a href={cardHref} class="block">
  <Card className="overflow-hidden card-interactive">
    <div class="relative h-64 w-full overflow-hidden">
      <Image
        src={vehicle.image}
        alt={vehicle.name}
        class="h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <CardHeader>
      <div class="flex items-start justify-between gap-4">
        <CardTitle className="text-2xl leading-tight">
          {vehicle.name}
        </CardTitle>
        <Badge variant="default" className="rounded-full px-3 py-1 text-sm">
          {vehicle.seats} Seat
        </Badge>
      </div>
    </CardHeader>

    <CardContent className="space-y-4">
      <div>
        <div
          class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700"
        >
          Spesifikasi
        </div>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div class="rounded border border-border p-2 text-center">
            <div class="text-xs text-text-muted">Transmisi</div>
            <div class="font-medium">{vehicle.transmission}</div>
          </div>
          <div class="rounded border border-border p-2 text-center">
            <div class="text-xs text-text-muted">Penumpang</div>
            <div class="font-medium">{vehicle.seats}</div>
          </div>
        </div>
      </div>

      <div>
        <div
          class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700"
        >
          Fitur Unggulan
        </div>
        <div class="flex flex-wrap gap-2">
          {
            vehicle.features.map((feature) => (
              <Badge variant="outline" className="rounded-full px-3 py-1 text-xs">
                {feature}
              </Badge>
            ))
          }
        </div>
      </div>

      <div>
        <div
          class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700"
        >
          Cocok Untuk
        </div>
        <ul class="space-y-1 text-sm leading-7 text-text-muted">
          {
            vehicle.bestFor.map((use) => (
              <li class="flex gap-2">
                <span>•</span>
                <span>{use}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <p class="border-t border-border pt-4 text-sm leading-7 text-text-muted">
        {vehicle.description}
      </p>
    </CardContent>

    <CardFooter>
      <span class="flex-1 inline-flex items-center justify-center rounded-md bg-brand-700 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-700 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 lg:px-8 lg:py-3.5 lg:text-lg">
        Pesan Sekarang
      </span>
    </CardFooter>
  </Card>
</a>

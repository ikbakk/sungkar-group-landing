---
import type { Vehicle } from "@/lib/content/shared/types";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardFooter,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { localizeHref } from "@/lib/i18n/localize";
import { Button } from "@/components/ui/button";

interface Props {
  vehicle: Vehicle;
  locale?: string;
  passengersLabel: string;
  specificationsLabel: string;
  transmissionLabel: string;
  featuresLabel: string;
  suitableForLabel: string;
  viewDetailRentLabel: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  vehicle,
  locale = "id",
  passengersLabel,
  specificationsLabel,
  transmissionLabel,
  featuresLabel,
  suitableForLabel,
  viewDetailRentLabel,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const cardHref = localizeHref(
  `/sewa-mobil/${vehicle.region}/${vehicle.slug}`,
  locale,
);
---

<Card class="overflow-hidden">
  <div class="relative h-64 w-full overflow-hidden">
    <OptimizedImage
      src={vehicle.imageTop}
      alt={vehicle.name}
      class="h-full w-full object-cover"
      loading={loading}
      fetchpriority={fetchpriority}
      widths={[320, 480, 640, 800]}
      sizes="(min-width: 768px) 50vw, 100vw"
      quality={68}
    />
  </div>

  <CardHeader>
    <div class="flex items-start justify-between gap-4">
      <CardTitle class="text-2xl leading-tight">
        {vehicle.name}
      </CardTitle>
      <Badge variant="default" class="rounded-full px-3 py-1 text-sm">
        {vehicle.seats}
        {passengersLabel}
      </Badge>
    </div>
  </CardHeader>

  <CardContent class="space-y-4">
    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {specificationsLabel}
      </div>
      <div class="grid grid-cols-2 gap-2 text-sm">
        <div class="rounded border border-border p-2 text-center">
          <div class="text-xs text-text-muted">
            {transmissionLabel}
          </div>
          <div class="font-medium">{vehicle.transmission}</div>
        </div>
        <div class="rounded border border-border p-2 text-center">
          <div class="text-xs text-text-muted">
            {passengersLabel}
          </div>
          <div class="font-medium">{vehicle.seats}</div>
        </div>
      </div>
    </div>

    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {featuresLabel}
      </div>
      <div class="flex flex-wrap gap-2">
        {
          vehicle.features.map((feature) => (
            <Badge variant="outline" class="rounded-full px-3 py-1 text-xs">
              {feature}
            </Badge>
          ))
        }
      </div>
    </div>

    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {suitableForLabel}
      </div>
      <ul class="space-y-1 text-sm leading-7 text-text-muted">
        {
          vehicle.bestFor.map((use) => (
            <li class="flex gap-2">
              <span>•</span>
              <span>{use}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="border-t border-border pt-4 text-sm leading-7 text-text-muted">
      {vehicle.description}
    </p>
  </CardContent>

  <CardFooter>
    <a href={cardHref}>
      <Button size="lg" class="w-full">{viewDetailRentLabel}</Button>
    </a>
  </CardFooter>
</Card>

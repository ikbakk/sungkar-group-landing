---
import type { Vehicle } from "@/lib/content/shared/types";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardFooter,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { localizeHref } from "@/lib/i18n/localize";
import { t } from "@/lib/i18n";
import { Button } from "@/components/ui/button";

interface Props {
  vehicle: Vehicle;
  locale?: string;
}

const { vehicle, locale = "id" } = Astro.props;
const uiStrings = t(locale);

const cardHref = localizeHref(
  `/sewa-mobil/${vehicle.region}/${vehicle.slug}`,
  locale,
);
---

<Card class="overflow-hidden">
  <div class="relative h-64 w-full overflow-hidden">
    <OptimizedImage
      src={vehicle.imageTop}
      alt={vehicle.name}
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <CardHeader>
    <div class="flex items-start justify-between gap-4">
      <CardTitle class="text-2xl leading-tight">
        {vehicle.name}
      </CardTitle>
      <Badge variant="default" class="rounded-full px-3 py-1 text-sm">
        {vehicle.seats} Seat
      </Badge>
    </div>
  </CardHeader>

  <CardContent class="space-y-4">
    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {uiStrings.sewaMobil.specifications}
      </div>
      <div class="grid grid-cols-2 gap-2 text-sm">
        <div class="rounded border border-border p-2 text-center">
          <div class="text-xs text-text-muted">
            {uiStrings.sewaMobil.transmission}
          </div>
          <div class="font-medium">{vehicle.transmission}</div>
        </div>
        <div class="rounded border border-border p-2 text-center">
          <div class="text-xs text-text-muted">
            {uiStrings.sewaMobil.passengers}
          </div>
          <div class="font-medium">{vehicle.seats}</div>
        </div>
      </div>
    </div>

    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {uiStrings.sewaMobil.features}
      </div>
      <div class="flex flex-wrap gap-2">
        {
          vehicle.features.map((feature) => (
            <Badge variant="outline" class="rounded-full px-3 py-1 text-xs">
              {feature}
            </Badge>
          ))
        }
      </div>
    </div>

    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {uiStrings.sewaMobil.suitableFor}
      </div>
      <ul class="space-y-1 text-sm leading-7 text-text-muted">
        {
          vehicle.bestFor.map((use) => (
            <li class="flex gap-2">
              <span>•</span>
              <span>{use}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="border-t border-border pt-4 text-sm leading-7 text-text-muted">
      {vehicle.description}
    </p>
  </CardContent>

  <CardFooter>
    <a href={cardHref}>
      <Button size="lg" class="w-full"
        >{uiStrings.sewaMobil.viewDetailRent}</Button
      >
    </a>
  </CardFooter>
</Card>

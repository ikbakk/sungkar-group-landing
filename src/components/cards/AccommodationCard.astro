---
import { TypographyH3 } from "@/components/ui/typography";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";

import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";
import type { Accommodation } from "@/lib/content/shared/types";
import { REGION_MAP } from "@/lib/regions";

interface Props {
  accommodation: Accommodation;
  featuresLabel: string;
  morePerksLabel: string;
  loading?: "lazy" | "eager";
}

const {
  accommodation,
  featuresLabel,
  morePerksLabel,
  loading = "lazy",
} = Astro.props;

const region = REGION_MAP[accommodation.region];
---

<Card class="group
      h-fit
      overflow-hidden
      py-0">
  <!-- Image -->

  <div class="relative overflow-hidden">
    <OptimizedImage
      src={accommodation.image}
      alt={accommodation.name}
      class="aspect-4/3
          w-full
          object-cover
          transition-transform
          duration-700
          ease-out
          group-hover:scale-105"
      loading={loading}
    />

    <div class="absolute left-4 top-4 font-sans">
      <Badge class={region.className}>
        {region.label}
      </Badge>
    </div>
  </div>

  <!-- Content -->

  <CardContent class="flex h-full flex-col gap-4 p-6">
    <div class="flex flex-wrap items-center gap-2">
      <TypographyH3
        class="text-lg
            leading-tight
            text-foreground"
      >
        {accommodation.name}
      </TypographyH3>
    </div>

    <p
      class="font-sans
          text-sm
          leading-7
          text-text-muted"
    >
      {accommodation.description}
    </p>

    <div>
      <div
        class="mb-2 text-xs font-medium uppercase tracking-[0.28em] text-brand-700"
      >
        {featuresLabel}
      </div>
      <ul class="space-y-1 text-sm font-sans">
        {
          accommodation.perks.slice(0, 3).map((perk) => (
            <li
              class="
                  flex
                  items-center
                  gap-2
                  text-text-muted
                "
            >
              <HugeiconsIcon
                icon={Tick02Icon}
                size={16}
                className="shrink-0 text-brand-700"
              />

              <span>{perk}</span>
            </li>
          ))
        }
        {
          accommodation.perks.length > 3 && (
            <li class="text-sm text-text-muted font-sans">
              {morePerksLabel.replace(
                "{n}",
                String(accommodation.perks.length - 3),
              )}
            </li>
          )
        }
      </ul>
    </div>
  </CardContent>
</Card>

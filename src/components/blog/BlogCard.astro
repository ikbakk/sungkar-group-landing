---
import { TypographyH3 } from "@/components/ui/typography";
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import type { BlogPostMeta } from "@/lib/content/blog";
import { localizeHref } from "@/lib/i18n/localize";

interface Props {
  post: BlogPostMeta;
  locale?: string;
  readingTimeLabel: string;
}

const { post, locale = "id", readingTimeLabel } = Astro.props;
const href = localizeHref("/blog/" + post.slug, locale);
---

<a href={href} class="block group">
  <Card
    class="h-fit overflow-hidden py-0 transition-all duration-300 ease-out group-hover:-translate-y-1 group-hover:shadow-[0_20px_40px_rgba(17,24,39,0.1)]"
  >
    <CardContent class="flex h-full flex-col gap-4 p-6">
      <div class="flex flex-wrap items-center gap-2">
        <Badge
          variant="outline"
          class="rounded-full px-3 py-1 text-xs font-medium"
        >
          {post.readingTime}
          {readingTimeLabel}
        </Badge>
        {
          post.tags.slice(0, 2).map((tag) => (
            <Badge variant="secondary" class="rounded-full px-3 py-1 text-xs">
              {tag}
            </Badge>
          ))
        }
      </div>

      <div>
        <TypographyH3
          class="text-xl leading-tight text-foreground group-hover:text-brand-600 transition-colors"
        >
          {post.title}
        </TypographyH3>
        <p
          class="mt-3 line-clamp-2 font-sans text-sm leading-7 text-text-muted"
        >
          {post.description}
        </p>
      </div>

      <div class="mt-auto text-xs text-text-muted">
        <time datetime={post.publishDate.toISOString()}>
          {
            post.publishDate.toLocaleDateString(
              locale === "id" ? "id-ID" : locale,
              {
                day: "numeric",
                month: "long",
                year: "numeric",
              },
            )
          }
        </time>
      </div>
    </CardContent>
  </Card>
</a>

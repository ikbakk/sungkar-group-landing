---
import { TypographyH2 } from "@/components/ui/typography";
import { HugeiconsIcon } from "@hugeicons/react";
import { Tick02Icon } from "@hugeicons/core-free-icons";

interface Props {
  takeaways: string[];
  title: string;
  description: string;
}

const { takeaways, title, description } = Astro.props;
---

<div class="mx-auto max-w-4xl">
  <TypographyH2 class="text-3xl leading-tight text-foreground">
    {title}
  </TypographyH2>
  <p class="mt-2 text-base leading-7 text-text-muted">
    {description}
  </p>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    {
      takeaways.map((takeaway) => (
        <div class="flex items-start gap-4 rounded-[1.25rem] border border-border bg-white p-5">
          <HugeiconsIcon
            icon={Tick02Icon}
            size={16}
            className="shrink-0 text-brand-700"
          />
          <span class="text-sm leading-6 text-foreground">{takeaway}</span>
        </div>
      ))
    }
  </div>
</div>

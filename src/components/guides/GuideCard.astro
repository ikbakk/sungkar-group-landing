---
import { REGION_LABEL, REGION_MAP } from "@/lib/regions";
import type { Guide } from "@/lib/content/guides";

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
const regionInfo = REGION_MAP[guide.region as keyof typeof REGION_MAP];
const regionLabel = guide.region === "general" ? "Umum" : (REGION_LABEL[guide.region as keyof typeof REGION_LABEL] ?? "Umum");
---

<article class="group relative flex flex-col rounded-[1.75rem] border border-border bg-white transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(17,24,39,0.1)]">
  <div class="flex flex-1 flex-col p-6 sm:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium tracking-wide"
        style="border-color: var(--color-brand-200); color: var(--color-brand-700); background-color: var(--color-brand-50);">
        {guide.readingTime} menit baca
      </span>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium tracking-wide"
        class:list={[regionInfo?.className ?? "bg-gray-100 text-gray-700 border-gray-200"]}>
        {regionLabel}
      </span>
    </div>

    <h3 class="font-heading text-xl leading-snug text-foreground group-hover:text-brand-600 transition-colors">
      <a href={`/panduan-wisata/${guide.slug}`} class="after:absolute after:inset-0">
        {guide.title}
      </a>
    </h3>

    <p class="mt-3 text-sm leading-6 text-text-muted font-sans">
      {guide.description}
    </p>

    <div class="mt-auto flex flex-wrap gap-2 pt-6">
      {guide.bestFor.slice(0, 3).map((item) => (
        <span class="inline-flex items-center rounded-full border border-border bg-surface-soft px-3 py-1 text-xs text-text-muted">
          {item}
        </span>
      ))}
    </div>
  </div>
</article>

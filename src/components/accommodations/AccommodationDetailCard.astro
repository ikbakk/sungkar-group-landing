---
import { Image } from "astro:assets";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
import type { Accommodation } from "@/lib/content/akomodasiData";

interface Props {
  accommodation: Accommodation;
}

const { accommodation } = Astro.props;
---

<Card className="border-border overflow-hidden bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)] transition-all duration-300 hover:shadow-[0_18px_55px_rgba(17,24,39,0.1)]">
  <div class="relative h-64 w-full overflow-hidden rounded-t-lg">
    <Image
      src={accommodation.image}
      alt={accommodation.name}
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <CardHeader>
    <CardTitle className="text-2xl leading-tight">
      {accommodation.name}
    </CardTitle>
  </CardHeader>

  <CardContent className="space-y-4">
    <p class="text-sm leading-7 text-text-muted">
      {accommodation.description}
    </p>

    <div>
      <div class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700">
        Fasilitas & Layanan
      </div>
      <div class="flex flex-wrap gap-2">
        {accommodation.perks.map((perk) => (
          <Badge variant="outline" className="rounded-full px-3 py-1">
            {perk}
          </Badge>
        ))}
      </div>
    </div>

    <Separator />

    <div>
      <div class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-700">
        Keunggulan Lokasi
      </div>
      <ul class="space-y-1 text-sm leading-7 text-text-muted">
        {accommodation.regionalHighlights.map((highlight) => (
          <li class="flex gap-2">
            <span>✓</span>
            <span>{highlight}</span>
          </li>
        ))}
      </ul>
    </div>
  </CardContent>
</Card>

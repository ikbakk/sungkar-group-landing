---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { cn } from "@/lib/utils";
import { t } from "@/lib/i18n";
import FormField from "./FormField.astro";
import type {
  FormField as FormFieldType,
  FormContext,
} from "@/lib/contact-data";
import { businessInfo } from "@/lib/contact-data";

interface Props {
  context: FormContext;
  fields: FormFieldType[];
  mode: "sidebar" | "section";
  itemName?: string;
  region?: string;
  locale?: string;
}

const { context, fields, mode, itemName, region, locale = "id" } = Astro.props;
const uiStrings = t(locale);

const whatsappNumber = businessInfo.whatsapp.replace(/\D/g, "");
const formId = `whatsapp-form-${context}-${Math.random().toString(36).slice(2, 8)}`;

const contextLabel =
  context === "sewa-mobil"
    ? uiStrings.contact.contextLabelSewa
    : uiStrings.contact.contextLabelPaket;

const isSidebar = mode === "sidebar";

const cardClass = isSidebar
  ? "border-border bg-brand-900 text-white shadow-[0_16px_45px_rgba(17,24,39,0.1)]"
  : "border-border bg-white";

const titleText =
  context === "sewa-mobil"
    ? isSidebar
      ? uiStrings.contact.sidebarTitleSewa
      : uiStrings.contact.sectionTitleSewa
    : isSidebar
      ? uiStrings.contact.sidebarTitlePaket
      : uiStrings.contact.sectionTitlePaket;

const descClass = isSidebar
  ? "text-sm leading-7 text-brand-100"
  : "text-sm leading-7 text-text-muted";
const formClass = isSidebar ? "grid gap-4" : "grid gap-4 md:grid-cols-2";
const btnClass = isSidebar
  ? "inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground text-sm px-8 h-11 font-medium whitespace-nowrap transition-all hover:bg-[color-mix(in_oklch,var(--secondary),var(--foreground)_5%)]"
  : "inline-flex items-center justify-center rounded-md bg-brand-900 text-white text-sm px-8 h-11 font-medium whitespace-nowrap transition-all hover:bg-brand-800";

const messageConfig = {
  greeting: uiStrings.contact.whatsappGreeting,
  sewaIntro: uiStrings.contact.whatsappSewaIntro,
  paketIntro: uiStrings.contact.whatsappPaketIntro,
  location: uiStrings.contact.whatsappLocation,
  followUp: uiStrings.contact.whatsappFollowUp,
  labels: {
    name: uiStrings.contact.formFieldName,
    travelDate:
      context === "sewa-mobil"
        ? uiStrings.contact.formFieldTravelDateSewa
        : uiStrings.contact.formFieldTravelDate,
    duration: uiStrings.contact.formFieldDuration,
    guests: uiStrings.contact.formFieldGuests,
    passengers: uiStrings.contact.formFieldPassengers,
    rentalReason: uiStrings.contact.formFieldRentalReason,
    message: uiStrings.contact.formFieldMessage,
  },
};
---

<Card class={cardClass}>
  <CardHeader>
    <CardTitle class={cn("text-3xl leading-tight", isSidebar && "text-white")}>
      {titleText}
    </CardTitle>
    {!isSidebar && <p class={descClass}>{uiStrings.contact.formDesc}</p>}
  </CardHeader>

  <CardContent>
    {
      isSidebar && (
        <p class="mb-6 text-sm leading-7 text-brand-100">
          {uiStrings.contact.formDescSidebar}
        </p>
      )
    }

    <form id={formId} class={formClass}>
      {
        itemName && (
          <label class="grid gap-2">
            <span class={isSidebar ? "form-label-light" : "form-label"}>
              {contextLabel}
            </span>
            <input
              type="text"
              value={itemName}
              disabled
              class={
                isSidebar
                  ? "form-input-dark w-full rounded-lg opacity-70 cursor-not-allowed"
                  : "form-input w-full rounded-lg opacity-60 cursor-not-allowed"
              }
            />
          </label>
        )
      }

      {
        region && (
          <label class="grid gap-2">
            <span class={isSidebar ? "form-label-light" : "form-label"}>
              {uiStrings.contact.chooseLocation}
            </span>
            <input
              type="text"
              value={region}
              disabled
              class={
                isSidebar
                  ? "form-input-dark w-full rounded-lg opacity-70 cursor-not-allowed"
                  : "form-input w-full rounded-lg opacity-60 cursor-not-allowed"
              }
            />
          </label>
        )
      }

      {
        fields.map((field) => (
          <FormField
            field={field}
            mode={mode}
            spanFull={!isSidebar && field.type === "textarea"}
          />
        ))
      }
    </form>
  </CardContent>

  <CardContent class="flex flex-wrap gap-3">
    <button id={"btn-submit-" + formId} type="button" class={btnClass}>
      {uiStrings.common.contactUs}
    </button>
  </CardContent>
</Card>

<script
  is:inline
  define:vars={{
    formId,
    whatsappNumber,
    context,
    itemName,
    region,
    messageConfig,
  }}
>
  // @ts-nocheck
  var form = document.getElementById(formId);
  var submitButton = document.getElementById("btn-submit-" + formId);

  function buildMessage(values) {
    var parts = [messageConfig.greeting];

    if (itemName) {
      parts.push("");
      parts.push(
        (context === "sewa-mobil"
          ? messageConfig.sewaIntro
          : messageConfig.paketIntro
        ).replace("{item}", itemName),
      );
    }

    if (region) {
      parts.push(messageConfig.location.replace("{region}", region));
    }

    parts.push("");

    Object.keys(values).forEach(function (key) {
      if (!values[key]) return;
      parts.push((messageConfig.labels[key] || key) + ": " + values[key]);
    });

    parts.push("");
    parts.push(messageConfig.followUp);

    return parts.join("\n");
  }

  submitButton?.addEventListener("click", function () {
    if (!form || !form.reportValidity()) return;

    var fieldIds = [
      "name",
      "travelDate",
      "duration",
      "passengers",
      "guests",
      "rentalReason",
      "message",
    ];

    var values = {};
    for (var i = 0; i < fieldIds.length; i++) {
      var el = form.querySelector('[name="' + fieldIds[i] + '"]');
      if (el) {
        values[fieldIds[i]] = el.value || "";
      }
    }

    var msg = buildMessage(values);
    var url =
      "https://wa.me/" + whatsappNumber + "?text=" + encodeURIComponent(msg);
    window.open(url, "_blank");
  });
</script>

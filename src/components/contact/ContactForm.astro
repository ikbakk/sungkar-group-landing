---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  NativeSelect,
  NativeSelectOption,
} from "@/components/ui/native-select";
import { t } from "@/lib/i18n";
import type { FormField, BusinessInfo } from "@/lib/contact-data";

interface Props {
  fields: FormField[];
  businessInfo: BusinessInfo;
  title?: string;
  description?: string;
  locale?: string;
  packages: Array<{
    title: string;
    slug: string;
    region: string;
    collectionSlug: string;
    collectionTitle: string;
  }>;
}

const {
  fields,
  businessInfo,
  title,
  description,
  locale = "id",
  packages,
} = Astro.props;
const uiStrings = t(locale);

const whatsappNumber = businessInfo.whatsapp.replace(/\D/g, "");

const packagesData = packages.map((pkg) => ({
  title: pkg.title,
  slug: pkg.slug,
  region: pkg.region,
  collectionSlug: pkg.collectionSlug,
  collectionTitle: pkg.collectionTitle,
}));

const formFields = fields.filter((f) => f.id !== "location");

const regions = Array.from(new Set(packagesData.map((p) => p.region))).map(
  (r) => ({
    key: r,
    label:
      r === "labuan-bajo"
        ? "Labuan Bajo"
        : r.charAt(0).toUpperCase() + r.slice(1),
  }),
);
---

<Card class="border-border bg-brand-900 text-white">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight text-white">
      {title ?? uiStrings.contact.formTitle}
    </CardTitle>

    <p class="text-sm leading-7 text-brand-100">
      {description ?? uiStrings.contact.formDescription}
    </p>
  </CardHeader>

  <CardContent class="grid gap-6">
    <form
      id="availability-form"
      class="grid gap-4"
      method="POST"
      action="https://api.web3forms.com/submit"
    >
      <input
        type="hidden"
        name="access_key"
        value="{import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || ''}"
      />
      <input
        type="hidden"
        name="subject"
        value={uiStrings.contact.formWhatsappSubject}
      />
      <input
        type="checkbox"
        name="botcheck"
        class="hidden"
        style="display:none"
      />
      <div class="grid gap-4 sm:grid-cols-2">
        {
          formFields.map((field) =>
            field.type === "textarea" ? (
              <label class="grid gap-2 sm:col-span-2">
                <span class="form-label-light">
                  {field.label}
                  {!field.required && (
                    <span class="text-xs font-normal text-brand-200">
                      {" "}
                      — {uiStrings.contact.optional}
                    </span>
                  )}
                </span>
                <textarea
                  id={field.id}
                  name={field.id}
                  placeholder={field.placeholder}
                  class="form-input-dark w-full min-h-24 resize-none rounded-lg"
                  required={field.required}
                />
              </label>
            ) : field.type === "select" ? (
              <label class="grid gap-2">
                <span class="form-label-light">
                  {field.label}
                  {!field.required && (
                    <span class="text-xs font-normal text-brand-200">
                      {" "}
                      — {uiStrings.contact.optional}
                    </span>
                  )}
                </span>
                <NativeSelect
                  name={field.id}
                  class="w-full rounded-lg border-white/10 bg-white/5 text-white hover:bg-white/10 [&_select]:text-white [&_select]:placeholder:text-brand-100/50 [&_select]:bg-transparent"
                >
                  <NativeSelectOption value="">
                    {field.placeholder}
                  </NativeSelectOption>
                  {field.options?.map((option) => (
                    <NativeSelectOption value={option}>
                      {option}
                    </NativeSelectOption>
                  ))}
                </NativeSelect>
              </label>
            ) : (
              <label class="grid gap-2">
                <span class="form-label-light">
                  {field.label}
                  {!field.required && (
                    <span class="text-xs font-normal text-brand-200">
                      {" "}
                      — {uiStrings.contact.optional}
                    </span>
                  )}
                </span>
                <input
                  id={field.id}
                  type={field.type}
                  name={field.id}
                  placeholder={field.placeholder}
                  class="form-input-dark w-full rounded-lg"
                  required={field.required}
                />
              </label>
            ),
          )
        }

        <div class="grid gap-4 sm:col-span-2 sm:grid-cols-2">
          <label class="grid gap-2">
            <span class="form-label-light"
              >{uiStrings.contact.chooseLocation}</span
            >
            <NativeSelect
              name="location"
              class="w-full rounded-lg border-white/10 bg-white/5 text-white hover:bg-white/10 [&_select]:text-white [&_select]:placeholder:text-brand-100/50 [&_select]:bg-transparent"
            >
              <NativeSelectOption value=""
                >{uiStrings.contact.chooseLocation}</NativeSelectOption
              >
              {
                regions.map((r) => (
                  <NativeSelectOption value={r.key}>
                    {r.label}
                  </NativeSelectOption>
                ))
              }
            </NativeSelect>
          </label>

          <label class="grid gap-2">
            <span class="form-label-light"
              >{uiStrings.contact.choosePackage}</span
            >
            <NativeSelect
              name="package"
              id="package-select"
              disabled
              class="w-full rounded-lg border-white/10 bg-white/5 text-white hover:bg-white/10 [&_select]:text-white [&_select]:placeholder:text-brand-100/50 [&_select]:bg-transparent"
            >
              <NativeSelectOption value="">
                {uiStrings.contact.selectLocationFirst}
              </NativeSelectOption>
            </NativeSelect>
          </label>
        </div>
      </div>
    </form>

    <div class="">
      <button
        id="contact-whatsapp"
        type="button"
        disabled
        class="inline-flex items-center justify-center rounded-md bg-secondary text-secondary-foreground text-sm px-8 h-11 font-medium whitespace-nowrap transition-all hover:bg-[color-mix(in_oklch,var(--secondary),var(--foreground)_5%)] disabled:opacity-50 disabled:pointer-events-none"
      >
        {uiStrings.common.contactUs}
      </button>
    </div>

    <div class="rounded-lg border border-white/10 bg-white/5 p-4">
      <p class="text-sm leading-6 text-brand-100">
        {uiStrings.contact.formDesc}
      </p>
    </div>
  </CardContent>
</Card>

<script
  is:inline
  define:vars={{
    whatsappNumber,
    packagesData,
    choosePackageLabel: uiStrings.contact.choosePackage,
    selectLocationFirstLabel: uiStrings.contact.selectLocationFirst,
    whatsappGreeting: uiStrings.contact.whatsappGreeting,
    whatsappLocationLabel: uiStrings.contact.whatsappLocation,
    whatsappFormDateLabel: uiStrings.contact.whatsappFormDate,
    whatsappFormGuestsLabel: uiStrings.contact.whatsappFormGuests,
    whatsappFormMessageLabel: uiStrings.contact.whatsappFormMessage,
    whatsappFormPackageLabel: uiStrings.contact.whatsappFormPackage,
    whatsappFollowUp: uiStrings.contact.whatsappFollowUp,
  }}
>
  var locationSelect = document.querySelector('[name="location"]');
  var packageSelect = document.querySelector('[name="package"]');
  var submitBtn = document.getElementById("contact-whatsapp");

  function updateButton() {
    var travelDate = document.getElementById("travelDate")
      ? document.getElementById("travelDate").value
      : "";
    var guests = document.getElementById("guests")
      ? document.getElementById("guests").value
      : "";
    var location = locationSelect ? locationSelect.value : "";
    var pkg = packageSelect ? packageSelect.value : "";

    if (submitBtn) {
      submitBtn.disabled = !(travelDate && guests && location && pkg);
    }
  }

  function updatePackages() {
    var region = locationSelect ? locationSelect.value : "";
    if (!region) {
      packageSelect.innerHTML =
        '<option value="">' + selectLocationFirstLabel + "</option>";
      packageSelect.disabled = true;
      updateButton();
      return;
    }

    var filtered = packagesData.filter(function (p) {
      return p.region === region;
    });

    var groups = {};
    for (var i = 0; i < filtered.length; i++) {
      var p = filtered[i];
      if (!groups[p.collectionSlug]) {
        groups[p.collectionSlug] = {
          title: p.collectionTitle,
          packages: [],
        };
      }
      groups[p.collectionSlug].packages.push(p);
    }

    var html = '<option value="">' + choosePackageLabel + "</option>";
    var groupKeys = Object.keys(groups);
    for (var g = 0; g < groupKeys.length; g++) {
      var group = groups[groupKeys[g]];
      html += '<optgroup label="' + group.title + '">';
      for (var k = 0; k < group.packages.length; k++) {
        var pkg = group.packages[k];
        html +=
          '<option value="' +
          pkg.title.replace(/"/g, "&quot;") +
          '">' +
          pkg.title +
          "</option>";
      }
      html += "</optgroup>";
    }

    packageSelect.innerHTML = html;
    packageSelect.value = "";
    packageSelect.disabled = false;
    updateButton();
  }

  locationSelect.addEventListener("change", updatePackages);
  packageSelect.addEventListener("change", updateButton);

  var travelDateInput = document.getElementById("travelDate");
  var guestsInput = document.getElementById("guests");

  if (travelDateInput) {
    travelDateInput.addEventListener("input", updateButton);
  }
  if (guestsInput) {
    guestsInput.addEventListener("input", updateButton);
  }

  async function submitForm() {
    var form = document.getElementById("availability-form");
    var accessKey = form.querySelector('[name="access_key"]').value;

    // Submit to Web3Forms if access key is configured
    if (accessKey) {
      var formData = new FormData(form);
      try {
        await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
      } catch (e) {
        console.warn("Form backend unreachable, falling back to WhatsApp only");
      }
    }

    // Always open WhatsApp
    openWhatsApp();
  }

  function openWhatsApp() {
    var travelDate = document.getElementById("travelDate")
      ? document.getElementById("travelDate").value
      : "";
    var guests = document.getElementById("guests")
      ? document.getElementById("guests").value
      : "";
    var location = locationSelect ? locationSelect.value : "";
    var packageName = packageSelect ? packageSelect.value : "";
    var message = document.getElementById("message")
      ? document.getElementById("message").value
      : "";

    var lines = [whatsappGreeting, ""];

    if (location) {
      var regionLabels = {
        lombok: "Lombok",
        sumbawa: "Sumbawa",
        "labuan-bajo": "Labuan Bajo",
      };
      lines.push(whatsappLocationLabel.replace("{region}", regionLabels[location] || location));
    }

    if (packageName) {
      lines.push(whatsappFormPackageLabel.replace("{package}", packageName));
    }

    lines.push("");
    lines.push(whatsappFormDateLabel.replace("{date}", travelDate));
    lines.push(whatsappFormGuestsLabel.replace("{guests}", guests));

    if (message) {
      lines.push(whatsappFormMessageLabel.replace("{message}", message));
    }

    lines.push("");
    lines.push(whatsappFollowUp);

    var whatsappMessage = lines.join("\n");
    var url =
      "https://wa.me/" +
      whatsappNumber +
      "?text=" +
      encodeURIComponent(whatsappMessage);
    window.open(url, "_blank");
  }

  submitBtn.addEventListener("click", submitForm);

  updateButton();
</script>

---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import type { FormField, BusinessInfo } from "@/lib/contact-data";

interface Props {
  fields: FormField[];
  businessInfo: BusinessInfo;
  title?: string;
  description?: string;
}

const {
  fields,
  businessInfo,
  title = "Ceritakan rencana perjalanan Anda",
  description = "Formulir pertanyaan",
} = Astro.props;

const whatsappNumber = businessInfo.whatsapp.replace(/\D/g, "");
---

<Card className="border-border bg-brand-900 text-white">
  <CardHeader>
    <Badge variant="secondary" className="w-fit rounded-full px-3 py-1">
      {description}
    </Badge>
    <CardTitle className="text-3xl leading-tight text-white">
      {title}
    </CardTitle>
  </CardHeader>
  <CardContent className="grid gap-4">
    <form id="availability-form" class="grid gap-4">
      {
        fields.map((field) =>
          field.type === "textarea" ? (
            <label class="grid gap-2">
              <span class="form-label-light">
                {field.label}
                {!field.required && (
                  <span class="text-xs font-normal text-brand-200">
                    {" "}
                    — opsional
                  </span>
                )}
              </span>
              <textarea
                id={field.id}
                name={field.id}
                placeholder={field.placeholder}
                class="form-input-dark min-h-24 resize-none"
                required={field.required}
              />
            </label>
          ) : (
            <label class="grid gap-2">
              <span class="form-label-light">
                {field.label}
                {!field.required && (
                  <span class="text-xs font-normal text-brand-200">
                    {" "}
                    — opsional
                  </span>
                )}
              </span>
              <input
                id={field.id}
                type={field.type}
                name={field.id}
                placeholder={field.placeholder}
                class="form-input-dark"
                required={field.required}
              />
            </label>
          )
        )
      }
    </form>

    <div class="flex flex-wrap gap-3 border-t border-white/10 pt-4">
      <Button href="#availability-form" variant="secondary">
        Cek Ketersediaan
      </Button>
      <Button
        href={`https://wa.me/${whatsappNumber}?text=Halo%20Sungkar%20Group%2C%20saya%20tertarik%20untuk%20booking%20tur.`}
        target="_blank"
      >
        Chat WhatsApp
      </Button>
    </div>

    <div class="mt-2 rounded-lg border border-white/10 bg-white/5 p-3">
      <p class="text-xs text-brand-100">
        <strong>💡 Tip:</strong> Isi formulir untuk prioritas lebih cepat, atau langsung
        chat WhatsApp untuk pertanyaan yang lebih fleksibel.
      </p>
    </div>
  </CardContent>
</Card>

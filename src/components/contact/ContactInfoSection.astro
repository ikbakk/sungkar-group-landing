---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import type { BusinessInfo } from "@/lib/contact-data";
import { Separator } from "../ui/separator";

interface Props {
  businessInfo: BusinessInfo;
  title?: string;
  description?: string;
}

const {
  businessInfo,
  title = "Informasi Kontak",
  description = "Hubungi kami melalui berbagai saluran yang tersedia",
} = Astro.props;
---

<Card class="border-border justify-center bg-white">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight">
      {title}
    </CardTitle>
    {description && <p class="text-sm text-text-muted">{description}</p>}
  </CardHeader>
  <CardContent class="flex flex-col gap-2">
    <!-- Contact Methods -->
    <a
      href={`tel:${businessInfo.phone}`}
      class="flex flex-col items-start rounded-lg border border-border p-4 bg-surface-soft transition-colors hover:border-brand-200 hover:bg-brand-50"
    >
      <div class="text-sm font-medium text-foreground mb-2">
        Telepon / Whatsapp
      </div>
      <div class="text-sm text-text-muted">
        {businessInfo.phone}
      </div>
    </a>

    <Separator />

    <!-- Address -->
    <address
      class="not-italic flex flex-col items-start rounded-lg border border-border p-4 bg-surface-soft transition-colors hover:border-brand-200 hover:bg-brand-50"
    >
      <p class="text-sm font-medium text-foreground mb-2">
        {businessInfo.name}
      </p>
      <div class="space-y-1 text-sm text-text-muted">
        <p>{businessInfo.address.street}</p>
        <p>
          {businessInfo.address.city}, {businessInfo.address.region}
          {businessInfo.address.postalCode}
        </p>
        <p>{businessInfo.address.country}</p>
      </div>
    </address>

    <Separator />

    <!-- Social Links -->
    {
      Object.values(businessInfo.socialLinks).filter(Boolean).length > 0 && (
        <div class="flex flex-col items-start rounded-lg border border-border p-4 bg-surface-soft transition-colors hover:border-brand-200 hover:bg-brand-50">
          <h3 class="font-sans font-medium text-sm text-foreground mb-2">
            Ikuti Kami
          </h3>
          <div class="flex flex-wrap gap-2">
            {businessInfo.socialLinks.instagram && (
              <a
                href={businessInfo.socialLinks.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-md border border-border bg-white px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-surface-soft"
                aria-label="Follow on Instagram"
              >
                Instagram
              </a>
            )}
            {businessInfo.socialLinks.facebook && (
              <a
                href={businessInfo.socialLinks.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-md border border-border bg-white px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-surface-soft"
                aria-label="Follow on Facebook"
              >
                Facebook
              </a>
            )}
            {businessInfo.socialLinks.youtube && (
              <a
                href={businessInfo.socialLinks.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-md border border-border bg-white px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-surface-soft"
                aria-label="Subscribe on YouTube"
              >
                YouTube
              </a>
            )}
            {businessInfo.socialLinks.tiktok && (
              <a
                href={businessInfo.socialLinks.tiktok}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-md border border-border bg-white px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-surface-soft"
                aria-label="Follow on TikTok"
              >
                TikTok
              </a>
            )}
          </div>
        </div>
      )
    }
  </CardContent>
</Card>

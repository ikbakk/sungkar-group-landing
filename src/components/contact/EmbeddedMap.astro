---
import { TypographyH2 } from "@/components/ui/typography";
import { t } from "@/lib/i18n";
import { Button } from "@/components/ui/button";

interface Props {
  title?: string;
  description?: string;
  embedUrl: string;
  googleMapsUrl: string;
  businessName?: string;
  businessAddress?: string;
  locale?: string;
}

const {
  title,
  description,
  embedUrl = "",
  googleMapsUrl = "",
  businessName = "Sungkar Group Indonesia",
  locale = "id",
} = Astro.props;
const uiStrings = t(locale);
const resolvedTitle = title || uiStrings.contact.mapTitle;
const resolvedDescription = description || uiStrings.contact.mapDescription;
---

<div class="grid lg:grid-cols-2 min-h-80">
  <div class="space-y-1 h-full flex flex-col justify-center">
    <TypographyH2 class="text-3xl leading-tight text-foreground">
      {resolvedTitle}
    </TypographyH2>
    <p class="text-sm leading-7 text-text-muted">
      {resolvedDescription}
    </p>

    <div class="w-full flex justify-center lg:justify-start">
      <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer">
        <Button size={"lg"} variant={"default"}>
          {uiStrings.reviews.seeOnGoogleMaps}
        </Button>
      </a>
    </div>
  </div>

  <div
    class="relative mt-4 lg:mt-0 min-h-80 lg:min-h-full rounded-lg overflow-hidden"
  >
    <iframe
      src={embedUrl}
      class="absolute inset-0 h-full w-full"
      loading="eager"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
      title={`${uiStrings.contact.formTitle} ${businessName}`}></iframe>
  </div>
</div>

---
import { Card } from "@/components/ui/card";

interface Props {
  title?: string;
  description?: string;
  latitude: number;
  longitude: number;
  zoom?: number;
  businessName?: string;
  businessAddress?: string;
}

const {
  title = "Lokasi Kami",
  description = "Sungkar Group beroperasi di Lombok, Nusa Tenggara Barat.",
  latitude,
  longitude,
  zoom = 11,
  businessName = "Sungkar Group",
  businessAddress = "Kuta, Lombok",
} = Astro.props;

// Google Maps embed URL with business location
const mapsEmbedUrl = new URL("https://www.google.com/maps/embed");
mapsEmbedUrl.searchParams.set(
  "pb",
  `!1m18!1m12!1m3!1d3946.${Math.random().toString().slice(2, 6)}!2d${longitude}!3d${latitude}!2m3!1f0!2f0!3f0!3m2!1i${1024 * zoom}!2i${768 * zoom}!4f13.1!3m3!1m2!1s0x0%3A0x0!2z${latitude}%2C${longitude}!5e0!3m2!1sen!2sid!4v${Date.now()}`
);

// OpenStreetMap embed (privacy-friendly alternative)
const osmUrl = `https://www.openstreetmap.org/export/embed.html?bbox=${longitude - 0.05},${latitude - 0.05},${longitude + 0.05},${latitude + 0.05}&layer=mapnik&marker=${latitude},${longitude}`;
---

<Card className="border-border overflow-hidden bg-white">
  <div class="grid gap-6 lg:grid-cols-2">
    <div class="p-6 lg:p-8">
      <h3 class="font-heading text-2xl font-semibold text-foreground">
        {title}
      </h3>
      <p class="mt-3 text-sm leading-7 text-text-muted">
        {description}
      </p>

      <div class="mt-6 space-y-4">
        <div class="rounded-lg border border-border bg-surface-soft p-4">
          <div class="text-xs font-medium uppercase tracking-[0.1em] text-brand-700">
            Alamat Bisnis
          </div>
          <p class="mt-2 text-sm font-medium text-foreground">
            {businessName}
          </p>
          <address class="mt-1 text-sm not-italic text-text-muted">
            {businessAddress}
          </address>
        </div>

        <div class="flex gap-3">
          <a
            href={`https://www.google.com/maps/search/${businessName}/@${latitude},${longitude},${zoom}z`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-lg bg-brand-50 px-4 py-2 text-sm font-medium text-brand-900 transition-colors hover:bg-brand-100"
          >
            Buka di Google Maps
          </a>
          <a
            href={`https://www.openstreetmap.org/?mlat=${latitude}&mlon=${longitude}&zoom=${zoom}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-lg border border-border bg-white px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-surface-soft"
          >
            OpenStreetMap
          </a>
        </div>
      </div>
    </div>

    <div class="relative hidden min-h-96 lg:block">
      <iframe
        src={osmUrl}
        style="border: 0;"
        allowFullScreen
        loading="lazy"
        referrerPolicy="no-referrer-when-downgrade"
        class="absolute inset-0 h-full w-full"
        title={`${businessName} location on map`}
      ></iframe>
    </div>
  </div>

  <!-- Mobile map -->
  <div class="block lg:hidden">
    <a
      href={`https://www.google.com/maps/search/${businessName}/@${latitude},${longitude},${zoom}z`}
      target="_blank"
      rel="noopener noreferrer"
      class="block bg-brand-50 p-6 text-center transition-colors hover:bg-brand-100"
    >
      <p class="text-sm font-medium text-brand-900">
        Lihat lokasi kami di Google Maps →
      </p>
    </a>
  </div>
</Card>

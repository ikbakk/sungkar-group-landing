---
import { Button } from "@/components/ui/button";

interface Props {
  title?: string;
  description?: string;
  embedUrl: string;
  googleMapsUrl: string;
  businessName?: string;
  businessAddress?: string;
}

const {
  title = "Lokasi Kami",
  description = "Kunjungi kantor Sungkar Group Indonesia atau hubungi tim kami untuk konsultasi perjalanan.",
  embedUrl = "",
  googleMapsUrl = "",
  businessName = "Sungkar Group Indonesia",
} = Astro.props;
---

<div class="grid lg:grid-cols-2 min-h-80">
  <div class="space-y-1 h-full flex flex-col justify-center">
    <h2 class="text-3xl leading-tight text-foreground">
      {title}
    </h2>
    <p class="text-sm leading-7 text-text-muted">
      {description}
    </p>

    <div class="w-full flex justify-center lg:justify-start">
      <!-- INFO: this is how cta pattern, Button component wrapped by a tag (attr is flexible) -->
      <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer">
        <Button size={"lg"} variant={"default"}> Buka di Google Maps </Button>
      </a>
      <!-- INFO: this is how cta -->
    </div>
  </div>

  <div
    class="relative mt-4 lg:mt-0 min-h-80 lg:min-h-full rounded-lg overflow-hidden"
  >
    <iframe
      src={embedUrl}
      class="absolute inset-0 h-full w-full"
      loading="eager"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
      title={`Peta lokasi ${businessName}`}></iframe>
  </div>
</div>

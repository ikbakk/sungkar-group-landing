---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { aboutContent } from "@/lib/content/about";
---

<SectionContainer background="bg-surface-soft">
  <Card className="border-border bg-white">
    <CardHeader>
      <CardTitle className="text-3xl leading-tight">
        Mengapa wisatawan memilih Sungkar Group
      </CardTitle>
    </CardHeader>

    <CardContent className="grid gap-4 md:grid-cols-2">
      {
        aboutContent.strengths.map((item) => (
          <div class="rounded-lg border border-border bg-surface-soft p-4">
            <div class="font-medium text-foreground">{item.title}</div>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {item.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { t } from "@/lib/i18n";

interface Props {
  strengths: Array<{ title: string; description: string }>;
  locale?: string;
}

const { strengths, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<SectionContainer background="bg-background">
  <Card class="border-border bg-white">
    <CardHeader>
      <CardTitle class="text-3xl leading-tight">
        {uiStrings.about.whyChooseUs}
      </CardTitle>
    </CardHeader>

    <CardContent class="grid gap-4 md:grid-cols-2">
      {
        strengths.map((item) => (
          <div class="rounded-lg border border-border bg-surface-soft p-4">
            <div class="font-medium text-foreground">{item.title}</div>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {item.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

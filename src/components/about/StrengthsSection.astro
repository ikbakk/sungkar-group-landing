---
import { TypographyH2, TypographyH3 } from "@/components/ui/typography";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader } from "@/components/ui/card";

interface Props {
  strengths: Array<{ title: string; description: string }>;
  sectionTitle: string;
}

const { strengths, sectionTitle } = Astro.props;
---

<SectionContainer background="bg-background">
  <Card class="border-border bg-white">
    <CardHeader>
      <TypographyH2 class="font-heading font-normal text-foreground">
        {sectionTitle}
      </TypographyH2>
    </CardHeader>

    <CardContent class="grid gap-4 md:grid-cols-2">
      {
        strengths.map((item) => (
          <div class="rounded-lg border border-border bg-surface-soft p-4">
            <TypographyH3 class="font-heading font-normal text-foreground">
              {item.title}
            </TypographyH3>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {item.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  commitment: { title: string; description: string };
}

const { commitment } = Astro.props;
---

<SectionContainer background="bg-background">
  <Card class="border-border bg-brand-900 text-white">
    <CardHeader>
      <CardTitle class="text-3xl leading-tight text-white">
        {commitment.title}
      </CardTitle>
    </CardHeader>

    <CardContent>
      <p class="text-sm leading-7 text-brand-100">
        {commitment.description}
      </p>
    </CardContent>
  </Card>
</SectionContainer>

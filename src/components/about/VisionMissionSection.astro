---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { t } from "@/lib/i18n";

interface Props {
  vision: { description: string };
  mission: { items: string[] };
  locale?: string;
}

const { vision, mission, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<SectionContainer background="bg-background">
  <div class="grid gap-8 lg:grid-cols-2">
    <Card class="border-border bg-white">
      <CardHeader>
        <CardTitle class="text-3xl leading-tight"
          >{uiStrings.about.vision}</CardTitle
        >
      </CardHeader>

      <CardContent>
        <p class="text-sm leading-7 text-text-muted">
          {vision.description}
        </p>
      </CardContent>
    </Card>

    <Card class="border-border bg-white">
      <CardHeader>
        <CardTitle class="text-3xl leading-tight"
          >{uiStrings.about.mission}</CardTitle
        >
      </CardHeader>

      <CardContent class="flex flex-col gap-4">
        {
          mission.items.map((item) => (
            <div class="flex gap-3">
              <span class="text-brand-700">•</span>

              <p class="text-sm leading-7 text-text-muted">{item}</p>
            </div>
          ))
        }
      </CardContent>
    </Card>
  </div>
</SectionContainer>

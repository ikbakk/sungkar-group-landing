---
import { TypographyH2, TypographyH3 } from "@/components/ui/typography";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader } from "@/components/ui/card";

interface Props {
  services: Array<{ title: string; description: string }>;
  sectionTitle: string;
}

const { services, sectionTitle } = Astro.props;
---

<SectionContainer background="bg-surface-soft">
  <Card class="border-border bg-white">
    <CardHeader>
      <TypographyH2 class="font-heading font-normal text-foreground">
        {sectionTitle}
      </TypographyH2>
    </CardHeader>

    <CardContent class="flex flex-col gap-4">
      {
        services.map((service, index) => (
          <div
            class={
              index % 2 === 0
                ? "rounded-lg border border-border bg-surface-soft px-4 py-3"
                : "rounded-lg border border-border bg-white px-4 py-3"
            }
          >
            <TypographyH3 class="font-heading font-normal text-foreground">
              {service.title}
            </TypographyH3>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {service.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

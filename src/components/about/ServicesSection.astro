---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  services: Array<{ title: string; description: string }>;
}

const { services } = Astro.props;
---

<SectionContainer background="bg-surface-soft">
  <Card class="border-border bg-white">
    <CardHeader>
      <CardTitle class="text-3xl leading-tight">
        <!-- TODO:This need to be localized -->
        Apa yang kami kerjakan
      </CardTitle>
    </CardHeader>

    <CardContent class="flex flex-col gap-4">
      {
        services.map((service, index) => (
          <div
            class={
              index % 2 === 0
                ? "rounded-lg border border-border bg-surface-soft px-4 py-3"
                : "rounded-lg border border-border bg-white px-4 py-3"
            }
          >
            <div class="font-medium text-foreground">{service.title}</div>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {service.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { TypographyH2 } from "@/components/ui/typography";
import OGImageAstroComponent from "../seo/OGImage.astro";

import { BRAND } from "@/assets/images";

interface Props {
  story: { title: string; paragraphs: string[] };
  sectionLabel: string;
}

const { story, sectionLabel } = Astro.props;
---

<SectionContainer background="bg-surface-soft">
  <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
    <div
      class="overflow-hidden rounded-xl h-full border border-border bg-brand-900"
    >
      <OGImageAstroComponent
        image={BRAND.logo}
        alt={sectionLabel}
        class="h-full w-full object-contain py-4 hidden lg:block"
        loading="eager"
      />
      <OGImageAstroComponent
        image={BRAND.logo}
        alt={sectionLabel}
        class="w-full h-full object-contain py-4 lg:hidden"
        loading="eager"
        width={512}
        height={323}
      />
    </div>

    <Card class="border-border bg-white">
      <CardHeader>
        <p class="text-brand-700 text-lg">{sectionLabel}</p>

        <TypographyH2 class="font-heading font-normal text-foreground">
          {story.title}
        </TypographyH2>
      </CardHeader>

      <CardContent class="flex flex-col gap-4">
        {
          story.paragraphs.map((paragraph) => (
            <p class="text-sm leading-7 text-text-muted">{paragraph}</p>
          ))
        }
      </CardContent>
    </Card>
  </div>
</SectionContainer>

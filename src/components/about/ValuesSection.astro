---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { aboutContent } from "@/lib/content/about";
---

<SectionContainer background="bg-surface-soft">
  <Card className="border-border bg-white">
    <CardHeader>
      <CardTitle className="text-3xl leading-tight">
        Nilai-Nilai Kami
      </CardTitle>
    </CardHeader>

    <CardContent className="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        aboutContent.values.map((value) => (
          <div class="rounded-2xl border border-border bg-surface-soft p-4">
            <div class="font-medium text-foreground">{value.title}</div>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {value.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

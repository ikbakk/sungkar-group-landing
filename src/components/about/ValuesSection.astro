---
import SectionContainer from "@/layouts/SectionContainer.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { t } from "@/lib/i18n";

interface Props {
  values: Array<{ title: string; description: string }>;
  locale?: string;
}

const { values, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<SectionContainer background="bg-surface-soft">
  <Card class="border-border bg-white">
    <CardHeader>
      <CardTitle class="text-3xl leading-tight"
        >{uiStrings.about.ourValues}</CardTitle
      >
    </CardHeader>

    <CardContent class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        values.map((value) => (
          <div class="rounded-2xl border border-border bg-surface-soft p-4">
            <div class="font-medium text-foreground">{value.title}</div>

            <div class="mt-2 text-sm leading-7 text-text-muted">
              {value.description}
            </div>
          </div>
        ))
      }
    </CardContent>
  </Card>
</SectionContainer>

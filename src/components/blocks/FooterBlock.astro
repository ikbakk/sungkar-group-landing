---
import { TypographyH3 } from "@/components/ui/typography";
import { cn } from "@/lib/utils";
import { Icon } from "@/components/ui/icon";
import { Logo, LogoText } from "@/components/ui/logo";
import { Section, SectionContainer } from "@/components/ui/section";
import { localizeHref } from "@/lib/i18n/localize";
import { getFooterStrings } from "@/lib/i18n";

type Props = {
  class?: string;
  locale?: string;
  brandName: string;
  brandHref: string;
  description: string;
  socials?: {
    label: string;
    href: string;
    icon: string;
  }[];
  columns: {
    title: string;
    links: {
      label: string;
      href: string;
    }[];
  }[];
  copyright: string;
  bottomLinks?: {
    label: string;
    href: string;
  }[];
};

const {
  class: className,
  locale = "id",
  brandName,
  brandHref,
  description,
  socials,
  columns,
  copyright,
  bottomLinks,
} = Astro.props;

const footerStrings = getFooterStrings(locale);

function lh(href: string): string {
  return localizeHref(href, locale) || href;
}
---

<footer class={cn("bg-brand-900 text-white", className)}>
  <Section class="bg-transparent py-16 lg:py-20">
    <SectionContainer>
      <!-- Trust Strip -->
      <div class="border-b border-white/10 pb-8 mb-8">
        <div
          class="flex flex-wrap items-center justify-center gap-6 text-sm text-white/80"
        >
          <div class="flex items-center gap-2">
            <svg
              class="h-5 w-5 text-brand-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
              ></path>
            </svg>
            <span>{footerStrings.footer.licensedTourOperator}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="h-5 w-5 text-warm-500"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path>
            </svg>
            <span>{footerStrings.footer.ratingOnGoogle}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="h-5 w-5 text-brand-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
              ></path>
            </svg>
            <span class="text-white/70"
              >{footerStrings.footer.secureBooking}</span
            >
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="h-5 w-5 text-brand-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-white/70">{footerStrings.footer.support247}</span>
          </div>
        </div>
      </div>
      <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
        <div class="flex flex-col gap-5">
          <Logo href={lh(brandHref)}>
            <LogoText class="text-2xl font-normal text-white"
              >{brandName}</LogoText
            >
          </Logo>
          <p class="max-w-xs text-sm leading-relaxed text-white/70">
            {description}
          </p>
          {
            socials && socials.length > 0 && (
              <div class="flex items-center gap-3">
                {socials.map((social) => (
                  <a
                    href={social.href}
                    class="text-white/50 hover:text-white transition-colors duration-300"
                    aria-label={social.label}
                    target="_blank"
                    rel="noreferrer"
                  >
                    <Icon name={social.icon} class="size-4" />
                  </a>
                ))}
              </div>
            )
          }
          <div class="mt-4">
            <p class="text-sm font-medium text-white mb-2">
              {footerStrings.footer.subscribeForTips}
            </p>
            <form class="flex gap-2">
              <input
                type="email"
                placeholder={footerStrings.footer.yourEmail}
                class="flex-1 rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-brand-400/50"
              />
              <button
                type="submit"
                class="rounded-full bg-brand-500 px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-400 transition-colors duration-300"
              >
                {footerStrings.footer.subscribe}
              </button>
            </form>
          </div>
        </div>
        <div class="grid gap-8 sm:grid-cols-3">
          {
            columns.map((column) => (
              <div class="flex flex-col gap-3">
                <TypographyH3 class="text-lg font-normal text-white">
                  {column.title}
                </TypographyH3>
                <ul class="flex flex-col gap-2.5 font-sans">
                  {column.links.map((link) => (
                    <li>
                      <a
                        href={lh(link.href)}
                        class="text-white/70 hover:text-white text-sm transition-colors duration-300"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <div class="border-t border-white/10 pt-8">
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="text-white/60 text-sm">{copyright}</p>
          {
            bottomLinks && bottomLinks.length > 0 && (
              <nav class="flex flex-wrap items-center gap-x-5 gap-y-2">
                {bottomLinks.map((link) => (
                  <a
                    href={lh(link.href)}
                    class="text-white/60 hover:text-white text-sm transition-colors duration-300"
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            )
          }
        </div>
      </div>
    </SectionContainer>
  </Section>
</footer>

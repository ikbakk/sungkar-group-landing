---
import { TypographyH2, TypographyH3 } from "@/components/ui/typography";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";
import { Icon } from "@/components/ui/icon";
import { Section, SectionContainer } from "@/components/ui/section";

import { t } from "@/lib/i18n";

type Props = {
  class?: string;
  locale?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  alignment?: "left" | "center" | "right";
  buttons?: {
    label: string;
    href: string;
    variant?: "default" | "outline" | "secondary" | "ghost";
  }[];
  services: {
    icon?: string;
    title: string;
    description: string;
    href?: string;
  }[];
  linkText?: string;
};

const {
  class: className,
  locale = "id",
  eyebrow,
  title,
  description,
  alignment = "center",
  buttons,
  services,
  linkText,
} = Astro.props;

const uiStrings = t(locale);
---

<Section class={cn("section-padding", className)}>
  <SectionContainer class="gap-12">
    <div
      class={cn(
        alignment === "center" && "mx-auto max-w-2xl text-center",
        alignment === "left" && "text-left",
        alignment === "right" && "text-right ml-auto",
      )}
    >
      {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
      <TypographyH2 class="section-title">
        {title}
      </TypographyH2>
      {
        description && (
          <p class="section-description text-balance">{description}</p>
        )
      }
      {
        buttons?.length && (
          <div
            class={cn(
              "mt-6 flex flex-wrap gap-3",
              alignment === "center" && "justify-center",
              alignment === "left" && "justify-start",
              alignment === "right" && "justify-end",
            )}
          >
            {buttons.map(({ href, label, ...button }) => (
              <Button as="a" href={href} variant={button.variant}>
                {label}
              </Button>
            ))}
          </div>
        )
      }
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <div class="section-card group/service flex flex-col gap-4 p-7">
            <div class="bg-brand-50 text-brand-600 ring-brand-100 flex size-11 items-center justify-center rounded-2xl ring-1 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover/service:scale-105">
              <Icon name={service.icon ?? "layout-grid"} class="size-5" />
            </div>
            <TypographyH3
              class="text-base font-semibold tracking-tight"
              style="font-family: var(--font-heading);"
            >
              {service.title}
            </TypographyH3>
            <p class="text-text-muted text-sm leading-relaxed">
              {service.description}
            </p>
            {service.href && (
              <a
                href={service.href}
                class="text-brand-600 mt-auto inline-flex items-center gap-1.5 text-sm font-medium transition-all duration-300 hover:gap-2.5"
              >
                {linkText || uiStrings.common.learnMore}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform duration-300 group-hover/service:translate-x-0.5"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </div>
        ))
      }
    </div>
  </SectionContainer>
</Section>

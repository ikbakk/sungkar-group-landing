---
import { TypographyH2 } from "@/components/ui/typography";
import type { ImageSource } from "@/lib/images";

import { cn } from "@/lib/utils";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";
import { Icon } from "@/components/ui/icon";
import { Marquee } from "@/components/ui/marquee";
import { Rating } from "@/components/ui/rating";
import { Section, SectionContainer } from "@/components/ui/section";

type Props = {
  class?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  alignment?: "left" | "center" | "right";
  reviews: {
    quote: string;
    image?: ImageSource;
    initials: string;
    name: string;
    role: string;
    rating: number;
  }[];
};

const {
  class: className,
  eyebrow,
  title,
  description,
  alignment = "center",
  reviews,
} = Astro.props;

const third = Math.ceil(reviews.length / 3);
const row1 = reviews.slice(0, third);
const row2 = reviews.slice(third, third * 2);
const row3 = reviews.slice(third * 2);
---

<Section class={cn("", className)}>
  {
    (eyebrow || title || description) && (
      <SectionContainer
        class={cn(
          "items-center gap-4",
          alignment === "left" && "items-start text-left",
          alignment === "right" && "items-end text-right",
          alignment === "center" && "text-center",
        )}
      >
        {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
        {title && (
          <TypographyH2 class="text-4xl leading-tight tracking-tight sm:text-5xl">
            {title}
          </TypographyH2>
        )}
        {description && (
          <p
            class={cn(
              "text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance",
              alignment === "center" && "mx-auto",
            )}
          >
            {description}
          </p>
        )}
      </SectionContainer>
    )
  }
  <div class="flex flex-col gap-5">
    <Marquee
      direction="left"
      pauseOnHover
      infinite
      gap="1.25rem"
      class="[&>div]:items-stretch"
    >
      {
        row1.map((item) => (
          <div class="section-card flex w-104 shrink-0 p-6">
            <div class="flex min-w-0 flex-1 flex-col gap-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <Avatar size="lg">
                    <AvatarImage src={item.image} alt={item.name} />
                    <AvatarFallback>{item.initials}</AvatarFallback>
                  </Avatar>
                  <div>
                    <p class="text-foreground text-sm font-semibold">
                      {item.name}
                    </p>
                    <p class="text-muted-foreground text-xs">{item.role}</p>
                  </div>
                </div>
                <Rating value={item.rating} />
              </div>
              <div class="flex min-w-0 gap-2.5">
                <Icon
                  name="quote"
                  class="text-brand-300 mt-0.5 size-5 shrink-0"
                />
                <p class="text-foreground/75 min-w-0 text-sm leading-relaxed">
                  {item.quote}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </Marquee>
    <Marquee
      direction="right"
      pauseOnHover
      infinite
      gap="1.25rem"
      class="[&>div]:items-stretch"
    >
      {
        row2.map((item) => (
          <div class="section-card flex w-104 shrink-0 p-6">
            <div class="flex min-w-0 flex-1 flex-col gap-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <Avatar size="lg">
                    <AvatarImage src={item.image} alt={item.name} />
                    <AvatarFallback>{item.initials}</AvatarFallback>
                  </Avatar>
                  <div>
                    <p class="text-foreground text-sm font-semibold">
                      {item.name}
                    </p>
                    <p class="text-muted-foreground text-xs">{item.role}</p>
                  </div>
                </div>
                <Rating value={item.rating} />
              </div>
              <div class="flex min-w-0 gap-2.5">
                <Icon
                  name="quote"
                  class="text-brand-300 mt-0.5 size-5 shrink-0"
                />
                <p class="text-foreground/75 min-w-0 text-sm leading-relaxed">
                  {item.quote}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </Marquee>
    <Marquee
      direction="left"
      pauseOnHover
      infinite
      gap="1.25rem"
      class="[&>div]:items-stretch"
    >
      {
        row3.map((item) => (
          <div class="section-card flex w-104 shrink-0 p-6">
            <div class="flex min-w-0 flex-1 flex-col gap-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <Avatar size="lg">
                    <AvatarImage src={item.image} alt={item.name} />
                    <AvatarFallback>{item.initials}</AvatarFallback>
                  </Avatar>
                  <div>
                    <p class="text-foreground text-sm font-semibold">
                      {item.name}
                    </p>
                    <p class="text-muted-foreground text-xs">{item.role}</p>
                  </div>
                </div>
                <Rating value={item.rating} />
              </div>
              <div class="flex min-w-0 gap-2.5">
                <Icon
                  name="quote"
                  class="text-brand-300 mt-0.5 size-5 shrink-0"
                />
                <p class="text-foreground/75 min-w-0 text-sm leading-relaxed">
                  {item.quote}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </Marquee>
  </div>
</Section>

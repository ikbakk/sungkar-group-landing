---
import { TypographyH2, TypographyH3 } from "@/components/ui/typography";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";
import { Icon } from "@/components/ui/icon";
import { Section, SectionContainer } from "@/components/ui/section";

type Props = {
  class?: string;
  title: string;
  description: string;
  eyebrow?: string;
  alignment?: "left" | "center" | "right";
  buttons?: {
    label: string;
    href: string;
    variant?: "default" | "outline" | "secondary" | "ghost";
  }[];
  features: {
    title: string;
    description: string;
    icon: string;
    href?: string;
    linkText?: string;
  }[];
};

const {
  class: className,
  title,
  description,
  eyebrow,
  alignment = "center",
  buttons,
  features,
} = Astro.props;
---

<Section class={cn("section-padding", className)}>
  <SectionContainer
    class={cn(
      "gap-8",
      alignment === "left" && "items-start text-left",
      alignment === "right" && "items-end text-right",
      alignment === "center" && "items-center text-center",
    )}
  >
    <div
      class={cn(
        "flex flex-col gap-4 max-w-2xl",
        alignment === "center" && "items-center",
        alignment === "right" && "items-end",
      )}
    >
      {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
      <TypographyH2 class="section-title">
        {title}
      </TypographyH2>
      <p class="section-description text-balance">
        {description}
      </p>
    </div>
    {
      buttons?.length && (
        <div
          class={cn(
            "flex flex-wrap gap-3",
            alignment === "center" && "justify-center",
            alignment === "left" && "justify-start",
            alignment === "right" && "justify-end",
          )}
        >
          {buttons.map(({ href, label, ...button }, index) => (
            <Button
              as="a"
              href={href}
              variant={button.variant ?? (index === 0 ? "default" : "outline")}
              {...button}
            >
              {label}
            </Button>
          ))}
        </div>
      )
    }
  </SectionContainer>
  <SectionContainer>
    <div class="grid gap-5 sm:grid-cols-2">
      {
        features.map((feature) => (
          <a
            href={feature.href}
            class="group/feature section-card-interactive flex flex-col gap-4 p-7"
          >
            <div class="bg-brand-50 text-brand-600 flex size-11 items-center justify-center rounded-2xl ring-1 ring-brand-100">
              <Icon name={feature.icon} class="size-5" />
            </div>
            <div class="flex flex-col gap-2">
              <TypographyH3
                class="text-foreground text-lg font-semibold"
                style="font-family: var(--font-heading);"
              >
                {feature.title}
              </TypographyH3>
              <p class="text-text-muted text-sm leading-relaxed">
                {feature.description}
              </p>
            </div>
            {feature.href && feature.linkText && (
              <span class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 transition-all duration-300 group-hover/feature:gap-2.5">
                {feature.linkText}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform duration-300 group-hover/feature:translate-x-0.5"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </span>
            )}
          </a>
        ))
      }
    </div>
  </SectionContainer>
</Section>

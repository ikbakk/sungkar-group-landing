---
import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import { Icon } from "@/components/ui/icon"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  eyebrow?: string
  alignment?: "left" | "center" | "right"
  buttons?: {
    label: string
    href: string
    variant?: "default" | "outline" | "secondary" | "ghost"
  }[]
  features: {
    title: string
    description: string
    icon: string
    href?: string
    linkText?: string
  }[]
}

const { class: className, title, description, eyebrow, alignment = "center", buttons, features } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class={cn("gap-6", alignment === "left" && "items-start text-left", alignment === "right" && "items-end text-right", alignment === "center" && "items-center text-center")}>
    <div class={cn("flex flex-col gap-4", alignment === "center" && "items-center max-w-2xl")}>
      {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
      <h2 class="text-4xl leading-tight tracking-tight sm:text-5xl">
        {title}
      </h2>
      <p class={cn("text-muted-foreground text-lg leading-relaxed text-balance line-clamp-2", alignment === "center" && "max-w-2xl")}>
        {description}
      </p>
    </div>
    {
      buttons?.length && (
        <div class={cn("flex flex-wrap gap-3", alignment === "center" && "justify-center", alignment === "left" && "justify-start", alignment === "right" && "justify-end")}>
          {buttons.map(({ href, label, ...button }, index) => (
            <Button
              as="a"
              href={href}
              variant={button.variant ?? (index === 0 ? "default" : "outline")}
              {...button}
            >
              {label}
            </Button>
          ))}
        </div>
      )
    }
  </SectionContainer>
  <SectionContainer>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        features.map((feature) => (
          <div class="group/feature hover:bg-muted/40 flex flex-col gap-4 rounded-xl border p-6 transition-colors">
            <div class="bg-primary/10 text-primary flex size-10 items-center justify-center rounded-lg">
              <Icon name={feature.icon} class="size-5" />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-foreground text-base">
                {feature.title}
              </h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {feature.description}
              </p>
            </div>
            {feature.href && feature.linkText && (
              <a
                href={feature.href}
                class="text-primary mt-auto inline-flex items-center gap-1 text-sm font-medium hover:underline"
              >
                {feature.linkText}
                <Icon name="arrow-right" class="size-3.5" />
              </a>
            )}
          </div>
        ))
      }
    </div>
  </SectionContainer>
</Section>

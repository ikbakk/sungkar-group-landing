---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { t } from "@/lib/i18n";

interface Props {
  title: string;
  description: string;
  locale?: string;
}

const { title, description, locale = "id" } = Astro.props;
const uiStrings = t(locale);
---

<Card class="border-border bg-brand-900 text-white">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight text-white">
      {title}
    </CardTitle>
  </CardHeader>

  <CardContent>
    <p class="text-sm leading-7 text-brand-100">
      {description}
    </p>

    <div class="mt-6">
      <Button href="/kontak" variant="secondary"> {uiStrings.common.contactUs} </Button>
    </div>
  </CardContent>
</Card>

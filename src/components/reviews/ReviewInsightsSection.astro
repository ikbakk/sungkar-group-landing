---
import { TypographyH4, TypographyP } from "@/components/ui/typography";

interface InsightItem {
  title: string;
  description: string;
}

interface Props {
  insights: {
    title: string;
    items: InsightItem[];
  };
  seeOnGoogleMaps: string;
  seeAllReviews: string;
}

const { insights, seeOnGoogleMaps, seeAllReviews } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-2">
  <div class="flex flex-col gap-4">
    <TypographyP
      class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
    >
      {insights.title}
    </TypographyP>

    <ul class="flex flex-col gap-3">
      {
        insights.items.map((item: InsightItem) => (
          <li class="flex items-start gap-3 rounded-xl border border-border bg-surface-soft p-4">
            <div>
              <TypographyH4>{item.title}</TypographyH4>
              <TypographyP class="mt-0.5 text-sm text-text-muted">
                {item.description}
              </TypographyP>
            </div>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="flex flex-col gap-4">
    <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
      {seeOnGoogleMaps}
    </div>

    <div class="overflow-hidden rounded-xl border border-border">
      <iframe
        src="https://maps.google.com/maps?q=Sungkar+Group+Indonesia+Lombok&output=embed"
        width="100%"
        height="280"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Sungkar Group Indonesia di Google Maps"></iframe>
    </div>

    <a
      href="https://www.google.com/maps/place/Sungkar+Group+Indonesia+-+(+Paket+Tour+Lombok+%7C+Paket+Group+Lombok+%7C+Tour+Lombok+%7C+Sewa+Mobil+Lombok+)/@-8.5645526,116.0789557,17z"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium text-brand-700 underline-offset-2 hover:underline"
    >
      {seeAllReviews} &rarr;
    </a>
  </div>
</div>

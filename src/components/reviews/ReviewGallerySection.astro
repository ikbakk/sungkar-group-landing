---
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { TypographyH2 } from "@/components/ui/typography";
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselPrevious,
  CarouselNext,
} from "@/components/ui/carousel";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { GALLERY } from "@/assets/images";

interface Props {
  title: string;
}

const { title } = Astro.props;

const galleryImages = Object.values(GALLERY);
---

<Card class="border-border bg-white">
  <CardHeader>
    <TypographyH2 class="text-3xl leading-tight">
      {title}
    </TypographyH2>
  </CardHeader>

  <CardContent class="sm:px-6">
    <Carousel
      opts={{
        slidesToScroll: 3,
        loop: true,
      }}
      class="w-[90%] mx-auto"
    >
      <CarouselContent>
        {
          galleryImages.map((img) => (
            <CarouselItem class="sm:basis-1/2 md:basis-1/3 md:pl-4">
              <div class="aspect-4/3 overflow-hidden rounded-xl border border-border ">
                <OptimizedImage
                  src={img}
                  alt="review-images"
                  class="h-full w-full object-cover hover:scale-105 duration-150"
                  loading="lazy"
                />
              </div>
            </CarouselItem>
          ))
        }
      </CarouselContent>

      <CarouselPrevious />
      <CarouselNext />
    </Carousel>
  </CardContent>
</Card>

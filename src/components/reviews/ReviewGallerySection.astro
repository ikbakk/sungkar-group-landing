---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { t } from "@/lib/i18n";

interface Props {
  locale?: string;
}

const { locale = "id" } = Astro.props;
const uiStrings = t(locale);
const photos = uiStrings.reviews.galleryPhotoCaptions;
---

<Card class="border-border bg-white">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight">
      {uiStrings.reviews.galleryTitle}
    </CardTitle>
  </CardHeader>

  <CardContent class="grid gap-4 md:grid-cols-2">
    {
      photos.map((item) => (
        <div class="aspect-4/3 rounded-xl border border-border bg-surface-soft flex items-center justify-center text-center text-sm font-medium text-text-muted">
          {item}
        </div>
      ))
    }
  </CardContent>
</Card>

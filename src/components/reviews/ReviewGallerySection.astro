---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselPrevious,
  CarouselNext,
} from "@/components/ui/carousel";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import { GALLERY } from "@/assets/images";
import { t } from "@/lib/i18n";

interface Props {
  locale?: string;
}

const { locale = "id" } = Astro.props;
const uiStrings = t(locale);

const galleryImages = Object.values(GALLERY);
---

<Card class="border-border bg-white">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight">
      {uiStrings.reviews.galleryTitle}
    </CardTitle>
  </CardHeader>

  <CardContent class="px-0 sm:px-6">
    <Carousel
      opts={{
        slidesToScroll: 4,
        loop: true,
        breakpoints: {
          "(max-width: 640px)": { slidesToScroll: 1 },
          "(max-width: 1024px)": { slidesToScroll: 2 },
        },
      }}
    >
      <CarouselContent class="-ml-2 md:-ml-4">
        {galleryImages.map((img) => (
          <CarouselItem class="basis-full sm:basis-1/2 md:basis-1/4 pl-2 md:pl-4">
            <div class="aspect-4/3 overflow-hidden rounded-xl border border-border">
              <OptimizedImage
                src={img}
                alt=""
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          </CarouselItem>
        ))}
      </CarouselContent>

      <CarouselPrevious class="left-2 sm:-left-12" />
      <CarouselNext class="right-2 sm:-right-12" />
    </Carousel>
  </CardContent>
</Card>

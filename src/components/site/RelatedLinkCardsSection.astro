---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";

interface RelatedLinkItem {
  title: string;
  description: string;
  href: string;
}

interface Props {
  title: string;
  items: RelatedLinkItem[];
  buttonLabel: string;
}

const { title, items, buttonLabel } = Astro.props as Props;
---

<div class="mx-auto max-w-5xl">
  <div class="mb-8 text-center">
    <h2 class="text-3xl font-semibold leading-tight text-foreground">
      {title}
    </h2>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    {
      items.map((item) => (
        <Card class="border-border bg-white">
          <CardHeader>
            <CardTitle class="text-2xl leading-tight">{item.title}</CardTitle>
          </CardHeader>
          <CardContent class="grid gap-3 text-sm leading-7 text-text-muted">
            <p>{item.description}</p>
            <Button as="a" href={item.href} variant="outline">
              {buttonLabel}
            </Button>
          </CardContent>
        </Card>
      ))
    }
  </div>
</div>

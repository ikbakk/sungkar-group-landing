---
import { TypographyH2 } from "@/components/ui/typography";
import SectionContainer from "@/layouts/SectionContainer.astro";
import { getFaqStrings } from "@/lib/i18n";
import FaqAccordion from "./FaqAccordion";

interface Props {
  title?: string;
  eyebrow?: string;
  locale?: string;
  items: {
    question: string;
    answer: string;
  }[];
  background?: string;
  variant?: "divider" | "card";
}

const {
  title,
  eyebrow,
  locale = "id",
  items,
  background = "bg-background",
  variant = "divider",
} = Astro.props;
const uiStrings = getFaqStrings(locale);
---

<SectionContainer background={background}>
  <div class="mb-8">
    <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
      {eyebrow}
    </div>

    <TypographyH2 class="mt-2 text-3xl leading-tight">
      {title || uiStrings.sectionTitle}
    </TypographyH2>
  </div>

  <FaqAccordion items={items} variant={variant} client:visible />
</SectionContainer>

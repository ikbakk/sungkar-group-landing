---
import SectionContainer from "@/layouts/SectionContainer.astro";
import FaqAccordion from "./FaqAccordion";

interface Props {
  title?: string;
  eyebrow?: string;
  items: {
    question: string;
    answer: string;
  }[];
  background?: string;
  variant?: "divider" | "card";
}

const {
  title = "Pertanyaan yang Sering Diajukan",
  eyebrow = "FAQ",
  items,
  background = "bg-background",
  variant = "divider",
} = Astro.props;
---

<SectionContainer background={background}>
  <div class="mb-8">
    <div class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700">
      {eyebrow}
    </div>

    <h2 class="mt-2 text-3xl leading-tight">
      {title}
    </h2>
  </div>

  <!-- TODO: if we can convert using https://ui.full.dev/components/accordion.md would be better -->
  <FaqAccordion items={items} variant={variant} client:load />
</SectionContainer>

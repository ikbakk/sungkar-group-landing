---
import { TypographyH1 } from "@/components/ui/typography";
import type { ImageSource } from "@/lib/images";
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/ui/breadcrumb";

type Crumb = {
  label: string;
  href?: string;
};

interface Stat {
  label: string;
  value: string;
}

interface Props {
  locale?: string;
  eyebrow?: string;
  title: string;
  description: string;
  breadcrumbs: Crumb[];
  image?: ImageSource;
  imageAlt?: string;
  stats?: Stat[];
}

const { eyebrow, title, description, breadcrumbs, image, imageAlt, stats } =
  Astro.props as Props;
---

{
  image ? (
    <section class="relative flex min-h-[70vh] flex-col justify-end bg-gray-900 lg:min-h-[80vh]">
      <OptimizedImage
        src={image}
        alt={imageAlt ?? title}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
        widths={[640, 960, 1280, 1600, 1920]}
        sizes="100vw"
        quality={76}
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/50 to-black/20" />

      <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-col px-4 pb-10 pt-32 sm:px-6 md:pt-32 lg:pb-14 lg:px-8">
        <Breadcrumb class="mb-8 min-w-0">
          <BreadcrumbList class="w-full min-w-0 flex-wrap">
            {breadcrumbs.map((crumb, index) => {
              const isCurrent = index === breadcrumbs.length - 1;

              return (
                <BreadcrumbItem
                  class={
                    isCurrent
                      ? "min-w-0 max-w-full"
                      : "shrink-0 whitespace-nowrap"
                  }
                >
                  {index > 0 && <BreadcrumbSeparator class="text-white/30" />}
                  {crumb.href ? (
                    <BreadcrumbLink
                      href={crumb.href}
                      class="text-white/70 transition-colors hover:text-white"
                    >
                      {crumb.label}
                    </BreadcrumbLink>
                  ) : (
                    <BreadcrumbPage
                      class="min-w-0 whitespace-normal break-words font-semibold text-white"
                      title={crumb.label}
                    >
                      {crumb.label}
                    </BreadcrumbPage>
                  )}
                </BreadcrumbItem>
              );
            })}
          </BreadcrumbList>
        </Breadcrumb>

        {eyebrow && (
          <div class="text-sm font-medium uppercase tracking-[0.28em] text-white/50">
            {eyebrow}
          </div>
        )}

        <TypographyH1 class="mt-4 max-w-4xl text-4xl leading-tight text-white sm:text-5xl lg:text-6xl">
          {title}
        </TypographyH1>

        <p class="mt-4 max-w-3xl text-base leading-7 text-white/70 sm:text-lg">
          {description}
        </p>

        {stats && stats.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
            {stats.map((stat) => (
              <div>
                <span class="block text-xs uppercase tracking-wider text-white/40">
                  {stat.label}
                </span>
                <span class="mt-0.5 block text-sm font-medium text-white">
                  {stat.value}
                </span>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  ) : (
    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-4 pt-32 pb-8 sm:px-6 lg:px-8 lg:pt-32">
        <Breadcrumb class="min-w-0 font-sans">
          <BreadcrumbList class="w-full min-w-0 flex-wrap">
            {breadcrumbs.map((crumb, index) => {
              const isCurrent = index === breadcrumbs.length - 1;

              return (
                <BreadcrumbItem
                  class={
                    isCurrent
                      ? "min-w-0 max-w-full"
                      : "shrink-0 whitespace-nowrap"
                  }
                >
                  {index > 0 && <BreadcrumbSeparator />}
                  {crumb.href ? (
                    <BreadcrumbLink href={crumb.href}>
                      {crumb.label}
                    </BreadcrumbLink>
                  ) : (
                    <BreadcrumbPage
                      class="min-w-0 whitespace-normal break-words font-semibold"
                      title={crumb.label}
                    >
                      {crumb.label}
                    </BreadcrumbPage>
                  )}
                </BreadcrumbItem>
              );
            })}
          </BreadcrumbList>
        </Breadcrumb>

        {eyebrow && (
          <div class="mt-8 text-sm font-sans font-medium uppercase tracking-[0.28em] text-brand-700">
            {eyebrow}
          </div>
        )}
        <TypographyH1 class="mt-4 max-w-4xl text-4xl leading-tight tracking-[-0.03em] text-foreground sm:text-5xl lg:text-6xl">
          {title}
        </TypographyH1>
        <p class="mt-5 max-w-3xl font-sans text-base leading-8 text-text-muted sm:text-lg">
          {description}
        </p>
      </div>
    </section>
  )
}

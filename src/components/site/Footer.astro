---
import FooterBlock from "@/components/blocks/FooterBlock.astro";
import { getFooterStrings } from "@/lib/i18n";
import { businessInfo } from "@/lib/contact-data";

interface Props {
  locale?: string | undefined;
}

const { locale = "id" } = Astro.props as Props;
const currentYear = new Date().getFullYear();
const footerStrings = getFooterStrings(locale);
const footerSocials = [
  {
    label: footerStrings.footer.instagram,
    href: businessInfo.socialLinks.instagram,
    icon: "instagram",
  },
  {
    label: footerStrings.footer.youtube,
    href: businessInfo.socialLinks.youtube,
    icon: "youtube",
  },
  {
    label: footerStrings.footer.facebook,
    href: businessInfo.socialLinks.facebook,
    icon: "facebook",
  },
  {
    label: footerStrings.footer.tiktok,
    href: businessInfo.socialLinks.tiktok,
    icon: "tiktok",
  },
].filter((social): social is { label: string; href: string; icon: string } =>
  Boolean(social.href),
);
---

<FooterBlock
  locale={locale}
  brandName={footerStrings.footer.brandName}
  brandHref="/"
  description={footerStrings.footer.description}
  socials={footerSocials}
  columns={[
    {
      title: footerStrings.footer.navigation,
      links: [
        { label: footerStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
        { label: footerStrings.breadcrumb.accommodations, href: "/akomodasi" },
        { label: footerStrings.breadcrumb.carRental, href: "/sewa-mobil" },
        { label: footerStrings.breadcrumb.destinations, href: "/destinasi" },
        {
          label: footerStrings.breadcrumb.travelGuides,
          href: "/panduan-wisata",
        },
        { label: footerStrings.breadcrumb.blog, href: "/blog" },
      ],
    },
    {
      title: footerStrings.footer.destinations,
      links: [
        { label: "Lombok", href: "/destinasi" },
        { label: "Sumbawa", href: "/destinasi" },
        { label: "Labuan Bajo", href: "/destinasi" },
      ],
    },
    {
      title: footerStrings.footer.company,
      links: [
        { label: footerStrings.breadcrumb.faq, href: "/faq" },
        { label: footerStrings.breadcrumb.reviews, href: "/ulasan" },
        { label: footerStrings.breadcrumb.about, href: "/tentang-kami" },
        { label: footerStrings.breadcrumb.contact, href: "/kontak" },
      ],
    },
  ]}
  copyright={footerStrings.footer.copyright.replace(
    "{year}",
    String(currentYear),
  )}
  bottomLinks={[
    {
      label: footerStrings.footer.privacy,
      href: "/kebijakan-privasi",
    },
    {
      label: footerStrings.footer.terms,
      href: "/syarat-ketentuan",
    },
  ]}
/>

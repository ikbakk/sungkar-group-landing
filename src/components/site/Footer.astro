---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";

const currentYear = new Date().getFullYear();
---

<footer class="bg-background">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <Separator />
    <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
      <div class="max-w-2xl">
        <div
          class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
        >
          Sungkar Group
        </div>

        <h2
          class="mt-4 font-heading text-3xl leading-tight text-foreground sm:text-4xl"
        >
          Operator wisata lokal untuk Lombok, Sumbawa, dan Labuan Bajo.
        </h2>

        <p class="mt-4 max-w-xl text-sm leading-7 text-text-muted">
          Paket wisata, transportasi, destinasi, akomodasi, dan panduan
          perjalanan yang dirancang untuk membantu wisatawan menjelajahi
          Indonesia Timur dengan lebih mudah.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          <a
            href="https://www.instagram.com/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Badge variant="outline" className="rounded-full px-3 py-1 text-xs">
              Instagram
            </Badge>
          </a>

          <a
            href="https://www.youtube.com/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Badge variant="outline" className="rounded-full px-3 py-1 text-xs">
              YouTube
            </Badge>
          </a>
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <Card>
          <CardHeader>
            <h3 class="text-xl font-heading">Navigasi</h3>
          </CardHeader>
          <CardContent>
            <div class="grid gap-2 text-sm text-text-muted">
              <a
                href="/paket-wisata"
                class="transition-colors hover:text-foreground"
              >
                Paket Wisata
              </a>

              <a
                href="/akomodasi"
                class="transition-colors hover:text-foreground"
              >
                Akomodasi
              </a>

              <a
                href="/sewa-mobil"
                class="transition-colors hover:text-foreground"
              >
                Sewa Mobil
              </a>

              <a
                href="/destinasi"
                class="transition-colors hover:text-foreground"
              >
                Destinasi
              </a>

              <a
                href="/panduan-wisata"
                class="transition-colors hover:text-foreground"
              >
                Panduan Wisata
              </a>

              <a href="/ulasan" class="transition-colors hover:text-foreground">
                Ulasan
              </a>

              <a
                href="/tentang-kami"
                class="transition-colors hover:text-foreground"
              >
                Tentang Kami
              </a>

              <a href="/kontak" class="transition-colors hover:text-foreground">
                Kontak
              </a>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <h3 class="text-xl font-heading">Destinasi Populer</h3>
          </CardHeader>

          <CardContent>
            <div class="grid gap-2 text-sm text-text-muted">
              <a
                href="/paket-wisata/lombok"
                class="transition-colors hover:text-foreground"
              >
                Lombok
              </a>

              <a
                href="/paket-wisata/sumbawa"
                class="transition-colors hover:text-foreground"
              >
                Sumbawa
              </a>

              <a
                href="/paket-wisata/labuan-bajo"
                class="transition-colors hover:text-foreground"
              >
                Labuan Bajo
              </a>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
    <Separator className="my-8" />
    <div
      class="flex flex-col gap-4 text-center text-sm text-text-muted md:flex-row md:items-center md:justify-between md:text-left"
    >
      <p>© {currentYear} Sungkar Group. All rights reserved.</p>

      <p>Lombok • Sumbawa • Labuan Bajo</p>
    </div>
  </div>
</footer>;

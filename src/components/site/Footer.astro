---
import FooterBlock from "@/components/blocks/FooterBlock.astro";
import { t } from "@/lib/i18n";

interface Props {
  locale?: string | undefined;
}

const { locale = "id" } = Astro.props as Props;
const currentYear = new Date().getFullYear();
const uiStrings = t(locale);
---

<FooterBlock
  locale={locale}
  brandName={uiStrings.footer.brandName}
  brandHref="/"
  description={uiStrings.footer.description}
  socials={[
    {
      label: uiStrings.footer.instagram,
      href: "https://www.instagram.com/tour_lombok/reels/",
      icon: "instagram",
    },
    {
      label: uiStrings.footer.youtube,
      href: "https://www.youtube.com/@sungkargroup1",
      icon: "youtube",
    },
    {
      label: uiStrings.footer.facebook,
      href: "https://www.facebook.com/tourlomboks",
      icon: "facebook",
    },
    {
      label: uiStrings.footer.tiktok,
      href: "https://www.tiktok.com/@tour_lombok",
      icon: "tiktok",
    },
  ]}
  columns={[
    {
      title: uiStrings.footer.navigation,
      links: [
        { label: uiStrings.breadcrumb.tourPackages, href: "/paket-wisata" },
        { label: uiStrings.breadcrumb.accommodations, href: "/akomodasi" },
        { label: uiStrings.breadcrumb.carRental, href: "/sewa-mobil" },
        { label: uiStrings.breadcrumb.destinations, href: "/destinasi" },
        { label: uiStrings.breadcrumb.travelGuides, href: "/panduan-wisata" },
        { label: uiStrings.breadcrumb.blog, href: "/blog" },
      ],
    },
    {
      title: uiStrings.footer.destinations,
      links: [
        { label: "Lombok", href: "/destinasi" },
        { label: "Sumbawa", href: "/destinasi" },
        { label: "Labuan Bajo", href: "/destinasi" },
      ],
    },
    {
      title: uiStrings.footer.company,
      links: [
        { label: uiStrings.breadcrumb.faq, href: "/faq" },
        { label: uiStrings.breadcrumb.reviews, href: "/ulasan" },
        { label: uiStrings.breadcrumb.about, href: "/tentang-kami" },
        { label: uiStrings.breadcrumb.contact, href: "/kontak" },
      ],
    },
  ]}
  copyright={uiStrings.footer.copyright.replace("{year}", String(currentYear))}
  bottomLinks={[
    {
      label: uiStrings.footer.privacy,
      href: "/kebijakan-privasi",
    },
    {
      label: uiStrings.footer.terms,
      href: "/syarat-ketentuan",
    },
  ]}
/>

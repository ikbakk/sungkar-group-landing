---
import FooterBlock from "@/components/blocks/FooterBlock.astro"

const currentYear = new Date().getFullYear();
---

<FooterBlock
  brandName="Sungkar Group"
  brandHref="/"
  description="Operator wisata lokal untuk Lombok, Sumbawa, dan Labuan Bajo."
  socials={[
    {
      label: "Instagram",
      href: "https://www.instagram.com/",
      icon: "instagram",
    },
    {
      label: "YouTube",
      href: "https://www.youtube.com/",
      icon: "youtube",
    },
  ]}
  columns={[
    {
      title: "Navigasi",
      links: [
        { label: "Paket Wisata", href: "/paket-wisata" },
        { label: "Akomodasi", href: "/akomodasi" },
        { label: "Sewa Mobil", href: "/sewa-mobil" },
        { label: "Destinasi", href: "/destinasi" },
        { label: "Panduan Wisata", href: "/panduan-wisata" },
      ],
    },
    {
      title: "Destinasi",
      links: [
        { label: "Lombok", href: "/paket-wisata/lombok" },
        { label: "Sumbawa", href: "/paket-wisata/sumbawa" },
        { label: "Labuan Bajo", href: "/paket-wisata/labuan-bajo" },
      ],
    },
    {
      title: "Perusahaan",
      links: [
        { label: "Ulasan", href: "/ulasan" },
        { label: "Tentang Kami", href: "/tentang-kami" },
        { label: "Kontak", href: "/kontak" },
      ],
    },
  ]}
  copyright={`\u00A9 ${currentYear} Sungkar Group. All rights reserved.`}
  bottomLinks={[
    { label: "Kebijakan Privasi", href: "/" },
    { label: "Syarat & Ketentuan", href: "/" },
  ]}
/>

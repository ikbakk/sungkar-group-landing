---
import SectionContainer from "@/layouts/SectionContainer.astro";

interface RelatedItem {
  title: string;
  href: string;
  description: string;
}

interface Props {
  title: string;
  items: RelatedItem[];
  background?: string;
}

const { title, items, background = "bg-background" } = Astro.props;
---

<SectionContainer background={background} padding="py-16 lg:py-24">
  <div class="mb-12">
    <h2 class="font-heading text-3xl leading-tight text-foreground">
      {title}
    </h2>
  </div>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      items.map((item) => (
        <a
          href={item.href}
          class="group card-interactive p-6"
        >
          <h3 class="font-heading text-xl text-foreground group-hover:text-brand-600 transition-colors">
            {item.title}
          </h3>
          <p class="mt-2 text-sm leading-6 text-text-muted font-sans">
            {item.description}
          </p>
        </a>
      ))
    }
  </div>
</SectionContainer>

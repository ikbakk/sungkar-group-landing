---
interface RelatedItem {
  title: string;
  href: string;
  description?: string;
  icon?: string;
}

interface Props {
  title?: string;
  items: RelatedItem[];
}

const { title = "Konten Terkait", items } = Astro.props;
---

<section class="py-16 lg:py-24">
  <div class="container mx-auto px-4">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">
        {title}
      </h2>
      <p class="mt-2 text-muted-foreground">
        Jelajahi lebih lanjut untuk merencanakan perjalanan Anda
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => (
          <a
            href={item.href}
            class="group relative overflow-hidden rounded-lg border border-border bg-surface p-6 transition-all duration-300 hover:border-brand-500 hover:shadow-lg"
          >
            <div class="flex items-start gap-4">
              {item.icon && (
                <div class="text-3xl">{item.icon}</div>
              )}
              <div class="flex-1">
                <h3 class="font-semibold text-foreground group-hover:text-brand-600 transition-colors">
                  {item.title}
                </h3>
                {item.description && (
                  <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
                    {item.description}
                  </p>
                )}
              </div>
              <div class="text-xl text-muted-foreground group-hover:text-brand-600 transition-colors flex-shrink-0">
                →
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

---
import OptimizedImage from "@/components/ui/OptimizedImage.astro"
import type { ImageSource } from "@/lib/images"
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = Omit<HTMLAttributes<"img">, "src"> & {
  src?: ImageSource
  srcLight?: ImageSource
  srcDark?: ImageSource
}

const { class: className, src, srcLight, srcDark } = Astro.props

const baseClasses = "w-auto shrink-0 h-6 object-contain"
---

{
  srcLight && srcDark ? (
    <>
      <OptimizedImage
        class={cn(baseClasses, "dark:hidden", className)}
        data-slot="logo-image"
        src={srcLight}
        sizes="200px"
        widths={[200]}
      />
      <OptimizedImage
        class={cn(baseClasses, "hidden dark:block", className)}
        data-slot="logo-image"
        src={srcDark}
        sizes="200px"
        widths={[200]}
      />
    </>
  ) : src ? (
    <OptimizedImage
      class={cn(baseClasses, className)}
      data-slot="logo-image"
      src={src}
      sizes="200px"
      widths={[200]}
    />
  ) : null
}

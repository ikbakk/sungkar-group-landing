---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { isStringImage, type ImageSource } from "@/lib/images";

interface Props {
  src: ImageSource;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  style?: string;
  widths?: number[];
  sizes?: string;
  format?: "webp" | "avif";
  quality?: number;
  width?: number;
  height?: number;
}

const { src, alt, width, height, ...rest } = Astro.props;
---

{
  isStringImage(src) ? (
    <img
      src={src}
      alt={alt}
      class={rest.class}
      loading={rest.loading}
      decoding={rest.decoding}
      fetchpriority={rest.fetchpriority}
      style={rest.style}
      width={width}
      height={height}
    />
  ) : (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      class={rest.class}
      loading={rest.loading}
      decoding={rest.decoding}
      fetchpriority={rest.fetchpriority}
      style={rest.style}
      widths={rest.widths}
      sizes={rest.sizes}
      format={rest.format}
      quality={rest.quality}
      width={width}
      height={height}
    />
  )
}

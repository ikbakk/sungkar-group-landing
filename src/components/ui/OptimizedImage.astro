---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { isRemoteImage, type ImageSource } from "@/lib/images";

interface Props {
  src: ImageSource;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  style?: string;
  widths?: number[];
  sizes?: string;
  format?: "webp" | "avif";
  quality?: number;
  width?: number;
  height?: number;
}

const { src, alt, ...rest } = Astro.props;
---

{
  isRemoteImage(src) ? (
    <Image
      src={src}
      alt={alt}
      class={rest.class}
      loading={rest.loading}
      decoding={rest.decoding}
      fetchpriority={rest.fetchpriority}
      style={rest.style}
      width={rest.width}
      height={rest.height}
    />
  ) : (
    <Image src={src as ImageMetadata} alt={alt} {...rest} />
  )
}

---
import OptimizedImage from "@/components/ui/OptimizedImage.astro";
import type { ImageSource } from "@/lib/images";

import { cn } from "@/lib/utils";

type Props = {
  src: ImageSource | undefined | null;
  alt?: string;
  class?: string;
  width?: number;
  height?: number;
  sizes?: string;
  widths?: number[];
  loading?: "lazy" | "eager";
};

const {
  class: className,
  alt = "",
  width = 44,
  height = 44,
  sizes = "44px",
  widths = [44, 88, 176],
  ...props
} = Astro.props;
---

{
  props.src && (
    <OptimizedImage
      src={props.src}
      alt={alt}
      class={cn(
        "absolute inset-0 z-10 aspect-square size-full rounded-full object-cover",
        className,
      )}
      width={width}
      height={height}
      sizes={sizes}
      widths={widths}
    />
  )
}

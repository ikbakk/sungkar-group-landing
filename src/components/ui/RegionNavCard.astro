---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  title: string;
  items: { id: string; label: string; count: number }[];
}

const { title, items } = Astro.props as Props;
---

<Card class="border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]">
  <CardHeader>
    <CardTitle class="text-3xl leading-tight">{title}</CardTitle>
  </CardHeader>
  <CardContent class="grid gap-3">
    {
      items.map((item) => (
        <a
          href={`#${item.id}`}
          class="flex items-center justify-between rounded-2xl border border-border bg-surface-soft px-4 py-3 text-sm font-medium text-foreground transition-colors hover:border-brand-300 hover:bg-brand-50"
        >
          <span>{item.label}</span>
          <span class="rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-700">
            {item.count}
          </span>
        </a>
      ))
    }
  </CardContent>
</Card>

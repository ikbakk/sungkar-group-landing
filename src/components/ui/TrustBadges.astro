---
interface Props {
  rating?: number;
  reviewCount?: number;
  bookingCount?: number;
  yearsInBusiness?: number;
  class?: string;
}

const {
  rating = 4.9,
  reviewCount = 1200,
  bookingCount = 15000,
  yearsInBusiness = 10,
  class: className = "",
} = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.5;
---

<div class:list={["flex flex-wrap items-center gap-4 text-sm", className]}>
  <!-- Rating -->
  <div class="flex items-center gap-1.5">
    <div class="flex items-center gap-0.5">
      {
        Array.from({ length: 5 }).map((_, i) => (
          <svg
            class:list={[
              "h-4 w-4",
              i < fullStars
                ? "text-warm-500"
                : i === fullStars && hasHalf
                  ? "text-warm-500"
                  : "text-gray-300",
            ]}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))
      }
    </div>
    <span class="font-semibold text-foreground">{rating}</span>
    <span class="text-text-muted">({reviewCount.toLocaleString()} reviews)</span
    >
  </div>

  <span class="hidden h-4 w-px bg-border sm:block" aria-hidden="true"></span>

  <!-- Bookings -->
  <div class="flex items-center gap-1.5">
    <svg
      class="h-4 w-4 text-brand-500"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
      ></path>
    </svg>
    <span
      ><strong class="text-foreground">{bookingCount.toLocaleString()}+</strong> happy
      travelers</span
    >
  </div>

  <span class="hidden h-4 w-px bg-border sm:block" aria-hidden="true"></span>

  <!-- Years -->
  <div class="flex items-center gap-1.5">
    <svg
      class="h-4 w-4 text-brand-500"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
      ></path>
    </svg>
    <span
      ><strong class="text-foreground">{yearsInBusiness}</strong> years operating</span
    >
  </div>
</div>

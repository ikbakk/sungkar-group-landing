---
/**
 * Google Analytics 4 with Consent Mode v2 (main thread)
 *
 *  1. Consent defaults — sets all storage types to 'denied'
 *     synchronously before gtag.js loads.
 *  2. GA4 gtag.js — loads on the main thread so it has full access
 *     to cookies, dataLayer, and consent updates from CookieConsentBanner.
 *
 * The CookieConsentBanner React component in the <body> calls
 * dataLayer.push(['consent', 'update', {...}]) on the same main-thread
 * dataLayer, so GA4 sees consent changes immediately.
 *
 * Only enabled in production builds.
 * Override GA ID via PUBLIC_GA_ID env var.
 */

const gaId = import.meta.env.PUBLIC_GA_ID || "G-P3W4KT8E8L";
const isProduction = import.meta.env.PROD;

const consentDefaultScript = `
window.dataLayer = window.dataLayer || [];
window.dataLayer.push(['consent', 'default', {
  'ad_storage': 'denied',
  'ad_user_data': 'denied',
  'ad_personalization': 'denied',
  'analytics_storage': 'denied',
  'wait_for_update': 500
}]);
`;

const gtagInitScript = `
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaId}');
`;
---

{
  isProduction && gaId && (
    <>
      {/*
      Consent Mode v2 defaults — runs synchronously before gtag.js loads
      so consent is established before any tracking data is sent.
    */}
      <script is:inline set:html={consentDefaultScript} />

      {/* GA4 gtag.js — main thread */}
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
      />
      <script is:inline set:html={gtagInitScript} />
    </>
  )
}

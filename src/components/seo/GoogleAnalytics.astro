---
/**
 * Google Analytics 4 with Consent Mode v2 (via Partytown)
 *
 *  1. Consent defaults (main thread) — sets all storage types to 'denied'
 *     before any tracking runs. dataLayer.push is forwarded to the Partytown
 *     worker via the forward config in astro.config.mjs.
 *  2. GA4 gtag (Partytown worker) — the gtag.js library and init run
 *     off the main thread so page performance is not impacted.
 *
 * The CookieConsentBanner React component in the <body> calls
 * dataLayer.push(['consent', 'update', {...}]) when the user makes
 * a choice, which is forwarded to the worker and processed by GA4.
 *
 * Only enabled in production builds.
 * Override GA ID via PUBLIC_GA_ID env var.
 */

const gaId = import.meta.env.PUBLIC_GA_ID || "G-P3W4KT8E8L";
const isProduction = import.meta.env.PROD;

const gtagInitScript = `
window.dataLayer = window.dataLayer || [];
function gtag() { dataLayer.push(arguments); }
gtag("js", new Date());
gtag("config", "${gaId}");
`;
---

{isProduction && gaId && (
  <>
    {/*
      Consent Mode v2 defaults — runs on the main thread (NOT Partytown)
      so consent is established synchronously before any tracking library
      loads in the Partytown worker. dataLayer.push is forwarded to the
      worker via Partytown's forward config.
    */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(['consent', 'default', {
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'analytics_storage': 'denied',
        'wait_for_update': 500
      }]);
    </script>

    {/*
      GA4 gtag.js loaded in the Partytown worker
    */}
    <script
      is:inline
      type="text/partytown"
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
    />
    <script is:inline type="text/partytown" set:html={gtagInitScript} />
  </>
)}

---
/**
 * Microsoft Clarity tracking code.
 *
 * Only enabled in production builds.
 * Override Clarity project ID via PUBLIC_CLARITY_ID env var.
 */

const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "xe8dag91o2";
const isProduction = import.meta.env.PROD;

const clarityScript = `
(function(w,d,id){
  var storageKey = "sg-cookie-consent";
  var loaded = false;

  function hasAnalyticsConsent() {
    try {
      var raw = w.localStorage && w.localStorage.getItem(storageKey);
      if (!raw) return false;
      var consent = JSON.parse(raw);
      return consent && consent.analytics_storage === "granted";
    } catch (error) {
      return false;
    }
  }

  function loadClarity() {
    if (loaded || !hasAnalyticsConsent()) return;
    loaded = true;
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      c[a]("consent", true);
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(w, d, "clarity", "script", id);
  }

  w.addEventListener("sg:cookie-consent", function(event) {
    if (event.detail && event.detail.analytics_storage === "granted") {
      loadClarity();
    } else if (typeof w.clarity === "function") {
      w.clarity("consent", false);
    }
  });

  loadClarity();
})(window, document, "${clarityId}");
`;
---

{isProduction && clarityId && <script is:inline set:html={clarityScript} />}

---
/**
 * Microsoft Clarity tracking code.
 *
 * Only enabled in production builds.
 * Override Clarity project ID via PUBLIC_CLARITY_ID env var.
 */

const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "xe8dag91o2";
const isProduction = import.meta.env.PROD;

const clarityScript = `
(function(c,l,a,r,i,t,y){
  c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
  t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
  y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
})(window, document, "clarity", "script", "${clarityId}");
`;
---

{isProduction && clarityId && <script is:inline set:html={clarityScript} />}

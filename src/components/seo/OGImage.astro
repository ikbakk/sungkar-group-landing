---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  /**
   * The image asset to use for OG
   */
  image: ImageMetadata;

  /**
   * Alt text for accessibility and fallback
   */
  alt: string;

  /**
   * Optional CSS classes for styling
   */
  class?: string;

  /**
   * Optional width for the image
   * Defaults to 1200px for OG standard
   */
  width?: number;

  /**
   * Optional height for the image
   * Defaults to 630px for OG standard
   */
  height?: number;

  /**
   * Whether to apply loading="lazy"
   * Defaults to false for OG images (should be eager)
   */
  loading?: "lazy" | "eager";
}

const {
  image,
  alt,
  class: className,
  width = 1200,
  height = 630,
  loading = "eager",
} = Astro.props;
---

<Image
  src={image}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  class={className}
  format="webp"
  quality={80}
/>

---
import type { ImageSource } from "@/lib/images";
import { getImageWidth, getImageHeight } from "@/lib/images";
import { SITE_URL } from "@/lib/site-config";
import { t } from "@/lib/i18n";
import { LOCALES } from "@/lib/i18n";
import { appendTrailingSlash, normalizeMetaDescription } from "@/lib/seo";

interface Props {
  title: string;
  description: string;

  canonical?: string;

  ogImage?: ImageSource;

  ogImageAlt?: string;

  ogType?: "website" | "article" | "profile";

  twitterCard?: "summary" | "summary_large_image";

  noIndex?: boolean;

  locale?: string;
}

const {
  title,
  description,

  canonical,

  ogImage,

  ogImageAlt = "Sungkar Group",

  ogType = "website",

  twitterCard: twitterCardOverride,

  noIndex = false,

  locale = "id",
} = Astro.props as Props;

const pageTitle = title.includes("Sungkar Group")
  ? title
  : `${title} | Sungkar Group`;

const canonicalPath = canonical ?? Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath, SITE_URL);
canonicalUrl.pathname = appendTrailingSlash(canonicalUrl.pathname);

const canonicalHref = canonicalUrl.toString();

const ogImageUrl = ogImage
  ? typeof ogImage === "string"
    ? ogImage
    : new URL(ogImage.src, SITE_URL).toString()
  : undefined;

const ogImageWidth = ogImage ? getImageWidth(ogImage) : undefined;

const ogImageHeight = ogImage ? getImageHeight(ogImage) : undefined;

const twitterCard =
  twitterCardOverride || (ogImageUrl ? "summary_large_image" : "summary");

const localeMap: Record<string, string> = {
  id: "id_ID",
  en: "en_US",
  ar: "ar_SA",
  ms: "ms_MY",
  zh: "zh_CN",
};

const ogLocale = localeMap[locale] || "id_ID";

const uiStrings = t(locale);
const metaDescription = normalizeMetaDescription(description);

const canonicalPathname = canonicalUrl.pathname;
const basePath =
  locale === "id"
    ? canonicalPathname
    : canonicalPathname.replace(new RegExp("^/" + locale), "") || "/";
const defaultUrl = new URL(basePath, SITE_URL).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>

<meta name="description" content={metaDescription} />
<meta name="msvalidate.01" content="66ABB4CFD3A0A8EF2007323324E7BD3D" />

<link rel="canonical" href={canonicalHref} />

<link rel="alternate" href={canonicalHref} hreflang={locale} />
<link rel="alternate" href={defaultUrl} hreflang="x-default" />
{
  LOCALES.filter((l) => l !== locale).map((l) => {
    const altUrl =
      l === "id"
        ? defaultUrl
        : new URL(`/${l}${basePath}`, SITE_URL).toString();
    return <link rel="alternate" href={altUrl} hreflang={l} />;
  })
}

<meta name="robots" content={noIndex ? "noindex,nofollow" : "index,follow"} />

<meta name="keywords" content={uiStrings.seo.keywords} />

<meta name="theme-color" content="#0f766e" />

<!-- Open Graph -->

<meta property="og:locale" content={ogLocale} />
<meta property="og:type" content={ogType} />

<meta property="og:site_name" content={uiStrings.seo.siteName} />

<meta property="og:title" content={pageTitle} />

<meta property="og:description" content={metaDescription} />

<meta property="og:url" content={canonicalHref} />

{
  ogImage && ogImageUrl && (
    <>
      <meta property="og:image" content={ogImageUrl} />

      {ogImageWidth && (
        <meta property="og:image:width" content={String(ogImageWidth)} />
      )}

      {ogImageHeight && (
        <meta property="og:image:height" content={String(ogImageHeight)} />
      )}

      <meta property="og:image:alt" content={ogImageAlt} />
    </>
  )
}

<!-- Twitter -->

<meta name="twitter:card" content={twitterCard} />

<meta name="twitter:title" content={pageTitle} />

<meta name="twitter:description" content={metaDescription} />

{
  ogImageUrl && (
    <>
      <meta name="twitter:image" content={ogImageUrl} />

      <meta name="twitter:image:alt" content={ogImageAlt} />
    </>
  )
}

<!-- Mobile -->

<meta name="apple-mobile-web-app-capable" content="yes" />

<meta
  name="apple-mobile-web-app-status-bar-style"
  content="black-translucent"
/>

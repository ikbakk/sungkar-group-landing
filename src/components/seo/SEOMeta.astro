---
import type { ImageMetadata } from "astro";

interface Props {
  /**
   * Page title (will be combined with site name if not already)
   */
  title: string;

  /**
   * Page description for meta tag
   */
  description: string;

  /**
   * Canonical URL for the page
   */
  canonical?: string;

  /**
   * OG image metadata from Astro
   */
  ogImage?: ImageMetadata;

  /**
   * Alt text for OG image
   */
  ogImageAlt?: string;

  /**
   * Page type for og:type
   */
  ogType?: "website" | "article" | "profile";

  /**
   * Twitter card type
   */
  twitterCard?: "summary" | "summary_large_image";

  /**
   * Whether to prevent indexing
   */
  noIndex?: boolean;

  /**
   * Site URL for generating absolute OG image URL
   */
  siteUrl?: string;

  /**
   * Locale for og:locale
   */
  locale?: string;
}

interface OGImageUrl {
  url: string;
  width: number;
  height: number;
  type: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogImageAlt = "Sungkar Group",
  ogType = "website",
  twitterCard: twitterCardType,
  noIndex = false,
  siteUrl = "https://sungkargroup.com",
  locale = "id_ID",
} = Astro.props;

const siteTitle =
  title === "Sungkar Group" ? title : `${title} | Sungkar Group`;

// Generate OG image URL from metadata
let ogImageUrl: OGImageUrl | null = null;
if (ogImage) {
  const imageUrl = `${siteUrl}${ogImage.src}`;
  ogImageUrl = {
    url: imageUrl,
    width: ogImage.width,
    height: ogImage.height,
    type: "image/webp",
  };
}

// Determine twitter card type
const twitterCard = twitterCardType || (ogImageUrl ? "summary_large_image" : "summary");
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Standard Meta Tags -->
<title>{siteTitle}</title>
<meta name="description" content={description} />
{canonical && <link rel="canonical" href={canonical} />}
{noIndex && <meta name="robots" content="noindex, nofollow" />}

<!-- OpenGraph Meta Tags -->
<meta property="og:locale" content={locale} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Sungkar Group" />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical || Astro.url} />
{
  ogImageUrl && (
    <>
      <meta property="og:image" content={ogImageUrl.url} />
      <meta property="og:image:width" content={String(ogImageUrl.width)} />
      <meta property="og:image:height" content={String(ogImageUrl.height)} />
      <meta property="og:image:type" content={ogImageUrl.type} />
      <meta property="og:image:alt" content={ogImageAlt} />
    </>
  )
}

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl.url} />}
{ogImageUrl && <meta name="twitter:image:alt" content={ogImageAlt} />}

<!-- Additional SEO Meta Tags -->
<meta name="theme-color" content="#0f766e" />
<meta name="apple-mobile-web-app-capable" content="true" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

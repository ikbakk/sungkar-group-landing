---
import HeroSection from "./HeroSection.astro";
import VideoSection from "./VideoSection.astro";
import FeaturedSection from "./FeaturedSection.astro";
import DestinationsSection from "./DestinationsSection.astro";
import TransportSection from "./TransportSection.astro";
import Reviews5Block from "@/components/blocks/reviews-5.astro";
import type { LandingAction, LandingHeroCard, LandingTourCard, LandingDestinationCard, LandingTransportCard } from "@/lib/content/landing";
import type { ImageSource } from "@/lib/images";

interface Props {
  locale?: string;
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    primaryAction: LandingAction;
    secondaryAction: LandingAction;
    cards: LandingHeroCard[];
  };
  featuredTours: {
    eyebrow: string;
    title: string;
    description: string;
    tours: LandingTourCard[];
    heroImage: ImageSource;
  };
  destinations: {
    eyebrow: string;
    title: string;
    description: string;
    destinations: LandingDestinationCard[];
  };
  transport: {
    eyebrow: string;
    title: string;
    description: string;
    services: LandingTransportCard[];
  };
  testimonials: any;
  video: any;
  backgroundImage: any;
}

const {
  locale = "id",
  hero,
  featuredTours,
  destinations,
  transport,
  testimonials,
  video,
  backgroundImage,
} = Astro.props;
---

<HeroSection
  eyebrow={hero.eyebrow}
  title={hero.title}
  description={hero.description}
  primaryAction={hero.primaryAction}
  secondaryAction={hero.secondaryAction}
  image={backgroundImage}
/>
<FeaturedSection
  eyebrow={featuredTours.eyebrow}
  title={featuredTours.title}
  description={featuredTours.description}
  featuredTours={featuredTours.tours}
  image={featuredTours.heroImage}
/>
<DestinationsSection
  class="bg-surface-soft"
  locale={locale}
  eyebrow={destinations.eyebrow}
  title={destinations.title}
  description={destinations.description}
  destinations={destinations.destinations}
/>
<Reviews5Block
  eyebrow={testimonials.eyebrow}
  title={testimonials.title}
  description={testimonials.description}
  alignment="center"
  reviews={testimonials.testimonials}
/>
<TransportSection
  class="bg-surface-soft"
  eyebrow={transport.eyebrow}
  title={transport.title}
  services={transport.services}
  alignment="right"
/>
<VideoSection
  eyebrow={video.eyebrow}
  title={video.title}
  description={video.description}
  ctaLabel={video.ctaLabel}
  ctaHref={video.ctaHref}
  embedUrl={video.embedUrl}
  alignment="left"
/>

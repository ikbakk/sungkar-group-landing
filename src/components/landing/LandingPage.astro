---
import HeroSection from "./HeroSection.astro";
import VideoSection from "./VideoSection.astro";
import FeaturedSection from "./FeaturedSection.astro";
import DestinationsSection from "./DestinationsSection.astro";
import TransportSection from "./TransportSection.astro";
import Reviews5Block from "@/components/blocks/reviews-5.astro";

import {
  landingHero,
  landingFeaturedTours,
  landingDestinations,
  landingTransport,
  landingTestimonials,
  landingVideo,
  landingBackgroundImage,
} from "@/lib/content/landing";
---

<HeroSection
  eyebrow={landingHero.eyebrow}
  title={landingHero.title}
  description={landingHero.description}
  primaryAction={landingHero.primaryAction}
  secondaryAction={landingHero.secondaryAction}
  image={landingBackgroundImage}
/>
<FeaturedSection
  eyebrow={landingFeaturedTours.eyebrow}
  title={landingFeaturedTours.title}
  description={landingFeaturedTours.description}
  featuredTours={landingFeaturedTours.tours}
  image={landingFeaturedTours.heroImage}
/>
<DestinationsSection
  class="bg-surface-soft"
  eyebrow={landingDestinations.eyebrow}
  title={landingDestinations.title}
  description={landingDestinations.description}
  destinations={landingDestinations.destinations}
/>
<Reviews5Block
  eyebrow={landingTestimonials.eyebrow}
  title={landingTestimonials.title}
  description={landingTestimonials.description}
  alignment="center"
  reviews={landingTestimonials.testimonials}
/>
<TransportSection
  class="bg-surface-soft"
  eyebrow={landingTransport.eyebrow}
  title={landingTransport.title}
  services={landingTransport.services}
  alignment="right"
/>
<VideoSection
  eyebrow={landingVideo.eyebrow}
  title={landingVideo.title}
  description={landingVideo.description}
  ctaLabel={landingVideo.ctaLabel}
  ctaHref={landingVideo.ctaHref}
  embedUrl={landingVideo.embedUrl}
  alignment="left"
/>

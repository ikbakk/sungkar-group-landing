---
import { Image } from "astro:assets";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import type { ImageMetadata } from "astro";
import type { LandingTourCard as FeaturedTour } from "@/lib/content/landing";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  featuredTours: FeaturedTour[];
  image: ImageMetadata;
}

const { eyebrow, title, description, featuredTours, image } =
  Astro.props as Props;
---

<section class="bg-white">
  <div class="section-container section-padding">
    <div class="grid-featured">
      <div class="order-2 flex lg:order-1">
        <div
          class="w-full overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
        >
          <Image
            src={image}
            alt="Paket wisata unggulan Sungkar Group"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div
        class="order-1 flex flex-col justify-center lg:order-2 lg:text-right"
      >
        <p class="section-eyebrow">
          {eyebrow}
        </p>
        <h2 class="section-title">
          {title}
        </h2>
        <p class="mt-5 ml-auto max-w-xl text-base leading-8 text-text-muted">
          {description}
        </p>

        <div class="mt-8 grid auto-rows-max gap-4 sm:grid-cols-2">
          {
            featuredTours.map((tour) => (
              <a
                href={`/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`}
                class="group block"
              >
                <Card
                  className="
                    h-full
                    transition-all
                    hover:-translate-y-1
                    hover:border-brand-200
                    hover:bg-brand-50
                    hover:shadow-lg
                  "
                >
                  <CardHeader className="gap-3">
                    <div class="flex flex-wrap gap-2">
                      {tour.region && (
                        <Badge variant="outline">{tour.region}</Badge>
                      )}

                      {tour.duration && (
                        <Badge variant="secondary">{tour.duration}</Badge>
                      )}
                    </div>

                    <CardTitle className="line-clamp-2 text-xl leading-tight">
                      {tour.title}
                    </CardTitle>
                  </CardHeader>

                  <CardContent>
                    <div class="relative">
                      <p
                        class="
                          line-clamp-4
                          text-sm
                          leading-7
                          text-text-muted
                        "
                      >
                        {tour.description}
                      </p>

                      <div
                        class="
                          pointer-events-none
                          absolute
                          bottom-0
                          left-0
                          h-8
                          w-full
                          bg-gradient-to-t
                          from-background
                          to-transparent
                        "
                      />
                    </div>
                  </CardContent>
                </Card>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

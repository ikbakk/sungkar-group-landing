---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface FeaturedTour {
  slug: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  featuredTours: FeaturedTour[];
  image: ImageMetadata;
}

const { eyebrow, title, description, featuredTours, image } =
  Astro.props as Props;
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-stretch">
      <div class="order-2 flex lg:order-1">
        <div
          class="w-full overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
        >
          <Image
            src={image}
            alt="Tur snorkeling Lombok"
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
      </div>
      <div
        class="order-1 flex flex-col justify-center lg:order-2 lg:text-right"
      >
        <p
          class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
        >
          {eyebrow}
        </p>
        <h2
          class="mt-4 font-heading text-4xl leading-tight tracking-[-0.02em] text-foreground sm:text-5xl"
        >
          {title}
        </h2>
        <p class="mt-5 ml-auto max-w-xl text-base leading-8 text-text-muted">
          {description}
        </p>

        <div class="mt-8 grid auto-rows-max gap-4 sm:grid-cols-2">
          {
            featuredTours.map((tour, index) => (
              <a
                href={`/paket-wisata/${tour.slug}`}
                class={
                  index === 0
                    ? "rounded-[1.75rem] border border-border bg-surface-soft p-5 text-left transition-colors hover:border-brand-200 hover:bg-brand-50"
                    : "rounded-[1.75rem] border border-border bg-white p-5 text-left transition-colors hover:border-brand-200 hover:bg-brand-50"
                }
              >
                <div class="font-heading text-2xl leading-tight text-foreground">
                  {tour.title}
                </div>
                <p class="mt-3 text-sm leading-7 text-text-muted">
                  {tour.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

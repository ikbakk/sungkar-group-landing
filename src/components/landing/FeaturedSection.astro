---
import Services6Block from "@/components/blocks/services-6.astro";
import type { ImageSource } from "@/lib/images";
import type { LandingTourCard as FeaturedTour } from "@/lib/content/landing";

interface Props {
  class?: string;
  eyebrow: string;
  title: string;
  description: string;
  featuredTours: FeaturedTour[];
  image: ImageSource;
}

const { class: className, eyebrow, title, description, featuredTours } = Astro.props as Props;
---

<Services6Block
  class={className}
  eyebrow={eyebrow}
  title={title}
  description={description}
  alignment="left"
  services={featuredTours.slice(0, 4).map((tour) => ({
    image: { src: tour.image, alt: tour.title },
    title: tour.title,
    description: tour.description,
    href: `/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`,
  }))}
/>

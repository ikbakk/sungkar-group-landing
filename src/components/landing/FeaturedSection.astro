---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { LandingTourCard as FeaturedTour } from "@/lib/content/landing";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  featuredTours: FeaturedTour[];
  image: ImageMetadata;
}

const { eyebrow, title, description, featuredTours, image } =
  Astro.props as Props;
---

<section class="bg-white">
  <div class="section-container section-padding">
    <div class="grid-featured">
      <div class="order-2 flex lg:order-1">
        <div
          class="w-full overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
        >
          <Image
            src={image}
            alt="Paket wisata unggulan Sungkar Group"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div
        class="order-1 flex flex-col justify-center lg:order-2 lg:text-right"
      >
        <p class="section-eyebrow">
          {eyebrow}
        </p>
        <h2 class="section-title">
          {title}
        </h2>
        <p class="mt-5 ml-auto max-w-xl text-base leading-8 text-text-muted">
          {description}
        </p>

        <div class="mt-8 grid auto-rows-max gap-4 sm:grid-cols-2">
          {
            featuredTours.map((tour, index) => (
              <a
                href={`/paket-wisata/${tour.region}/${tour.collectionSlug}/${tour.slug}`}
                class:list={[
                  "section-card",
                  "p-5 text-left transition-colors hover:border-brand-200 hover:bg-brand-50",
                  index === 0 ? "bg-surface-soft" : "bg-white",
                ]}
              >
                <div class="font-heading text-2xl leading-tight text-foreground">
                  {tour.title}
                </div>
                <p class="mt-3 text-sm leading-7 text-text-muted">
                  {tour.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

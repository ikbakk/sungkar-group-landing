---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  alignment?: "left" | "center";
  light?: boolean;
  className?: string;
}

const { 
  eyebrow, 
  title, 
  description, 
  alignment = "left",
  light = false,
  className = ""
} = Astro.props;
---

<div class:list={[
  "section-header",
  alignment === "center" && "text-center",
  className
]}>
  <p class:list={[
    light ? "section-eyebrow-light" : "section-eyebrow"
  ]}>
    {eyebrow}
  </p>
  
  <h2 class:list={[
    light ? "section-title-light" : "section-title"
  ]}>
    {title}
  </h2>
  
  {description && (
    <p class:list={[
      alignment === "center" ? "mx-auto mt-6 max-w-2xl" : "mt-5 max-w-xl",
      light ? "section-description-light" : "section-description"
    ]}>
      {description}
    </p>
  )}
</div>

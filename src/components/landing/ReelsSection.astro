---
import { cn } from "@/lib/utils";
import { Section, SectionContainer } from "@/components/ui/section";

interface ReelItem {
  url: string;
}

interface Props {
  class?: string;
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  reels: ReelItem[];
}

const {
  class: className,
  eyebrow,
  title,
  description,
  ctaLabel,
  ctaHref,
  reels,
} = Astro.props;
---

<Section class={cn("section-padding bg-surface-soft", className)}>
  <SectionContainer class="grid gap-12 lg:grid-cols-2">
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-4">
        <p class="section-eyebrow w-fit">{eyebrow}</p>
        <h2 class="section-title">{title}</h2>
        <p class="section-description text-balance">{description}</p>
      </div>
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-magnetic-primary w-fit"
      >
        {ctaLabel}
        <span class="btn-icon-circle">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17L17 7"></path>
            <path d="M7 7h10v10"></path>
          </svg>
        </span>
      </a>
    </div>
    <div class="reels-masonry columns-1 gap-3 sm:columns-2 sm:gap-4">
      {
        reels.map((reel) => (
          <div
            class="mb-3 w-full break-inside-avoid overflow-hidden rounded-[1.25rem] ring-1 ring-black/[0.04] sm:mb-4"
          >
            <blockquote
              class="instagram-media"
              data-instgrm-captioned
              data-instgrm-permalink={reel.url}
              data-instgrm-version="14"
              style="background:#FFF;border:0;border-radius:3px;box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15);margin:1px;max-width:658px;min-width:326px;padding:0;width:99.375%;width:-webkit-calc(100% - 2px);width:calc(100% - 2px);"
            >
              <a
                href={reel.url}
                target="_blank"
                rel="noopener noreferrer"
                style="background:#FFFFFF;line-height:0;padding:0 0;text-align:center;text-decoration:none;width:100%;display:block;"
              >
                View on Instagram
              </a>
            </blockquote>
          </div>
        ))
      }
    </div>
  </SectionContainer>
</Section>

<script is:inline>
  (function () {
    var processEmbeds = function () {
      if (typeof window !== "undefined" && window.instgrm && window.instgrm.Embeds) {
        try {
          window.instgrm.Embeds.process();
        } catch (_) {}
      }
    };

    if (typeof window !== "undefined" && window.instgrm && window.instgrm.Embeds) {
      processEmbeds();
      return;
    }

    var existing = document.querySelector('script[src*="instagram.com/embed.js"],script[src*="iframely.net/files/instagram_embed.js"]');
    if (existing) {
      existing.addEventListener("load", processEmbeds, { once: true });
      window.setTimeout(processEmbeds, 800);
      return;
    }

    var s = document.createElement("script");
    s.async = true;
    s.src = "https://www.instagram.com/embed.js";
    s.onload = processEmbeds;
    s.onerror = function () {
      var fallback = document.createElement("script");
      fallback.async = true;
      fallback.src = "https://iframely.net/files/instagram_embed.js";
      fallback.onload = processEmbeds;
      document.body.appendChild(fallback);
    };
    document.body.appendChild(s);
  })();
</script>

<style is:global>
  .reels-masonry .instagram-media,
  .reels-masonry .instagram-media-rendered {
    width: 100% !important;
    min-width: 0 !important;
    max-width: 100% !important;
    margin: 0 !important;
  }
</style>

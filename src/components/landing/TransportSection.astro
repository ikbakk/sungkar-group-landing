---
import Services5Block from "@/components/blocks/services-5.astro";

interface TransportService {
  title: string;
  description: string;
}

interface Props {
  class?: string;
  locale?: string;
  eyebrow: string;
  title: string;
  services: TransportService[];
  alignment?: "left" | "center" | "right";
}

const {
  class: className,
  locale = "id",
  eyebrow,
  title,
  services,
  alignment = "right",
} = Astro.props as Props;
---

<Services5Block
  class={className}
  locale={locale}
  eyebrow={eyebrow}
  title={title}
  alignment={alignment}
  services={services.map((s) => ({
    icon: s.title.toLowerCase().includes("antar-jemput") ? "plane" : "car",
    title: s.title,
    description: s.description,
  }))}
/>

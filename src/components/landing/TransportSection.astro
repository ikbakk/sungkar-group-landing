---
const { } = Astro.props;
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr] lg:items-center">
      <div>
        <p
          class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
        >
          Transportasi
        </p>
        <h2
          class="mt-4 max-w-2xl font-heading text-4xl leading-tight tracking-[-0.02em] text-foreground sm:text-5xl"
        >
          Transportasi yang rapi untuk transfer dan perjalanan harian
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-[1.5rem] border border-border bg-surface-soft p-6">
          <div class="font-heading text-2xl leading-tight text-foreground">
            Antar-jemput bandara
          </div>
          <p class="mt-3 text-sm leading-7 text-text-muted">
            Cocok untuk kedatangan pagi atau malam dengan koordinasi yang
            sederhana.
          </p>
        </div>
        <div class="rounded-[1.5rem] border border-border bg-white p-6">
          <div class="font-heading text-2xl leading-tight text-foreground">
            Driver harian
          </div>
          <p class="mt-3 text-sm leading-7 text-text-muted">
            Fleksibel untuk tamu yang ingin menyesuaikan urutan destinasi.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface DestinationCard {
  title: string;
  description: string;
  image: ImageMetadata;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  destinations: DestinationCard[];
}

const { eyebrow, title, description, destinations } = Astro.props as Props;
---

<section class="border-y border-border bg-surface-soft">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <p
          class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
        >
          {eyebrow}
        </p>
        <h2
          class="mt-4 font-heading text-4xl leading-tight tracking-[-0.02em] text-foreground sm:text-5xl"
        >
          {title}
        </h2>
      </div>
      <p class="max-w-2xl text-base leading-8 text-text-muted">
        {description}
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        destinations.map((destination, index) => (
          <article
            class={
              index % 2 === 0
                ? "overflow-hidden rounded-[1.75rem] border border-border bg-white shadow-[0_16px_45px_rgba(17,24,39,0.05)]"
                : "overflow-hidden rounded-[1.75rem] border border-border bg-surface-soft shadow-[0_16px_45px_rgba(17,24,39,0.05)]"
            }
          >
            <div class="aspect-4/3 overflow-hidden">
              <Image
                src={destination.image}
                alt={destination.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <div class="text-xs font-medium uppercase tracking-[0.22em] text-brand-700">
                {destination.title}
              </div>
              <p class="mt-2 text-sm leading-7 text-text-muted">
                {destination.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
import Features1Block from "@/components/blocks/features-1.astro";
import type { ImageMetadata } from "astro";

interface DestinationCard {
  title: string;
  description: string;
  image: ImageMetadata;
  slug: string;
}

interface Props {
  class?: string;
  eyebrow: string;
  title: string;
  description: string;
  destinations: DestinationCard[];
}

const { class: className, eyebrow, title, description, destinations } = Astro.props as Props;

const icons = [
  "map-pin",
  "waves",
  "mountain",
  "compass",
];
---

<Features1Block
  class={className}
  eyebrow={eyebrow}
  title={title}
  description={description}
  alignment="right"
  features={destinations.slice(0, 4).map((d, i) => ({
    icon: icons[i] ?? "map-pin",
    title: d.title,
    description: d.description,
    href: `/destinasi/${d.slug}`,
    linkText: "Jelajahi",
  }))}
/>

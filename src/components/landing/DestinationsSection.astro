---
import Features1Block from "@/components/blocks/features-1.astro";
import type { ImageSource } from "@/lib/images";
import { localizeHref } from "@/lib/i18n/localize";

interface DestinationCard {
  title: string;
  description: string;
  image: ImageSource;
  slug: string;
}

interface Props {
  class?: string;
  locale?: string;
  eyebrow: string;
  title: string;
  description: string;
  destinations: DestinationCard[];
  linkText?: string;
}

const { class: className, locale = "id", eyebrow, title, description, destinations, linkText = "Jelajahi" } = Astro.props as Props;

const icons = [
  "map-pin",
  "waves",
  "mountain",
  "compass",
];
---

<Features1Block
  class={className}
  eyebrow={eyebrow}
  title={title}
  description={description}
  alignment="right"
  features={destinations.slice(0, 4).map((d, i) => ({
    icon: icons[i] ?? "map-pin",
    title: d.title,
    description: d.description,
    href: localizeHref(`/destinasi/${d.slug}`, locale),
    linkText,
  }))}
/>

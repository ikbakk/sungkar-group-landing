---
import SectionContainer from "@/layouts/SectionContainer.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  embedUrl: string;
}

const { eyebrow, title, description, ctaLabel, ctaHref, embedUrl } =
  Astro.props;
---

<SectionContainer background="bg-surface-soft">
  <div class="section-container section-padding">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="section-eyebrow">
          {eyebrow}
        </p>

        <h2 class="section-title">
          {title}
        </h2>

        <p class="section-description">
          {description}
        </p>

        <a
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex text-sm font-medium text-brand-700 underline underline-offset-4"
        >
          {ctaLabel}
        </a>
      </div>

      <div
        class="overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
      >
        <div class="aspect-video">
          <iframe
            src={embedUrl}
            class="h-full w-full"
            title="Video Sungkar Group"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</SectionContainer>

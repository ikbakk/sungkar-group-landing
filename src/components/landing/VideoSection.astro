---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  panelEyebrow: string;
  panelTitle: string;
  panelDescription: string;
}

const {
  eyebrow,
  title,
  description,
  ctaLabel,
  ctaHref,
  panelEyebrow,
  panelTitle,
  panelDescription,
} = Astro.props as Props;
---

<section class="bg-surface-soft">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p
          class="text-sm font-medium uppercase tracking-[0.28em] text-brand-700"
        >
          {eyebrow}
        </p>
        <h2
          class="mt-4 max-w-2xl font-heading text-4xl leading-tight tracking-[-0.02em] text-foreground sm:text-5xl"
        >
          {title}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-8 text-text-muted">
          {description}
        </p>
        <a
          href={ctaHref}
          class="mt-6 inline-flex text-sm font-medium text-brand-700 underline underline-offset-4 hover:text-brand-800"
        >
          {ctaLabel}
        </a>
      </div>

      <div
        class="overflow-hidden rounded-[2rem] border border-border bg-white shadow-[0_18px_45px_rgba(17,24,39,0.05)]"
      >
        <div class="aspect-video bg-brand-900 p-4 sm:p-6">
          <div
            class="flex h-full w-full flex-col justify-between rounded-[1.5rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08)_0%,rgba(255,255,255,0.03)_100%)] p-6 text-white"
          >
            <div
              class="text-xs font-medium uppercase tracking-[0.28em] text-brand-200"
            >
              {panelEyebrow}
            </div>
            <div>
              <div class="font-heading text-3xl leading-tight">
                {panelTitle}
              </div>
              <p class="mt-3 max-w-xl text-sm leading-7 text-brand-100">
                {panelDescription}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

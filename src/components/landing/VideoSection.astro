---
import { TypographyH2 } from "@/components/ui/typography";
import { cn } from "@/lib/utils";
import { Section, SectionContainer } from "@/components/ui/section";

interface Props {
  class?: string;
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  embedUrl: string;
  alignment?: "left" | "center" | "right";
}

const {
  class: className,
  eyebrow,
  title,
  description,
  ctaLabel,
  ctaHref,
  embedUrl = "left",
} = Astro.props;
---

<Section class={cn("section-padding", className)}>
  <SectionContainer class="grid gap-12 lg:grid-cols-2 lg:items-center">
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-4">
        <p class="section-eyebrow w-fit">{eyebrow}</p>
        <TypographyH2 class="section-title">
          {title}
        </TypographyH2>
        <p class="section-description text-balance">
          {description}
        </p>
      </div>
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-magnetic-primary w-fit"
      >
        {ctaLabel}
        <span class="btn-icon-circle">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17L17 7"></path><path d="M7 7h10v10"></path>
          </svg>
        </span>
      </a>
    </div>
    <div class="double-bezel">
      <div class="double-bezel-inner aspect-4/3 w-full overflow-hidden">
        <iframe
          src={embedUrl}
          class="h-full w-full"
          title={title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen></iframe>
      </div>
    </div>
  </SectionContainer>
</Section>

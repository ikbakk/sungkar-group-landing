---
interface Testimonial {
  name: string;
  title: string;
  content: string;
  rating: number;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  testimonials: Testimonial[];
}

const { eyebrow, title, description, testimonials } = Astro.props as Props;
---

<section class="bg-surface-soft py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center lg:mb-16">
      <p
        class="text-sm font-medium uppercase tracking-[0.28em]"
        style="color: var(--color-brand-700);"
      >
        {eyebrow}
      </p>
      <h2
        class="mt-4 font-heading text-4xl leading-tight tracking-[-0.02em] text-foreground sm:text-5xl"
      >
        {title}
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-text-muted">
        {description}
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((testimonial) => (
          <div class="card-interactive p-6 sm:p-8">
            <div class="flex gap-1">
              {Array(testimonial.rating)
                .fill(0)
                .map(() => (
                  <svg
                    class="h-5 w-5"
                    style="color: var(--color-brand-600);"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
            </div>

            <p class="mt-5 text-base leading-7 text-foreground">
              "{testimonial.content}"
            </p>

            <div class="mt-6 border-t border-border pt-6">
              <p class="font-medium text-foreground">{testimonial.name}</p>
              <p class="text-sm text-text-muted">{testimonial.title}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
import { Image } from "astro:assets";
const { Hero, HeroLombok, highlights } = Astro.props;
---

<section id="beranda" class="relative pt-20 overflow-hidden bg-background">
  <div class="absolute inset-0">
    <Image
      src={Hero}
      alt="Pemandangan Lombok saat matahari terbit"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.08)_0%,rgba(255,255,255,0.22)_34%,rgba(255,255,255,0.88)_100%)]"
    >
    </div>
  </div>

  <div
    class="relative mx-auto grid max-w-7xl grid-cols-1 gap-12 px-4 pb-16 pt-16 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:pb-24 lg:pt-20"
  >
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.28em] text-brand-800">
        Sungkar Group
      </p>
      <h1
        class="mt-5 font-heading text-5xl leading-[0.92] tracking-[-0.03em] text-foreground sm:text-6xl lg:text-7xl"
      >
        Wisata Lombok yang disusun dari pengalaman lokal, bukan dari template
      </h1>
      <p class="mt-6 max-w-xl text-base leading-8 text-text-muted sm:text-lg">
        Sungkar Group membantu Anda menjelajahi Lombok, Gili, Rinjani, dan
        Sumbawa lewat tur pribadi, transportasi yang rapi, dan itinerary yang
        terasa tenang sejak penjemputan pertama.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/kontak"
          class="inline-flex items-center justify-center rounded-full bg-brand-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-brand-700"
        >
          Cek Ketersediaan
        </a>
        <a
          href="/paket-wisata"
          class="inline-flex items-center justify-center rounded-full border border-border bg-white px-6 py-3 text-sm font-medium text-foreground transition-colors hover:border-brand-200 hover:bg-brand-50"
        >
          Lihat Itinerary
        </a>
      </div>

      <div
        class="mt-10 grid gap-4 border-t border-border/70 pt-8 sm:grid-cols-3"
      >
        {
          highlights.map((item, index) => (
            <div class={index === 1 ? "sm:text-center" : ""}>
              <div class="text-sm font-medium text-foreground">
                {item.title}
              </div>
              <p class="mt-2 text-sm leading-6 text-text-muted">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="lg:pt-14">
      <div
        class="overflow-hidden rounded-[2.25rem] border border-border bg-white shadow-[0_24px_70px_rgba(17,24,39,0.14)]"
      >
        <div class="grid gap-0 md:grid-cols-[0.95fr_1.05fr]">
          <div class="bg-white px-6 py-8 sm:px-8 sm:py-10">
            <div
              class="text-xs font-medium uppercase tracking-[0.24em] text-brand-700"
            >
              Sorotan singkat
            </div>
            <h2
              class="mt-3 font-heading text-3xl leading-tight text-foreground"
            >
              Waktu, rute, dan suasana dibuat lebih gampang dipahami
            </h2>
            <p class="mt-4 text-sm leading-7 text-text-muted">
              Halaman depan disusun untuk memberi gambaran cepat sebelum tamu
              masuk ke detail paket, destinasi, atau transportasi.
            </p>
          </div>
          <div class="min-h-64 bg-brand-50">
            <Image
              src={HeroLombok}
              alt="Lombok dari sudut pandang wisata"
              class="h-full w-full object-cover"
              loading={"eager"}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

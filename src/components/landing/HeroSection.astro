---
import { Image } from "astro:assets";
import { Button } from "@/components/ui/button";
import Hero from "@/assets/images/hero.webp";
import Hero1 from "@/assets/images/hero1.webp";
import DestinationGili from "@/assets/images/destination-gili.png";
import TourSnorkeling from "@/assets/images/tour-snorkeling.png";

const { HeroLombok } = Astro.props;
---

<section
  id="beranda"
  class="relative min-h-screen overflow-hidden bg-background"
>
  <div class="absolute inset-0">
    <Image
      src={Hero}
      alt="Pemandangan Lombok saat matahari terbit"
      class="h-full w-full object-top"
      loading="eager"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(36,73,98,0.25) 0%, rgba(36,73,98,0.12) 40%, transparent 95%);"
    >
    </div>
  </div>

  <div
    class="relative mx-auto flex w-full max-w-7xl items-center justify-between gap-6 px-4 min-h-screen sm:px-6 lg:gap-12 lg:px-8"
  >
    <!-- Left Content -->
    <div class="w-full lg:w-auto lg:flex-1 lg:max-w-2xl">
      <p
        class="text-sm font-medium uppercase tracking-[0.28em] drop-shadow-lg"
        style="color: var(--color-brand-50); text-shadow: 0 2px 8px rgba(0,0,0,0.3);"
      >
        Sungkar Group
      </p>
      <h1
        class="mt-6 font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[0.92] tracking-[-0.03em] drop-shadow-xl"
        style="color: var(--color-surface); text-shadow: 0 4px 12px rgba(0,0,0,0.4);"
      >
        Wisata Lombok yang disusun dari pengalaman lokal
      </h1>
      <p
        class="mt-4 sm:mt-6 max-w-xl text-sm sm:text-base lg:text-lg leading-7 sm:leading-8 drop-shadow-lg"
        style="color: var(--color-surface); text-shadow: 0 2px 8px rgba(0,0,0,0.3);"
      >
        Sungkar Group membantu Anda menjelajahi Lombok, Gili, Rinjani, dan
        Sumbawa lewat tur pribadi, transportasi yang rapi, dan itinerary yang
        terasa tenang sejak penjemputan pertama.
      </p>

      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row flex-wrap gap-3">
        <Button href="/kontak" variant="default" size="xl">
          Mulai Perjalanan Anda
        </Button>
        <Button href="/paket-wisata" variant="outline" size="xl">
          Jelajahi Paket
        </Button>
      </div>
    </div>

    <!-- Right Side - Stacked Cards (Hidden on mobile, visible on lg) -->
    <div
      class="hidden lg:block flex-1 h-full relative hero-cards-container"
      style="min-height: 600px;"
    >
      <div class="absolute inset-0 flex items-center justify-center">
        <!-- Card 1 - Main featured image (Center, front) -->
        <div
          class="hero-card card-1 absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
          style="width: 280px; height: 340px;"
        >
          <Image
            src={Hero1}
            alt="Destinasi wisata Lombok"
            class="hero-card-image w-full h-full object-cover"
            loading="eager"
          />
          <div
            class="hero-card-overlay absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end rounded-lg"
          >
            <div class="p-6 w-full">
              <h3 class="text-white font-heading text-xl">Destinasi Impian</h3>
              <p class="text-brand-50 text-sm mt-2">Jelajahi keindahan alam</p>
            </div>
          </div>
        </div>

        <!-- Card 2 - Secondary card (Right, back) -->
        <div
          class="hero-card card-2 absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
          style="width: 240px; height: 280px; right: 20px; top: 80px;"
        >
          <Image
            src={HeroLombok}
            alt="Pantai Lombok"
            class="hero-card-image w-full h-full object-cover"
            loading="eager"
          />
          <div
            class="hero-card-overlay absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent flex items-end rounded-lg"
          >
            <div class="p-4 w-full">
              <p class="text-white font-medium text-sm">Pantai Eksotis</p>
            </div>
          </div>
        </div>

        <!-- Card 3 - Accent card (Left, back) -->
        <div
          class="hero-card card-3 absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
          style="width: 220px; height: 260px; left: 40px; top: 120px;"
        >
          <Image
            src={DestinationGili}
            alt="Kepulauan Gili"
            class="hero-card-image w-full h-full object-cover"
            loading="eager"
          />
          <div
            class="hero-card-overlay absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end rounded-lg"
          >
            <div class="p-4 w-full">
              <p class="text-white font-medium text-sm">Kepulauan Gili</p>
            </div>
          </div>
        </div>

        <!-- Card 4 - New card (Right, further back) -->
        <div
          class="hero-card card-4 absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
          style="width: 200px; height: 240px; right: -10px; top: 200px;"
        >
          <Image
            src={TourSnorkeling}
            alt="Tur Snorkeling"
            class="hero-card-image w-full h-full object-cover"
            loading="eager"
          />
          <div
            class="hero-card-overlay absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent flex items-end rounded-lg"
          >
            <div class="p-3 w-full">
              <p class="text-white font-medium text-xs">Snorkeling</p>
            </div>
          </div>
        </div>

        <!-- Card 5 - New card (Left, further back) -->
        <div
          class="hero-card card-5 absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
          style="width: 180px; height: 220px; left: -20px; top: 240px;"
        >
          <div
            class="hero-card-image w-full h-full rounded-lg bg-gradient-to-br from-brand-400/30 to-brand-600/40 flex items-center justify-center flex-col p-3"
          >
            <div class="text-3xl mb-2">🏖️</div>
            <p class="text-white font-heading text-center text-sm">Pantai</p>
          </div>
          <div
            class="hero-card-overlay absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent flex items-end rounded-lg"
          >
            <div class="p-3 w-full">
              <p class="text-white font-medium text-xs">Pantai Santai</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  a[href] {
    text-decoration: none;
  }

  .hero-card {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center center;
  }

  .card-1 {
    z-index: 20;
  }

  .card-2 {
    z-index: 10;
  }

  .card-3 {
    z-index: 5;
  }

  .card-4 {
    z-index: 3;
  }

  .card-5 {
    z-index: 2;
  }

  .hero-card:hover {
    z-index: 100 !important;
  }

  .hero-card-image {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-card-overlay {
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }

  .hero-card:hover .hero-card-overlay {
    opacity: 1;
  }

  .card-1:hover {
    transform: rotate(-6deg) scale(1.1);
  }

  .card-1:hover .hero-card-image {
    transform: scale(1.1);
  }

  .card-2:hover {
    transform: rotate(6deg) scale(1.05) translateY(-32px);
  }

  .card-2:hover .hero-card-image {
    transform: scale(1.25);
  }

  .card-3:hover {
    transform: rotate(-12deg) scale(0.95);
  }

  .card-4:hover {
    transform: rotate(3deg) scale(1.05);
  }

  .card-5:hover {
    transform: rotate(-3deg) scale(0.95);
  }
</style>

---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Button } from "@/components/ui/button";
import FadeInText from "@astroanimate/core/FadeInText";

interface LandingAction {
  label: string;
  href: string;
  variant: "default" | "outline" | "ghost" | "secondary";
}

interface LandingHeroCard {
  className: string;
  style: string;
  image?: ImageMetadata;
  alt?: string;
  title: string;
  description?: string;
  emoji?: string;
  contentSizeClass: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryAction: LandingAction;
  secondaryAction: LandingAction;
  cards: LandingHeroCard[];
}

const { eyebrow, title, description, primaryAction, secondaryAction, cards } =
  Astro.props as Props;
---

<section
  id="beranda"
  class="relative min-h-screen overflow-hidden bg-background"
>
  <div class="absolute inset-0">
    <slot name="background" />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(36,73,98,0.25) 0%, rgba(36,73,98,0.12) 40%, transparent 95%);"
    >
    </div>
  </div>

  <FadeInText enhance={true} duration={0.9} blur={false}>
    <div
      class="relative mx-auto flex min-h-screen w-full max-w-7xl items-center justify-between gap-6 px-4 sm:px-6 lg:gap-12 lg:px-8"
    >
      <div class="w-full lg:w-auto lg:max-w-2xl lg:flex-1">
        <p
          class="text-sm font-medium uppercase tracking-[0.28em] drop-shadow-lg"
          style="color: var(--color-brand-50); text-shadow: 0 2px 8px rgba(0,0,0,0.3);"
        >
          {eyebrow}
        </p>
        <h1
          class="mt-6 font-heading text-4xl leading-[0.92] tracking-[-0.03em] drop-shadow-xl sm:text-5xl lg:text-6xl xl:text-7xl"
          style="color: var(--color-surface); text-shadow: 0 4px 12px rgba(0,0,0,0.4);"
        >
          {title}
        </h1>
        <p
          class="mt-4 max-w-xl text-sm leading-7 drop-shadow-lg sm:mt-6 sm:text-base sm:leading-8 lg:text-lg"
          style="color: var(--color-surface); text-shadow: 0 2px 8px rgba(0,0,0,0.3);"
        >
          {description}
        </p>

        <div class="mt-8 flex flex-col flex-wrap gap-3 sm:mt-10 sm:flex-row">
          <Button variant={primaryAction.variant} size="xl">
            <a href={primaryAction.href}>
              {primaryAction.label}
            </a>
          </Button>
          <Button variant={secondaryAction.variant} size="xl">
            <a href={secondaryAction.href}>
              {secondaryAction.label}
            </a>
          </Button>
        </div>
      </div>

      <div
        class="hero-cards-container relative hidden h-full flex-1 lg:block"
        style="min-height: 600px;"
      >
        <div class="absolute inset-0 flex items-center justify-center">
          {
            cards.map((card, index) => (
              <div
                class:list={[
                  "hero-card absolute overflow-hidden cursor-pointer rounded-lg bg-card ring-1 ring-foreground/10 shadow-[0_18px_45px_rgba(17,24,39,0.08)]",
                  card.className,
                ]}
                style={card.style}
              >
                {card.image ? (
                  <Image
                    src={card.image}
                    alt={card.alt ?? card.title}
                    class="hero-card-image h-full w-full object-cover"
                    loading="eager"
                    quality={70}
                    format="webp"
                  />
                ) : (
                  <div class="hero-card-image flex h-full w-full flex-col items-center justify-center rounded-lg bg-linear-to-br from-brand-400/30 to-brand-600/40 p-3">
                    <div class="mb-2 text-3xl">{card.emoji}</div>
                    <p class="text-center font-heading text-sm text-white">
                      {card.title}
                    </p>
                  </div>
                )}

                <div
                  class:list={[
                    "hero-card-overlay absolute inset-0 flex items-end rounded-lg bg-linear-to-t",
                    index === 1 || index === 3
                      ? "from-black/50 via-transparent to-transparent"
                      : "from-black/60 via-transparent to-transparent",
                  ]}
                >
                  <div class={card.contentSizeClass + " w-full"}>
                    {index === 0 ? (
                      <>
                        <h3 class="font-heading text-xl text-white">
                          {card.title}
                        </h3>
                        {card.description ? (
                          <p class="mt-2 text-sm text-brand-50">
                            {card.description}
                          </p>
                        ) : null}
                      </>
                    ) : index === 4 ? (
                      <p class="text-xs font-medium text-white">{card.title}</p>
                    ) : (
                      <p class="text-sm font-medium text-white">{card.title}</p>
                    )}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </FadeInText>
</section>

<style>
  a[href] {
    text-decoration: none;
  }

  .hero-card {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center center;
  }

  .card-1 {
    z-index: 20;
  }

  .card-2 {
    z-index: 10;
  }

  .card-3 {
    z-index: 5;
  }

  .card-4 {
    z-index: 3;
  }

  .card-5 {
    z-index: 2;
  }

  .hero-card:hover {
    z-index: 100 !important;
  }

  .hero-card-image {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-card-overlay {
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }

  .hero-card:hover .hero-card-overlay {
    opacity: 1;
  }

  .card-1:hover {
    transform: rotate(-6deg) scale(1.1);
  }

  .card-1:hover .hero-card-image {
    transform: scale(1.1);
  }

  .card-2:hover {
    transform: rotate(6deg) scale(1.05) translateY(-32px);
  }

  .card-2:hover .hero-card-image {
    transform: scale(1.25);
  }

  .card-3:hover {
    transform: rotate(-12deg) scale(0.95);
  }

  .card-4:hover {
    transform: rotate(3deg) scale(1.05);
  }

  .card-5:hover {
    transform: rotate(-3deg) scale(0.95);
  }
</style>

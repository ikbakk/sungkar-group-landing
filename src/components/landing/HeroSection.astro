---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryAction: {
    label: string;
    href: string;
  };
  secondaryAction: {
    label: string;
    href: string;
  };
  image: ImageMetadata;
  imageAlt?: string;
}

const { eyebrow, title, description, primaryAction, secondaryAction, image, imageAlt } =
  Astro.props as Props;
---

<section
  class="relative flex min-h-[100dvh] items-end overflow-hidden bg-brand-900 pt-24"
>
  <Image
    src={image}
    alt={imageAlt ?? title}
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
    quality={85}
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
  />

  <div class="absolute inset-0 bg-gradient-to-t from-brand-900/70 via-brand-900/20 to-transparent" />

  <div class="relative z-10 mx-auto flex w-full max-w-7xl items-end px-4 pb-10 sm:px-6 sm:pb-14 lg:pb-20 lg:px-8">
    <div
      class="w-full rounded-2xl border border-white/10 bg-background/90 p-8 shadow-xl backdrop-blur-md sm:p-10 lg:max-w-2xl xl:max-w-3xl xl:p-12"
    >
      <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.2em] text-brand-600 sm:text-sm">
        <span>{eyebrow}</span>
      </div>

      <h1
        class="mt-5 font-heading text-3xl leading-[1.08] tracking-[-0.02em] text-foreground sm:text-4xl lg:text-5xl xl:text-6xl"
      >
        {title}
      </h1>

      <p
        class="mt-4 max-w-xl text-sm leading-relaxed text-muted-foreground sm:text-base lg:text-lg"
      >
        {description}
      </p>

      <div class="mt-8 flex flex-col flex-wrap gap-3 sm:flex-row">
        <a
          href={primaryAction.href}
          class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600/50"
        >
          {primaryAction.label}
        </a>
        <a
          href={secondaryAction.href}
          class="inline-flex items-center justify-center rounded-lg border-2 border-foreground px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-foreground hover:text-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground/30"
        >
          {secondaryAction.label}
        </a>
      </div>
    </div>
  </div>
</section>

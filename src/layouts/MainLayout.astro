---
import Header from "@/components/header/Header.astro";
import Footer from "@/components/site/Footer.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import { generateOrganizationSchema, generateWebsiteSchema } from "@/lib/schemas";
import "../styles/global.css";
import FadeInText from "@astroanimate/core/FadeInText";
import type { ImageMetadata } from "astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: ImageMetadata | string;
  imageAlt?: string;
  noIndex?: boolean;
}

const {
  title = "Sungkar Group",
  description = "Operator wisata Lombok berbasis lokal untuk tur pribadi, destinasi, transportasi, ulasan, dan panduan wisata.",
  canonical,
  image,
  noIndex = false,
} = Astro.props as Props;

const siteTitle =
  title === "Sungkar Group" ? title : `${title} | Sungkar Group`;
const imageUrl = typeof image === "string" ? image : image?.src;

const siteUrl = new URL(Astro.url.origin).toString().replace(/\/$/, "");
const organizationSchema = generateOrganizationSchema(siteUrl);
const websiteSchema = generateWebsiteSchema(siteUrl);
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:locale" content="id_ID" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sungkar Group" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta
      name="twitter:card"
      content={imageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <!-- Global Structured Data -->
    <StructuredData schema={organizationSchema} />
    <StructuredData schema={websiteSchema} />
  </head>
  <body>
    <Header />
    <main id="content">
      <FadeInText duration={0.4}>
        <slot />
      </FadeInText>
    </main>
    <Footer />
  </body>
</html>

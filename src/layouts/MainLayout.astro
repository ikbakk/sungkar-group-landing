---
import Header from "@/components/header/Header.astro";
import Footer from "@/components/site/Footer.astro";
import WhatsAppFloat from "@/components/ui/WhatsAppFloat.astro";
import CookieConsentBanner from "@/components/site/CookieConsentBanner";
import GoogleAnalytics from "@/components/seo/GoogleAnalytics.astro";
import MicrosoftClarity from "@/components/seo/MicrosoftClarity.astro";
import SEOMeta from "@/components/seo/SEOMeta.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import type { Locale } from "@/lib/i18n";

import {
  generateOrganizationSchema,
  generateWebsiteSchema,
  graphSchema,
} from "@/lib/schemas";

import { getPageOGMetadata } from "@/lib/og-metadata";

import type { ImageSource } from "@/lib/images";

import { SITE_URL } from "@/lib/site-config";

import { isRTL } from "@/lib/i18n";

import { ClientRouter } from "astro:transitions";

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: ImageSource;
  imageAlt?: string;
  ogType?: "website" | "article" | "profile";
  noIndex?: boolean;
  locale?: string;
  enableClientRouter?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  ogType = "website",
  noIndex = false,
  locale = "id",
  enableClientRouter = false,
} = Astro.props as Props;

const currentLocale = locale;

const pathOGMetadata = getPageOGMetadata(Astro.url.pathname);

const pageTitle = title ?? pathOGMetadata.title;

const pageDescription = description ?? pathOGMetadata.description;

const pageImage = image ?? pathOGMetadata.image;

const pageImageAlt = imageAlt ?? pathOGMetadata.imageAlt;

const siteUrl = SITE_URL;

const siteGraphSchema = graphSchema([
  generateOrganizationSchema(siteUrl),
  generateWebsiteSchema(siteUrl),
]);
---

<html lang={currentLocale} dir={isRTL(currentLocale) ? "rtl" : "ltr"}>
  <head>
    <SEOMeta
      title={pageTitle}
      description={pageDescription}
      canonical={canonical}
      ogImage={pageImage}
      ogImageAlt={pageImageAlt}
      ogType={ogType}
      noIndex={noIndex}
      locale={currentLocale}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sungkar Group Blog Feed"
      href="/feed.xml"
    />

    <StructuredData schema={siteGraphSchema} />

    <GoogleAnalytics />
    <MicrosoftClarity />

    {enableClientRouter && <ClientRouter />}

    <!-- Netlify Identity: redirect invite/password-recovery/confirmation to /admin/ -->
    <script>
      (function () {
        var hash = window.location.hash;
        if (
          hash &&
          (hash.indexOf("invite_token") !== -1 ||
            hash.indexOf("confirmation_token") !== -1 ||
            hash.indexOf("recovery_token") !== -1)
        ) {
          window.location.replace("/admin/" + hash);
        }
      })();
    </script>
  </head>

  <body>
    <a
      href="#content"
      class="fixed left-4 top-4 z-[100] -translate-y-20 rounded-md bg-white px-4 py-2 text-sm font-semibold text-brand-900 shadow-lg transition-transform focus:translate-y-0 focus:outline-none focus:ring-2 focus:ring-brand-500"
    >
      Skip to main content
    </a>

    <Header locale={currentLocale} />

    <main id="content" tabindex="-1">
      <slot />
    </main>

    <Footer locale={currentLocale} />

    <WhatsAppFloat />
    <CookieConsentBanner locale={currentLocale as Locale} client:idle />
  </body>
</html>

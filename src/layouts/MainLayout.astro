---
import Header from "@/components/header/Header.astro";
import Footer from "@/components/site/Footer.astro";
import CookieConsentBanner from "@/components/site/CookieConsentBanner";
import GoogleAnalytics from "@/components/seo/GoogleAnalytics.astro";
import SEOMeta from "@/components/seo/SEOMeta.astro";
import StructuredData from "@/components/seo/StructuredData.astro";
import type { Locale } from "@/lib/i18n";

import {
  generateOrganizationSchema,
  generateWebsiteSchema,
} from "@/lib/schemas";

import { getPageOGMetadata } from "@/lib/og-metadata";

import type { ImageSource } from "@/lib/images";

import { SITE_URL } from "@/lib/site-config";

import { isRTL } from "@/lib/i18n";

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: ImageSource;
  imageAlt?: string;
  ogType?: "website" | "article" | "profile";
  noIndex?: boolean;
  locale?: string;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  ogType = "website",
  noIndex = false,
  locale = "id",
} = Astro.props as Props;

const currentLocale = locale;

const pathOGMetadata = getPageOGMetadata(Astro.url.pathname);

const pageTitle = title ?? pathOGMetadata.title;

const pageDescription = description ?? pathOGMetadata.description;

const pageImage = image ?? pathOGMetadata.image;

const pageImageAlt = imageAlt ?? pathOGMetadata.imageAlt;

const siteUrl = SITE_URL;

const organizationSchema = generateOrganizationSchema(siteUrl);

const websiteSchema = generateWebsiteSchema(siteUrl);
---

<html lang={currentLocale} dir={isRTL(currentLocale) ? "rtl" : "ltr"}>
  <head>
    <SEOMeta
      title={pageTitle}
      description={pageDescription}
      canonical={canonical}
      ogImage={pageImage}
      ogImageAlt={pageImageAlt}
      ogType={ogType}
      noIndex={noIndex}
      locale={currentLocale}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <StructuredData schema={organizationSchema} />
    <StructuredData schema={websiteSchema} />

    <GoogleAnalytics />

    <!-- Netlify Identity: redirect invite/password-recovery/confirmation to /admin/ -->
    <script>
      (function () {
        var hash = window.location.hash;
        if (
          hash &&
          (hash.indexOf("invite_token") !== -1 ||
            hash.indexOf("confirmation_token") !== -1 ||
            hash.indexOf("recovery_token") !== -1)
        ) {
          window.location.replace("/admin/" + hash);
        }
      })();
    </script>
  </head>

  <body>
    <Header locale={currentLocale} />

    <main id="content">
      <slot />
    </main>

    <Footer locale={currentLocale} />

    <CookieConsentBanner locale={currentLocale as Locale} client:load />
  </body>
</html>
